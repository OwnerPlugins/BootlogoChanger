msgid "Activate the debug-output on console"
msgstr "କନସୋଲରେ ଡିବଗ୍-ଆଉଟପୁଟ୍ ସକ୍ରିୟ କରନ୍ତୁ |"

msgid "Bootlogo is excluded from random selection"
msgstr "ବୁଟଲୋଗୋ ଅନିୟମିତ ଚୟନରୁ ବାଦ ଦିଆଯାଇଛି |"

msgid "Bootlogo is included in random selection"
msgstr "ବୁଟଲୋଗୋ ଅନିୟମିତ ଚୟନରେ ଅନ୍ତର୍ଭୁକ୍ତ |"

msgid "Cancel"
msgstr "ବାତିଲ୍ କରନ୍ତୁ |"

msgid "Choose random bootlogo at the start of the box"
msgstr "ବାକ୍ସର ଆରମ୍ଭରେ ଅନିୟମିତ ବୁଟଲୋଗୋ ବାଛନ୍ତୁ |"

msgid "Copy logofiles failed"
msgstr "ଲୋଗୋଫାଇଲ୍ କପି ବିଫଳ ହେଲା |"

msgid "Current bootlogo"
msgstr "ସାମ୍ପ୍ରତିକ ବୁଟଲୋଗୋ |"

msgid "Debugmode"
msgstr "ତ୍ରୁଟି ନିବାରଣ ଧାରା"

msgid "Deinstallation of FFmpeg failed"
msgstr "FFmpeg ର ବିସ୍ଥାପନ ବିଫଳ ହେଲା |"

msgid "Delete current mvi-files before changing bootlogo"
msgstr "ବୁଟଲୋଗୋ ପରିବର୍ତ୍ତନ କରିବା ପୂର୍ବରୁ ସାମ୍ପ୍ରତିକ mvi- ଫାଇଲଗୁଡ଼ିକୁ ଡିଲିଟ୍ କରନ୍ତୁ |"

msgid "Directory with bootlogo folders"
msgstr "ବୁଟଲୋଗୋ ଫୋଲ୍ଡରଗୁଡ଼ିକ ସହିତ ଡିରେକ୍ଟୋରୀ |"

msgid "Display duration of the status messages (sec)"
msgstr "ସ୍ଥିତି ସନ୍ଦେଶଗୁଡ଼ିକର ସମୟସୀମା ପ୍ରଦର୍ଶନ କରନ୍ତୁ (ସେକେଣ୍ଡ୍)"

msgid "Easily switch between different bootlogos"
msgstr "ବିଭିନ୍ନ ବୁଟଲୋଗସ୍ ମଧ୍ୟରେ ସହଜରେ ସୁଇଚ୍ କରନ୍ତୁ |"

msgid "Exclude"
msgstr "ବାଦ ଦିଅନ୍ତୁ |"

msgid "Exit plugin without saving"
msgstr "ସଞ୍ଚୟ ନକରି ପ୍ଲଗଇନ୍ ଛାଡନ୍ତୁ |"

msgid "FFmpeg is needed to generate thumbnails from the mvi files"
msgstr "Mvi ଫାଇଲଗୁଡ଼ିକରୁ ଥମ୍ବନେଲ ସୃଷ୍ଟି କରିବାକୁ FFmpeg ଆବଶ୍ୟକ |"

msgid "FFmpeg ist missing, no preview pictures available - there is an option to install it in the stettings"
msgstr "FFmpeg ହଜିଯାଇଛି, କ pre ଣସି ପୂର୍ବାବଲୋକନ ଚିତ୍ର ଉପଲବ୍ଧ ନାହିଁ - ଏହାକୁ ଷ୍ଟେଟିଙ୍ଗରେ ସଂସ୍ଥାପନ କରିବାର ଏକ ବିକଳ୍ପ ଅଛି |"

msgid "FFmpeg removed successfully"
msgstr "FFmpeg ସଫଳତାର ସହିତ ଅପସାରିତ ହେଲା |"

msgid "FFmpeg successfully installed"
msgstr "FFmpeg ସଫଳତାର ସହିତ ସଂସ୍ଥାପିତ ହୋଇଛି |"

msgid "First delete the mvi-files of the current bootlogo then copy the files of the new one"
msgstr "ପ୍ରଥମେ ସାମ୍ପ୍ରତିକ ବୁଟଲୋଗୋର mvi- ଫାଇଲଗୁଡ଼ିକୁ ଡିଲିଟ୍ କର ଏବଂ ତା’ପରେ ନୂଆ ଫାଇଲଗୁଡ଼ିକୁ କପି କର |"

msgid "Found bootlogos"
msgstr "ବୁଟଲୋଗସ୍ ମିଳିଲା |"

msgid "Full screen view the selected bootlogo"
msgstr "ମନୋନୀତ ବୁଟଲୋଗୋକୁ ପୂର୍ଣ୍ଣ ସ୍କ୍ରିନ୍ ଦର୍ଶନ କରନ୍ତୁ |"

msgid "Hide directories without 'mvi'-files"
msgstr "'Mvi'- ଫାଇଲ୍ ବିନା ଡିରେକ୍ଟୋରୀଗୁଡିକ ଲୁଚାନ୍ତୁ |"

msgid "Hide empty directories"
msgstr "ଖାଲି ଡିରେକ୍ଟୋରୀଗୁଡିକ ଲୁଚାନ୍ତୁ |"

msgid "How many seconds should status messages be displayed (1-60 sec)"
msgstr "ଷ୍ଟାଟସ୍ ମେସେଜ୍ ଗୁଡିକ କେତେ ସେକେଣ୍ଡ୍ ପ୍ରଦର୍ଶିତ ହେବା ଉଚିତ୍ (1-60 ସେକେଣ୍ଡ୍)"

msgid "Include"
msgstr "ଅନ୍ତର୍ଭୂକ୍ତ କରନ୍ତୁ |"

msgid "Include or exlude logo in random choice"
msgstr "ଅନିୟମିତ ପସନ୍ଦରେ ଲୋଗୋ ଅନ୍ତର୍ଭୂକ୍ତ କରନ୍ତୁ କିମ୍ବା ବାଦ ଦିଅନ୍ତୁ |"

msgid "Included Screens"
msgstr "ପରଦା ଅନ୍ତର୍ଭୁକ୍ତ |"

msgid "Install/deinstall ffmpeg"
msgstr "Ffmpeg ସଂସ୍ଥାପନ / ସଂସ୍ଥାପନ କରନ୍ତୁ |"

msgid "Installation of FFmpeg failed"
msgstr "FFmpeg ର ସ୍ଥାପନ ବିଫଳ ହେଲା"

msgid "No bootlogos found in directory"
msgstr "ଡିରେକ୍ଟୋରୀରେ କ boot ଣସି ବୁଟଲୋଗସ୍ ମିଳିଲା ନାହିଁ |"

msgid "OK"
msgstr "ଠିକ ଅଛି |"

msgid "Open settings"
msgstr "ସେଟିଂସମୂହ ଖୋଲନ୍ତୁ |"

msgid "Preview Logo"
msgstr "ଲୋଗୋ ପୂର୍ବାବଲୋକନ କରନ୍ତୁ |"

msgid "Preview picture"
msgstr "ଛବି ପୂର୍ବାବଲୋକନ"

msgid "Random mode"
msgstr "ଅନିୟମିତ ମୋଡ୍ |"

msgid "Random selection at startup disabled"
msgstr "ଷ୍ଟାର୍ଟଅପ୍ ରେ ଅନିୟମିତ ଚୟନ ଅକ୍ଷମ |"

msgid "Random selection at startup enabled"
msgstr "ଷ୍ଟାର୍ଟଅପ୍ ରେ ଅନିୟମିତ ଚୟନ ସକ୍ଷମ |"

msgid "Save Changes and exit plugin"
msgstr "ପରିବର୍ତ୍ତନଗୁଡିକ ସଞ୍ଚୟ କରନ୍ତୁ ଏବଂ ପ୍ଲଗଇନ୍ ଛାଡନ୍ତୁ |"

msgid "Search for folders with boot logos in this directory"
msgstr "ଏହି ଡିରେକ୍ଟୋରୀରେ ବୁଟ ଲୋଗୋ ସହିତ ଫୋଲ୍ଡରଗୁଡ଼ିକୁ ଖୋଜ |"

msgid "Which bootlogos should be displayed?"
msgstr "କେଉଁ ବୁଟଲୋଗସ୍ ପ୍ରଦର୍ଶିତ ହେବା ଉଚିତ୍?"

msgid "Which logo should be displayed as a preview picture?"
msgstr "କେଉଁ ଲୋଗୋ ଏକ ପୂର୍ବାବଲୋକନ ଚିତ୍ର ଭାବରେ ପ୍ରଦର୍ଶିତ ହେବା ଉଚିତ୍?"

msgid "[BootlogoChanger] activated new bootlogo"
msgstr "[BootlogoChanger] ନୂତନ ବୁଟଲୋଗୋ ସକ୍ରିୟ କଲା |"

msgid "[BootlogoChanger] activating new bootlogo failed"
msgstr "[BootlogoChanger] ନୂତନ ବୁଟଲୋଗୋ ସକ୍ରିୟ କରିବାରେ ବିଫଳ ହେଲା |"

msgid "[BootlogoChanger] copy failed"
msgstr "[BootlogoChanger] କପି ବିଫଳ ହେଲା |"

msgid "[BootlogoChanger] deleting old bootlogo files"
msgstr "[BootlogoChanger] ପୁରୁଣା ବୁଟଲୋଗୋ ଫାଇଲଗୁଡ଼ିକୁ ଡିଲିଟ କରିବା |"

msgid "[BootlogoChanger] deleting previewPicture"
msgstr "[BootlogoChanger] ପୂର୍ବାବଲୋକନ ବିଲୋପ କରିବା |"

msgid "[BootlogoChanger] ffmpeg not found"
msgstr "[BootlogoChanger] ffmpeg ମିଳିଲା ନାହିଁ |"

msgid "[BootlogoChanger] found Bootlogos"
msgstr "[BootlogoChanger] Bootlogos ପାଇଲା |"

msgid "[BootlogoChanger] found ffmpeg"
msgstr "[BootlogoChanger] ffmpeg ପାଇଲା |"

msgid "[BootlogoChanger] no bootlogos for randomization selected"
msgstr "[BootlogoChanger] ରାଣ୍ଡୋମାଇଜେସନ୍ ପାଇଁ କ boot ଣସି ବୁଟଲୋଗସ୍ ଚୟନ କରାଯାଇ ନାହିଁ |"

msgid "[BootlogoChanger] previewPicture changed"
msgstr "[BootlogoChanger] ପୂର୍ବାବଲୋକନ ଚିତ୍ର ବଦଳିଗଲା |"

msgid "[BootlogoChanger] randomization of bootlogos activated"
msgstr "[BootlogoChanger] bootlogos ର randomization ସକ୍ରିୟ ହୋଇଛି |"

msgid "[BootlogoChanger] randomization of bootlogos deactivated"
msgstr "[BootlogoChanger] ବୁଟଲୋଗୋ ର ରାଣ୍ଡୋମାଇଜେସନ୍ ନିଷ୍କ୍ରିୟ ହୋଇଛି |"

msgid "[BootlogoChanger] randomization: bootlogo found"
msgstr "[BootlogoChanger] ରାଣ୍ଡୋମାଇଜେସନ୍: ବୁଟଲୋଗୋ ମିଳିଲା |"

msgid "[BootlogoChanger] selected bootlogos"
msgstr "[BootlogoChanger] ମନୋନୀତ ବୁଟଲୋଗସ୍ |"

msgid "deinstall"
msgstr "ସଂସ୍ଥାପନ କରନ୍ତୁ"

msgid "found"
msgstr "ମିଳିଲା"

msgid "install"
msgstr "ସଂସ୍ଥାପନ କରନ୍ତୁ |"

