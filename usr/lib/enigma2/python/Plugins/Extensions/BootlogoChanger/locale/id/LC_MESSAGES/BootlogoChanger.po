msgid "Activate the debug-output on console"
msgstr "Aktifkan output debug di konsol"

msgid "Bootlogo is excluded from random selection"
msgstr "Bootlogo dikecualikan dari pemilihan acak"

msgid "Bootlogo is included in random selection"
msgstr "Bootlogo disertakan dalam pemilihan acak"

msgid "Cancel"
msgstr "Membatalkan"

msgid "Choose random bootlogo at the start of the box"
msgstr "Pilih bootlogo acak di awal kotak"

msgid "Copy logofiles failed"
msgstr "Gagal menyalin file logo"

msgid "Current bootlogo"
msgstr "Bootlogo saat ini"

msgid "Debugmode"
msgstr "Modus debug"

msgid "Deinstallation of FFmpeg failed"
msgstr "Penghapusan instalasi FFmpeg gagal"

msgid "Delete current mvi-files before changing bootlogo"
msgstr "Hapus file mvi saat ini sebelum mengubah bootlogo"

msgid "Directory with bootlogo folders"
msgstr "Direktori dengan folder bootlogo"

msgid "Display duration of the status messages (sec)"
msgstr "Menampilkan durasi pesan status (detik)"

msgid "Easily switch between different bootlogos"
msgstr "Beralih dengan mudah di antara bootlogo yang berbeda"

msgid "Exclude"
msgstr "Mengecualikan"

msgid "Exit plugin without saving"
msgstr "Keluar dari plugin tanpa menyimpan"

msgid "FFmpeg is needed to generate thumbnails from the mvi files"
msgstr "FFmpeg diperlukan untuk menghasilkan thumbnail dari file mvi"

msgid "FFmpeg ist missing, no preview pictures available - there is an option to install it in the stettings"
msgstr "FFmpeg tidak ada, tidak ada gambar pratinjau yang tersedia - ada opsi untuk menginstalnya di pengaturan"

msgid "FFmpeg removed successfully"
msgstr "FFmpeg berhasil dihapus"

msgid "FFmpeg successfully installed"
msgstr "FFmpeg berhasil diinstal"

msgid "First delete the mvi-files of the current bootlogo then copy the files of the new one"
msgstr "Pertama-tama hapus file mvi dari bootlogo saat ini, lalu salin file yang baru"

msgid "Found bootlogos"
msgstr "Ditemukan bootlogo"

msgid "Full screen view the selected bootlogo"
msgstr "Tampilan layar penuh bootlogo yang dipilih"

msgid "Hide directories without 'mvi'-files"
msgstr "Sembunyikan direktori tanpa file 'mvi'"

msgid "Hide empty directories"
msgstr "Sembunyikan direktori kosong"

msgid "How many seconds should status messages be displayed (1-60 sec)"
msgstr "Berapa detik pesan status harus ditampilkan (1-60 detik)"

msgid "Include"
msgstr "Termasuk"

msgid "Include or exlude logo in random choice"
msgstr "Sertakan atau kecualikan logo dalam pilihan acak"

msgid "Included Screens"
msgstr "Layar yang Disertakan"

msgid "Install/deinstall ffmpeg"
msgstr "Instal/copot pemasangan ffmpeg"

msgid "Installation of FFmpeg failed"
msgstr "Instalasi FFmpeg gagal"

msgid "No bootlogos found in directory"
msgstr "Tidak ada bootlogo yang ditemukan di direktori"

msgid "OK"
msgstr "OKE"

msgid "Open settings"
msgstr "Buka pengaturan"

msgid "Preview Logo"
msgstr "Pratinjau Logo"

msgid "Preview picture"
msgstr "Pratinjau gambar"

msgid "Random mode"
msgstr "Modus acak"

msgid "Random selection at startup disabled"
msgstr "Pilihan acak saat startup dinonaktifkan"

msgid "Random selection at startup enabled"
msgstr "Pilihan acak saat startup diaktifkan"

msgid "Save Changes and exit plugin"
msgstr "Simpan Perubahan dan keluar dari plugin"

msgid "Search for folders with boot logos in this directory"
msgstr "Cari folder dengan logo boot di direktori ini"

msgid "Which bootlogos should be displayed?"
msgstr "Bootlogo mana yang harus ditampilkan?"

msgid "Which logo should be displayed as a preview picture?"
msgstr "Logo mana yang harus ditampilkan sebagai gambar pratinjau?"

msgid "[BootlogoChanger] activated new bootlogo"
msgstr "[BootlogoChanger] mengaktifkan bootlogo baru"

msgid "[BootlogoChanger] activating new bootlogo failed"
msgstr "[BootlogoChanger] gagal mengaktifkan bootlogo baru"

msgid "[BootlogoChanger] copy failed"
msgstr "Penyalinan [BootlogoChanger] gagal"

msgid "[BootlogoChanger] deleting old bootlogo files"
msgstr "[BootlogoChanger] menghapus file bootlogo lama"

msgid "[BootlogoChanger] deleting previewPicture"
msgstr "[BootlogoChanger] menghapus previewPicture"

msgid "[BootlogoChanger] ffmpeg not found"
msgstr "[BootlogoChanger] ffmpeg tidak ditemukan"

msgid "[BootlogoChanger] found Bootlogos"
msgstr "[BootlogoChanger] menemukan Bootlogo"

msgid "[BootlogoChanger] found ffmpeg"
msgstr "[BootlogoChanger] menemukan ffmpeg"

msgid "[BootlogoChanger] no bootlogos for randomization selected"
msgstr "[BootlogoChanger] tidak ada bootlogo untuk pengacakan yang dipilih"

msgid "[BootlogoChanger] previewPicture changed"
msgstr "[BootlogoChanger] pratinjauGambar berubah"

msgid "[BootlogoChanger] randomization of bootlogos activated"
msgstr "[BootlogoChanger] pengacakan bootlogo diaktifkan"

msgid "[BootlogoChanger] randomization of bootlogos deactivated"
msgstr "[BootlogoChanger] pengacakan bootlogo dinonaktifkan"

msgid "[BootlogoChanger] randomization: bootlogo found"
msgstr "Pengacakan [BootlogoChanger]: bootlogo ditemukan"

msgid "[BootlogoChanger] selected bootlogos"
msgstr "[BootlogoChanger] bootlogo yang dipilih"

msgid "deinstall"
msgstr "hapus instalan"

msgid "found"
msgstr "ditemukan"

msgid "install"
msgstr "memasang"

msgid "missing"
msgstr "hilang"

msgid "off"
msgstr "mati"

msgid "on"
msgstr "pada"
