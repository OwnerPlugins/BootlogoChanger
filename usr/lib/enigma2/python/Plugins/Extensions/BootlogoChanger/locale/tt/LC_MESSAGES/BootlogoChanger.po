msgid "Activate the debug-output on console"
msgstr "Консолда төзәтүне чыгаруны активлаштырыгыз"

msgid "Bootlogo is excluded from random selection"
msgstr "Ботлого очраклы сайлаудан чыгарыла"

msgid "Bootlogo is included in random selection"
msgstr "Ботлого очраклы сайлауда кертелгән"

msgid "Cancel"
msgstr "Баш тарту"

msgid "Choose random bootlogo at the start of the box"
msgstr "Рамка башында очраклы bootlogo сайлагыз"

msgid "Copy logofiles failed"
msgstr "Логофайлларны күчерү уңышсыз"

msgid "Current bootlogo"
msgstr "Хәзерге ботлого"

msgid "Debugmode"
msgstr "Чишү режимы"

msgid "Deinstallation of FFmpeg failed"
msgstr "FFmpeg-ны бетерү уңышсыз булды"

msgid "Delete current mvi-files before changing bootlogo"
msgstr "Ботлогоны алыштырганчы хәзерге mvi-файлларны бетерегез"

msgid "Directory with bootlogo folders"
msgstr "Ботлого папкалары белән каталог"

msgid "Display duration of the status messages (sec)"
msgstr "Статус хәбәрләренең озынлыгын күрсәтү (сек)"

msgid "Easily switch between different bootlogos"
msgstr "Төрле ботлоглар арасында җиңел күчү"

msgid "Exclude"
msgstr "Чыгарыгыз"

msgid "Exit plugin without saving"
msgstr "Плагинны сакламыйча чыгу"

msgid "FFmpeg is needed to generate thumbnails from the mvi files"
msgstr "MF файлларыннан эскизлар ясау өчен FFmpeg кирәк"

msgid "FFmpeg ist missing, no preview pictures available - there is an option to install it in the stettings"
msgstr "FFmpeg юкка чыга, алдан карау рәсемнәре юк - аны көйләүләргә урнаштыру мөмкинлеге бар"

msgid "FFmpeg removed successfully"
msgstr "FFmpeg уңышлы бетерелде"

msgid "FFmpeg successfully installed"
msgstr "FFmpeg уңышлы урнаштырылган"

msgid "First delete the mvi-files of the current bootlogo then copy the files of the new one"
msgstr "Башта хәзерге bootlogo-ның mvi-файлларын бетерегез, аннары яңасының файлларын күчерегез"

msgid "Found bootlogos"
msgstr "Ботлоглар табылды"

msgid "Full screen view the selected bootlogo"
msgstr "Сайланган ботлого тулы экран күренеше"

msgid "Hide directories without 'mvi'-files"
msgstr "'Mvi'-файлсыз каталогларны яшерегез"

msgid "Hide empty directories"
msgstr "Буш каталогларны яшерегез"

msgid "How many seconds should status messages be displayed (1-60 sec)"
msgstr "Статус хәбәрләре ничә секунд күрсәтелергә тиеш (1-60 сек)"

msgid "Include"
msgstr "Керегез"

msgid "Include or exlude logo in random choice"
msgstr "Логотипны очраклы сайлауда кертегез яки чыгарыгыз"

msgid "Included Screens"
msgstr "Экраннар"

msgid "Install/deinstall ffmpeg"
msgstr "Ffmpeg урнаштыру / бетерү"

msgid "Installation of FFmpeg failed"
msgstr "FFmpeg урнаштыру уңышсыз булды"

msgid "No bootlogos found in directory"
msgstr "Каталогта бернинди ботлог та табылмады"

msgid "OK"
msgstr "Ярар"

msgid "Open settings"
msgstr "Ачык көйләүләр"

msgid "Preview Logo"
msgstr "Логотипны карау"

msgid "Preview picture"
msgstr "Рәсемне карау"

msgid "Random mode"
msgstr "Очраклы режим"

msgid "Random selection at startup disabled"
msgstr "Стартапта очраклы сайлау инвалид"

msgid "Random selection at startup enabled"
msgstr "Стартта очраклы сайлау кушылган"

msgid "Save Changes and exit plugin"
msgstr "Esзгәрешләрне саклагыз һәм плагиннан чыгу"

msgid "Search for folders with boot logos in this directory"
msgstr "Бу каталогтагы ботинка логотиплары булган папкаларны эзләгез"

msgid "Which bootlogos should be displayed?"
msgstr "Кайсы ботлоглар күрсәтелергә тиеш?"

msgid "Which logo should be displayed as a preview picture?"
msgstr "Кайсы логотипны алдан карау рәсеме итеп күрсәтергә кирәк?"

msgid "[BootlogoChanger] activated new bootlogo"
msgstr "[BootlogoChanger] яңа bootlogo активлаштырды"

msgid "[BootlogoChanger] activating new bootlogo failed"
msgstr "[BootlogoChanger] яңа bootlogoны активлаштыру уңышсыз булды"

msgid "[BootlogoChanger] copy failed"
msgstr "[BootlogoChanger] күчермәсе уңышсыз"

msgid "[BootlogoChanger] deleting old bootlogo files"
msgstr "[BootlogoChanger] иске bootlogo файлларын бетерү"

msgid "[BootlogoChanger] deleting previewPicture"
msgstr "[BootlogoChanger] алдан карауPicture бетерү"

msgid "[BootlogoChanger] ffmpeg not found"
msgstr "[BootlogoChanger] ffmpeg табылмады"

msgid "[BootlogoChanger] found Bootlogos"
msgstr "[BootlogoChanger] Bootlogos тапты"

msgid "[BootlogoChanger] found ffmpeg"
msgstr "[BootlogoChanger] ffmpeg тапты"

msgid "[BootlogoChanger] no bootlogos for randomization selected"
msgstr "[BootlogoChanger] рандуизация өчен ботлоглар сайланмаган"

msgid "[BootlogoChanger] previewPicture changed"
msgstr "[BootlogoChanger] алдан карауPicture үзгәрде"

msgid "[BootlogoChanger] randomization of bootlogos activated"
msgstr "[BootlogoChanger] bootlogos рандуизациясе активлашты"

msgid "[BootlogoChanger] randomization of bootlogos deactivated"
msgstr "[BootlogoChanger] ботлогларның рандуизациясе туктатылды"

msgid "[BootlogoChanger] randomization: bootlogo found"
msgstr "[BootlogoChanger] рандуизация: bootlogo табылды"

msgid "[BootlogoChanger] selected bootlogos"
msgstr "[BootlogoChanger] сайланган ботлоглар"

msgid "deinstall"
msgstr "бетерү"

msgid "found"
msgstr "табылды"

msgid "install"
msgstr "урнаштыру"

msgid "missing"
msgstr "югалган"

msgid "off"
msgstr "сүндерелгән"

msgid "on"
msgstr "өстендә"
