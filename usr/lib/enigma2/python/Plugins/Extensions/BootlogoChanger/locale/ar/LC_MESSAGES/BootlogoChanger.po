msgid "Activate the debug-output on console"
msgstr "قم بتنشيط إخراج التصحيح على وحدة التحكم"

msgid "Bootlogo is excluded from random selection"
msgstr "يتم استبعاد Bootlogo من الاختيار العشوائي"

msgid "Bootlogo is included in random selection"
msgstr "يتم تضمين Bootlogo في الاختيار العشوائي"

msgid "Cancel"
msgstr "يلغي"

msgid "Choose random bootlogo at the start of the box"
msgstr "اختر شعار تمهيد عشوائيًا في بداية المربع"

msgid "Copy logofiles failed"
msgstr "فشل نسخ ملفات الشعار"

msgid "Current bootlogo"
msgstr "شعار التمهيد الحالي"

msgid "Debugmode"
msgstr "وضع التصحيح"

msgid "Deinstallation of FFmpeg failed"
msgstr "فشل إلغاء تثبيت FFmpeg"

msgid "Delete current mvi-files before changing bootlogo"
msgstr "احذف ملفات mvi الحالية قبل تغيير شعار التشغيل"

msgid "Directory with bootlogo folders"
msgstr "الدليل مع مجلدات شعار التمهيد"

msgid "Display duration of the status messages (sec)"
msgstr "مدة عرض رسائل الحالة (ثانية)"

msgid "Easily switch between different bootlogos"
msgstr "التبديل بسهولة بين شعارات التمهيد المختلفة"

msgid "Exclude"
msgstr "استبعاد"

msgid "Exit plugin without saving"
msgstr "الخروج من البرنامج المساعد دون حفظ"

msgid "FFmpeg is needed to generate thumbnails from the mvi files"
msgstr "هناك حاجة إلى FFmpeg لإنشاء صور مصغرة من ملفات mvi"

msgid "FFmpeg ist missing, no preview pictures available - there is an option to install it in the stettings"
msgstr "FFmpeg مفقود، ولا تتوفر صور للمعاينة - هناك خيار لتثبيته في الإعدادات"

msgid "FFmpeg removed successfully"
msgstr "تمت إزالة FFmpeg بنجاح"

msgid "FFmpeg successfully installed"
msgstr "تم تثبيت FFmpeg بنجاح"

msgid "First delete the mvi-files of the current bootlogo then copy the files of the new one"
msgstr "قم أولاً بحذف ملفات mvi الخاصة بشعار التشغيل الحالي ثم انسخ ملفات الشعار الجديد"

msgid "Found bootlogos"
msgstr "تم العثور على شعارات التمهيد"

msgid "Full screen view the selected bootlogo"
msgstr "عرض ملء الشاشة لشعار التمهيد المحدد"

msgid "Hide directories without 'mvi'-files"
msgstr "إخفاء الدلائل التي لا تحتوي على ملفات "mvi"."

msgid "Hide empty directories"
msgstr "إخفاء الدلائل الفارغة"

msgid "How many seconds should status messages be displayed (1-60 sec)"
msgstr "كم ثانية يجب أن يتم عرض رسائل الحالة (1-60 ثانية)"

msgid "Include"
msgstr "يشمل"

msgid "Include or exlude logo in random choice"
msgstr "تضمين أو استبعاد الشعار في اختيار عشوائي"

msgid "Included Screens"
msgstr "الشاشات المضمنة"

msgid "Install/deinstall ffmpeg"
msgstr "تثبيت/إلغاء تثبيت ffmpeg"

msgid "Installation of FFmpeg failed"
msgstr "فشل تثبيت FFmpeg"

msgid "No bootlogos found in directory"
msgstr "لم يتم العثور على شعارات تمهيد في الدليل"

msgid "OK"
msgstr "نعم"

msgid "Open settings"
msgstr "افتح الإعدادات"

msgid "Preview Logo"
msgstr "معاينة الشعار"

msgid "Preview picture"
msgstr "معاينة الصورة"

msgid "Random mode"
msgstr "الوضع العشوائي"

msgid "Random selection at startup disabled"
msgstr "تم تعطيل الاختيار العشوائي عند بدء التشغيل"

msgid "Random selection at startup enabled"
msgstr "تم تمكين الاختيار العشوائي عند بدء التشغيل"

msgid "Save Changes and exit plugin"
msgstr "حفظ التغييرات والخروج من البرنامج المساعد"

msgid "Search for folders with boot logos in this directory"
msgstr "ابحث عن المجلدات التي تحتوي على شعارات التمهيد في هذا الدليل"

msgid "Which bootlogos should be displayed?"
msgstr "ما هي شعارات التمهيد التي يجب عرضها؟"

msgid "Which logo should be displayed as a preview picture?"
msgstr "ما الشعار الذي يجب عرضه كصورة معاينة؟"

msgid "[BootlogoChanger] activated new bootlogo"
msgstr "قام [BootlogoChanger] بتنشيط شعار التشغيل الجديد"

msgid "[BootlogoChanger] activating new bootlogo failed"
msgstr "[BootlogoChanger] فشل تفعيل شعار التشغيل الجديد"

msgid "[BootlogoChanger] copy failed"
msgstr "فشلت نسخة [BootlogoChanger]."

msgid "[BootlogoChanger] deleting old bootlogo files"
msgstr "[BootlogoChanger] حذف ملفات شعار التشغيل القديمة"

msgid "[BootlogoChanger] deleting previewPicture"
msgstr "[BootlogoChanger] حذف صورة المعاينة"

msgid "[BootlogoChanger] ffmpeg not found"
msgstr "[BootlogoChanger] لم يتم العثور على ffmpeg"

msgid "[BootlogoChanger] found Bootlogos"
msgstr "عثر [BootlogoChanger] على Bootlogos"

msgid "[BootlogoChanger] found ffmpeg"
msgstr "تم العثور على [BootlogoChanger] ffmpeg"

msgid "[BootlogoChanger] no bootlogos for randomization selected"
msgstr "[BootlogoChanger] لم يتم تحديد أي شعارات تمهيد للتوزيع العشوائي"

msgid "[BootlogoChanger] previewPicture changed"
msgstr "[BootlogoChanger] تم تغيير صورة المعاينة"

msgid "[BootlogoChanger] randomization of bootlogos activated"
msgstr "[BootlogoChanger] تم تفعيل التوزيع العشوائي لشعارات التمهيد"

msgid "[BootlogoChanger] randomization of bootlogos deactivated"
msgstr "[BootlogoChanger] تم إلغاء تنشيط التوزيع العشوائي لشعارات التمهيد"

msgid "[BootlogoChanger] randomization: bootlogo found"
msgstr "[BootlogoChanger] التوزيع العشوائي: تم العثور على شعار التمهيد"

msgid "[BootlogoChanger] selected bootlogos"
msgstr "[BootlogoChanger] شعارات التمهيد المحددة"

msgid "deinstall"
msgstr "إلغاء التثبيت"

msgid "found"
msgstr "وجد"

msgid "install"
msgstr "ثَبَّتَ"

msgid "missing"
msgstr "مفتقد"

msgid "off"
msgstr "عن"

msgid "on"
msgstr "على"
