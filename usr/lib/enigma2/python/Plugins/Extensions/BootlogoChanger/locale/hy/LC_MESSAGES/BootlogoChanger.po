msgid "Activate the debug-output on console"
msgstr "Ակտիվացրեք վրիպազերծման ելքը վահանակի վրա"

msgid "Bootlogo is excluded from random selection"
msgstr "Bootlogo-ն բացառված է պատահական ընտրությունից"

msgid "Bootlogo is included in random selection"
msgstr "Bootlogo-ն ներառված է պատահական ընտրության մեջ"

msgid "Cancel"
msgstr "Չեղարկել"

msgid "Choose random bootlogo at the start of the box"
msgstr "Ընտրեք պատահական bootlogo վանդակի սկզբում"

msgid "Copy logofiles failed"
msgstr "Լոգոֆայլերի պատճենումը ձախողվեց"

msgid "Current bootlogo"
msgstr "Ընթացիկ bootlogo"

msgid "Debugmode"
msgstr "Վրիպազերծման ռեժիմ"

msgid "Deinstallation of FFmpeg failed"
msgstr "FFmpeg-ի ապատեղադրումը ձախողվեց"

msgid "Delete current mvi-files before changing bootlogo"
msgstr "Ջնջեք ընթացիկ mvi-ֆայլերը նախքան bootlogo-ն փոխելը"

msgid "Directory with bootlogo folders"
msgstr "Գրացուցակ bootlogo թղթապանակներով"

msgid "Display duration of the status messages (sec)"
msgstr "Ցուցադրել կարգավիճակի հաղորդագրությունների տևողությունը (վրկ)"

msgid "Easily switch between different bootlogos"
msgstr "Հեշտությամբ անցեք տարբեր bootlogos-ի միջև"

msgid "Exclude"
msgstr "Բացառել"

msgid "Exit plugin without saving"
msgstr "Դուրս եկեք հավելվածից՝ առանց պահելու"

msgid "FFmpeg is needed to generate thumbnails from the mvi files"
msgstr "FFmpeg-ն անհրաժեշտ է mvi ֆայլերից մանրապատկերներ ստեղծելու համար"

msgid "FFmpeg ist missing, no preview pictures available - there is an option to install it in the stettings"
msgstr "FFmpeg-ը բացակայում է, նախադիտման նկարներ չկան. այն տեղադրելու տարբերակ կա կարգավորումներում"

msgid "FFmpeg removed successfully"
msgstr "FFmpeg-ը հաջողությամբ հեռացվեց"

msgid "FFmpeg successfully installed"
msgstr "FFmpeg-ը հաջողությամբ տեղադրվեց"

msgid "First delete the mvi-files of the current bootlogo then copy the files of the new one"
msgstr "Նախ ջնջեք ընթացիկ bootlogo-ի mvi-ֆայլերը, ապա պատճենեք նորի ֆայլերը"

msgid "Found bootlogos"
msgstr "Գտնվել են bootlogos"

msgid "Full screen view the selected bootlogo"
msgstr "Ամբողջ էկրանով դիտեք ընտրված bootlogo-ն"

msgid "Hide directories without 'mvi'-files"
msgstr "Թաքցնել դիրեկտորիաներն առանց «mvi» ֆայլերի"

msgid "Hide empty directories"
msgstr "Թաքցնել դատարկ գրացուցակները"

msgid "How many seconds should status messages be displayed (1-60 sec)"
msgstr "Քանի՞ վայրկյան պետք է ցուցադրվեն կարգավիճակի հաղորդագրությունները (1-60 վրկ)"

msgid "Include"
msgstr "Ներառել"

msgid "Include or exlude logo in random choice"
msgstr "Ներառել կամ բացառել պատկերանշանը պատահական ընտրության մեջ"

msgid "Included Screens"
msgstr "Ներառված էկրաններ"

msgid "Install/deinstall ffmpeg"
msgstr "Տեղադրեք/տեղահանեք ffmpeg"

msgid "Installation of FFmpeg failed"
msgstr "FFmpeg-ի տեղադրումը ձախողվեց"

msgid "No bootlogos found in directory"
msgstr "Գրացուցակում ոչ մի bootlogo չի գտնվել"

msgid "OK"
msgstr "Լավ"

msgid "Open settings"
msgstr "Բացեք կարգավորումները"

msgid "Preview Logo"
msgstr "Նախադիտել լոգոն"

msgid "Preview picture"
msgstr "Նախադիտել նկարը"

msgid "Random mode"
msgstr "Պատահական ռեժիմ"

msgid "Random selection at startup disabled"
msgstr "Գործարկման ժամանակ պատահական ընտրությունն անջատված է"

msgid "Random selection at startup enabled"
msgstr "Գործարկման ժամանակ պատահական ընտրությունը միացված է"

msgid "Save Changes and exit plugin"
msgstr "Պահպանել փոփոխությունները և դուրս գալ հավելվածից"

msgid "Search for folders with boot logos in this directory"
msgstr "Այս գրացուցակում փնտրեք բեռնման լոգոներով թղթապանակներ"

msgid "Which bootlogos should be displayed?"
msgstr "Ո՞ր բոտլոգոները պետք է ցուցադրվեն:"

msgid "Which logo should be displayed as a preview picture?"
msgstr "Ո՞ր լոգոն պետք է ցուցադրվի որպես նախադիտման նկար:"

msgid "[BootlogoChanger] activated new bootlogo"
msgstr "[BootlogoChanger]-ն ակտիվացրել է նոր bootlogo"

msgid "[BootlogoChanger] activating new bootlogo failed"
msgstr "[BootlogoChanger] նոր bootlogo-ի ակտիվացումը ձախողվեց"

msgid "[BootlogoChanger] copy failed"
msgstr "[BootlogoChanger] պատճենումը ձախողվեց"

msgid "[BootlogoChanger] deleting old bootlogo files"
msgstr "[BootlogoChanger] ջնջում է հին bootlogo ֆայլերը"

msgid "[BootlogoChanger] deleting previewPicture"
msgstr "[BootlogoChanger] ջնջում է նախադիտման պատկերը"

msgid "[BootlogoChanger] ffmpeg not found"
msgstr "[BootlogoChanger] ffmpeg չի գտնվել"

msgid "[BootlogoChanger] found Bootlogos"
msgstr "[BootlogoChanger]-ը գտել է Bootlogos-ը"

msgid "[BootlogoChanger] found ffmpeg"
msgstr "[BootlogoChanger]-ը գտել է ffmpeg"

msgid "[BootlogoChanger] no bootlogos for randomization selected"
msgstr "[BootlogoChanger] պատահականության համար ընտրված բոտլոգներ չկան"

msgid "[BootlogoChanger] previewPicture changed"
msgstr "[BootlogoChanger] նախադիտում Պատկերը փոխվել է"

msgid "[BootlogoChanger] randomization of bootlogos activated"
msgstr "[BootlogoChanger] ակտիվացված է bootlogos-ի պատահականացում"

msgid "[BootlogoChanger] randomization of bootlogos deactivated"
msgstr "[BootlogoChanger] bootlogos-ի պատահականացումն ապաակտիվացված է"

msgid "[BootlogoChanger] randomization: bootlogo found"
msgstr "[BootlogoChanger] պատահականացում. bootlogo-ն գտնվեց"

msgid "[BootlogoChanger] selected bootlogos"
msgstr "[BootlogoChanger] ընտրված bootlogos"

msgid "deinstall"
msgstr "տեղահանել"

msgid "found"
msgstr "հայտնաբերվել է"

msgid "install"
msgstr "տեղադրել"

msgid "missing"
msgstr "անհայտ կորած"

msgid "off"
msgstr "անջատված է"

msgid "on"
msgstr "վրա"
