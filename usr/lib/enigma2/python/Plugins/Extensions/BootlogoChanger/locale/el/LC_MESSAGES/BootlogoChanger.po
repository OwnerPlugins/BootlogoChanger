msgid "Activate the debug-output on console"
msgstr "Ενεργοποιήστε την έξοδο εντοπισμού σφαλμάτων στην κονσόλα"

msgid "Bootlogo is excluded from random selection"
msgstr "Το Bootlogo εξαιρείται από την τυχαία επιλογή"

msgid "Bootlogo is included in random selection"
msgstr "Το Bootlogo περιλαμβάνεται στην τυχαία επιλογή"

msgid "Cancel"
msgstr "Ματαίωση"

msgid "Choose random bootlogo at the start of the box"
msgstr "Επιλέξτε τυχαίο bootlogo στην αρχή του πλαισίου"

msgid "Copy logofiles failed"
msgstr "Η αντιγραφή αρχείων λογότυπου απέτυχε"

msgid "Current bootlogo"
msgstr "Τρέχον bootlogo"

msgid "Debugmode"
msgstr "Λειτουργία εντοπισμού σφαλμάτων"

msgid "Deinstallation of FFmpeg failed"
msgstr "Η απεγκατάσταση του FFmpeg απέτυχε"

msgid "Delete current mvi-files before changing bootlogo"
msgstr "Διαγράψτε τα τρέχοντα αρχεία mvi πριν αλλάξετε το bootlogo"

msgid "Directory with bootlogo folders"
msgstr "Κατάλογος με φακέλους bootlogo"

msgid "Display duration of the status messages (sec)"
msgstr "Εμφάνιση διάρκειας των μηνυμάτων κατάστασης (δευτ.)"

msgid "Easily switch between different bootlogos"
msgstr "Εύκολη εναλλαγή μεταξύ διαφορετικών bootlogos"

msgid "Exclude"
msgstr "Αποκλείω"

msgid "Exit plugin without saving"
msgstr "Έξοδος από την προσθήκη χωρίς αποθήκευση"

msgid "FFmpeg is needed to generate thumbnails from the mvi files"
msgstr "Το FFmpeg απαιτείται για τη δημιουργία μικρογραφιών από τα αρχεία mvi"

msgid "FFmpeg ist missing, no preview pictures available - there is an option to install it in the stettings"
msgstr "Το FFmpeg λείπει, δεν υπάρχουν διαθέσιμες εικόνες προεπισκόπησης - υπάρχει μια επιλογή να το εγκαταστήσετε στις ρυθμίσεις"

msgid "FFmpeg removed successfully"
msgstr "Το FFmpeg καταργήθηκε με επιτυχία"

msgid "FFmpeg successfully installed"
msgstr "Το FFmpeg εγκαταστάθηκε με επιτυχία"

msgid "First delete the mvi-files of the current bootlogo then copy the files of the new one"
msgstr "Πρώτα διαγράψτε τα αρχεία mvi του τρέχοντος bootlogo και μετά αντιγράψτε τα αρχεία του νέου"

msgid "Found bootlogos"
msgstr "Βρέθηκαν bootlogos"

msgid "Full screen view the selected bootlogo"
msgstr "Προβολή σε πλήρη οθόνη του επιλεγμένου bootlogo"

msgid "Hide directories without 'mvi'-files"
msgstr "Απόκρυψη καταλόγων χωρίς 'mvi'-αρχεία"

msgid "Hide empty directories"
msgstr "Απόκρυψη κενών καταλόγων"

msgid "How many seconds should status messages be displayed (1-60 sec)"
msgstr "Πόσα δευτερόλεπτα πρέπει να εμφανίζονται τα μηνύματα κατάστασης (1-60 δευτερόλεπτα)"

msgid "Include"
msgstr "Συμπεριλαμβάνω"

msgid "Include or exlude logo in random choice"
msgstr "Συμπεριλάβετε ή εξαιρέστε το λογότυπο σε τυχαία επιλογή"

msgid "Included Screens"
msgstr "Συμπεριλαμβανόμενες οθόνες"

msgid "Install/deinstall ffmpeg"
msgstr "Εγκατάσταση/απεγκατάσταση του ffmpeg"

msgid "Installation of FFmpeg failed"
msgstr "Η εγκατάσταση του FFmpeg απέτυχε"

msgid "No bootlogos found in directory"
msgstr "Δεν βρέθηκαν bootlogos στον κατάλογο"

msgid "OK"
msgstr "ΕΝΤΑΞΕΙ"

msgid "Open settings"
msgstr "Ανοίξτε τις ρυθμίσεις"

msgid "Preview Logo"
msgstr "Προεπισκόπηση λογότυπου"

msgid "Preview picture"
msgstr "Προεπισκόπηση εικόνας"

msgid "Random mode"
msgstr "Τυχαία λειτουργία"

msgid "Random selection at startup disabled"
msgstr "Η τυχαία επιλογή κατά την εκκίνηση απενεργοποιήθηκε"

msgid "Random selection at startup enabled"
msgstr "Ενεργοποιήθηκε η τυχαία επιλογή κατά την εκκίνηση"

msgid "Save Changes and exit plugin"
msgstr "Αποθήκευση αλλαγών και έξοδος από την προσθήκη"

msgid "Search for folders with boot logos in this directory"
msgstr "Αναζητήστε φακέλους με λογότυπα εκκίνησης σε αυτόν τον κατάλογο"

msgid "Which bootlogos should be displayed?"
msgstr "Ποια bootlogos πρέπει να εμφανίζονται;"

msgid "Which logo should be displayed as a preview picture?"
msgstr "Ποιο λογότυπο πρέπει να εμφανίζεται ως εικόνα προεπισκόπησης;"

msgid "[BootlogoChanger] activated new bootlogo"
msgstr "Το [BootlogoChanger] ενεργοποίησε νέο bootlogo"

msgid "[BootlogoChanger] activating new bootlogo failed"
msgstr "Η ενεργοποίηση του νέου bootlogo του [BootlogoChanger] απέτυχε"

msgid "[BootlogoChanger] copy failed"
msgstr "Η αντιγραφή του [BootlogoChanger] απέτυχε"

msgid "[BootlogoChanger] deleting old bootlogo files"
msgstr "[BootlogoChanger] διαγραφή παλαιών αρχείων bootlogo"

msgid "[BootlogoChanger] deleting previewPicture"
msgstr "[BootlogoChanger] διαγραφή προεπισκόπησηςΕικόνας"

msgid "[BootlogoChanger] ffmpeg not found"
msgstr "Το [BootlogoChanger] ffmpeg δεν βρέθηκε"

msgid "[BootlogoChanger] found Bootlogos"
msgstr "Το [BootlogoChanger] βρήκε τα Bootlogos"

msgid "[BootlogoChanger] found ffmpeg"
msgstr "Το [BootlogoChanger] βρέθηκε ffmpeg"

msgid "[BootlogoChanger] no bootlogos for randomization selected"
msgstr "[BootlogoChanger] δεν επιλέχθηκαν bootlogos για τυχαία τυχαιότητα"

msgid "[BootlogoChanger] previewPicture changed"
msgstr "Προεπισκόπηση [BootlogoChanger] Η εικόνα άλλαξε"

msgid "[BootlogoChanger] randomization of bootlogos activated"
msgstr "Ενεργοποιήθηκε η τυχαιοποίηση των bootlogo [BootlogoChanger]"

msgid "[BootlogoChanger] randomization of bootlogos deactivated"
msgstr "[BootlogoChanger] η τυχαιοποίηση των bootlogos απενεργοποιήθηκε"

msgid "[BootlogoChanger] randomization: bootlogo found"
msgstr "Τυχαιοποίηση [BootlogoChanger]: βρέθηκε το bootlogo"

msgid "[BootlogoChanger] selected bootlogos"
msgstr "[BootlogoChanger] επιλεγμένα bootlogos"

msgid "deinstall"
msgstr "απεγκατάσταση"

msgid "found"
msgstr "θεμελιώ"

msgid "install"
msgstr "εγκαθιστώ"

msgid "missing"
msgstr "απών"

msgid "off"
msgstr "μακριά από"

msgid "on"
msgstr "επί"
