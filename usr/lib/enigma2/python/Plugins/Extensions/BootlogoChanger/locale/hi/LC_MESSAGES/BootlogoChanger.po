msgid "Activate the debug-output on console"
msgstr "कंसोल पर डिबग-आउटपुट सक्रिय करें"

msgid "Bootlogo is excluded from random selection"
msgstr "बूटलोगो को यादृच्छिक चयन से बाहर रखा गया है"

msgid "Bootlogo is included in random selection"
msgstr "बूटलोगो को यादृच्छिक चयन में शामिल किया गया है"

msgid "Cancel"
msgstr "रद्द करना"

msgid "Choose random bootlogo at the start of the box"
msgstr "बॉक्स की शुरुआत में यादृच्छिक बूटलोगो चुनें"

msgid "Copy logofiles failed"
msgstr "लोगोफ़ाइलें कॉपी करना विफल रहा"

msgid "Current bootlogo"
msgstr "वर्तमान बूटलोगो"

msgid "Debugmode"
msgstr "डिबग मोड"

msgid "Deinstallation of FFmpeg failed"
msgstr "FFmpeg का अनइंस्टॉलेशन विफल रहा"

msgid "Delete current mvi-files before changing bootlogo"
msgstr "बूटलोगो बदलने से पहले वर्तमान एमवीआई-फ़ाइलें हटा दें"

msgid "Directory with bootlogo folders"
msgstr "बूटलोगो फ़ोल्डरों के साथ निर्देशिका"

msgid "Display duration of the status messages (sec)"
msgstr "स्थिति संदेशों की प्रदर्शन अवधि (सेकंड)"

msgid "Easily switch between different bootlogos"
msgstr "विभिन्न बूटलोगो के बीच आसानी से स्विच करें"

msgid "Exclude"
msgstr "बहिष्कृत करें"

msgid "Exit plugin without saving"
msgstr "बिना सहेजे प्लगइन से बाहर निकलें"

msgid "FFmpeg is needed to generate thumbnails from the mvi files"
msgstr "एमवीआई फाइलों से थंबनेल उत्पन्न करने के लिए एफएफएमपीईजी की आवश्यकता है"

msgid "FFmpeg ist missing, no preview pictures available - there is an option to install it in the stettings"
msgstr "FFmpeg गायब है, कोई पूर्वावलोकन चित्र उपलब्ध नहीं है - स्टेटिंग्स में इसे स्थापित करने का एक विकल्प है"

msgid "FFmpeg removed successfully"
msgstr "FFmpeg सफलतापूर्वक हटा दिया गया"

msgid "FFmpeg successfully installed"
msgstr "FFmpeg सफलतापूर्वक स्थापित हो गया"

msgid "First delete the mvi-files of the current bootlogo then copy the files of the new one"
msgstr "पहले मौजूदा बूटलोगो की एमवीआई-फ़ाइलें हटाएं, फिर नए की फ़ाइलें कॉपी करें"

msgid "Found bootlogos"
msgstr "बूटलोगो मिला"

msgid "Full screen view the selected bootlogo"
msgstr "चयनित बूटलोगो को पूर्ण स्क्रीन पर देखें"

msgid "Hide directories without 'mvi'-files"
msgstr "'एमवीआई'-फ़ाइलों के बिना निर्देशिकाएँ छिपाएँ"

msgid "Hide empty directories"
msgstr "खाली निर्देशिका छिपाएँ"

msgid "How many seconds should status messages be displayed (1-60 sec)"
msgstr "स्थिति संदेश कितने सेकंड में प्रदर्शित होने चाहिए (1-60 सेकंड)"

msgid "Include"
msgstr "शामिल करना"

msgid "Include or exlude logo in random choice"
msgstr "यादृच्छिक चयन में लोगो को शामिल करें या बाहर करें"

msgid "Included Screens"
msgstr "शामिल स्क्रीन"

msgid "Install/deinstall ffmpeg"
msgstr "ffmpeg इंस्टॉल/अनइंस्टॉल करें"

msgid "Installation of FFmpeg failed"
msgstr "FFmpeg की स्थापना विफल रही"

msgid "No bootlogos found in directory"
msgstr "निर्देशिका में कोई बूटलॉग नहीं मिला"

msgid "OK"
msgstr "ठीक है"

msgid "Open settings"
msgstr "खुली सेटिंग"

msgid "Preview Logo"
msgstr "लोगो का पूर्वावलोकन करें"

msgid "Preview picture"
msgstr "चित्र का पूर्वावलोकन करें"

msgid "Random mode"
msgstr "यादृच्छिक मोड"

msgid "Random selection at startup disabled"
msgstr "स्टार्टअप पर यादृच्छिक चयन अक्षम किया गया"

msgid "Random selection at startup enabled"
msgstr "स्टार्टअप पर यादृच्छिक चयन सक्षम"

msgid "Save Changes and exit plugin"
msgstr "परिवर्तन सहेजें और प्लगइन से बाहर निकलें"

msgid "Search for folders with boot logos in this directory"
msgstr "इस निर्देशिका में बूट लोगो वाले फ़ोल्डर खोजें"

msgid "Which bootlogos should be displayed?"
msgstr "कौन से बूटलोगो प्रदर्शित किए जाने चाहिए?"

msgid "Which logo should be displayed as a preview picture?"
msgstr "पूर्वावलोकन चित्र के रूप में कौन सा लोगो प्रदर्शित किया जाना चाहिए?"

msgid "[BootlogoChanger] activated new bootlogo"
msgstr "[बूटलोगोचेंजर] ने नया बूटलोगो सक्रिय किया"

msgid "[BootlogoChanger] activating new bootlogo failed"
msgstr "[बूटलोगोचेंजर] नया बूटलोगो सक्रिय करना विफल रहा"

msgid "[BootlogoChanger] copy failed"
msgstr "[बूटलोगोचेंजर] प्रतिलिपि विफल रही"

msgid "[BootlogoChanger] deleting old bootlogo files"
msgstr "[बूटलोगोचेंजर] पुरानी बूटलोगो फ़ाइलें हटा रहा है"

msgid "[BootlogoChanger] deleting previewPicture"
msgstr "[बूटलोगोचेंजर] पूर्वावलोकनचित्र हटा रहा है"

msgid "[BootlogoChanger] ffmpeg not found"
msgstr "[बूटलोगोचेंजर] एफएफएमपीईजी नहीं मिला"

msgid "[BootlogoChanger] found Bootlogos"
msgstr "[बूटलोगोचेंजर] को बूटलॉगोज़ मिला"

msgid "[BootlogoChanger] found ffmpeg"
msgstr "[बूटलोगोचेंजर] को एफएफएमपीईजी मिला"

msgid "[BootlogoChanger] no bootlogos for randomization selected"
msgstr "[बूटलोगोचेंजर] रैंडमाइजेशन के लिए कोई बूटलॉग चयनित नहीं है"

msgid "[BootlogoChanger] previewPicture changed"
msgstr "[बूटलोगोचेंजर] पूर्वावलोकनचित्र बदल गया"

msgid "[BootlogoChanger] randomization of bootlogos activated"
msgstr "[बूटलोगोचेंजर] बूटलॉग का रैंडमाइजेशन सक्रिय किया गया"

msgid "[BootlogoChanger] randomization of bootlogos deactivated"
msgstr "[बूटलोगोचेंजर] बूटलॉग का रैंडमाइजेशन निष्क्रिय किया गया"

msgid "[BootlogoChanger] randomization: bootlogo found"
msgstr "[बूटलोगोचेंजर] रैंडमाइजेशन: बूटलोगो मिला"

msgid "[BootlogoChanger] selected bootlogos"
msgstr "[बूटलोगोचेंजर] चयनित बूटलोगो"

msgid "deinstall"
msgstr "अनइंस्टॉल करें"

msgid "found"
msgstr "मिला"

msgid "install"
msgstr "स्थापित करना"

msgid "missing"
msgstr "गुम"

msgid "off"
msgstr "बंद"

msgid "on"
msgstr "पर"
