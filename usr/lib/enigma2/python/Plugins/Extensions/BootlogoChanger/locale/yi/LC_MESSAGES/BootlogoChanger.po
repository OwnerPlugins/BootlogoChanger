msgid "Activate the debug-output on console"
msgstr "אַקטאַווייט די דיבאַג רעזולטאַט אויף קאַנסאָול"

msgid "Bootlogo is excluded from random selection"
msgstr "באָאָטלאָגאָ איז יקסקלודיד פון טראַפ - סעלעקציע"

msgid "Bootlogo is included in random selection"
msgstr "באָאָטלאָגאָ איז אַרייַנגערעכנט אין טראַפ - סעלעקציע"

msgid "Cancel"
msgstr "באָטל מאַכן"

msgid "Choose random bootlogo at the start of the box"
msgstr "קלייַבן טראַפ באָאָטלאָגאָ אין די אָנהייב פון די קעסטל"

msgid "Copy logofiles failed"
msgstr "קאָפּי לאָגאָ טעקעס ניט אַנדערש"

msgid "Current bootlogo"
msgstr "קראַנט באָאָטלאָגאָ"

msgid "Debugmode"
msgstr "דיבאַג מאָדע"

msgid "Deinstallation of FFmpeg failed"
msgstr "דעינסטאַללאַטיאָן פון FFmpeg ניט אַנדערש"

msgid "Delete current mvi-files before changing bootlogo"
msgstr "ויסמעקן קראַנט מווי טעקעס איידער טשאַנגינג באָאָטלאָגאָ"

msgid "Directory with bootlogo folders"
msgstr "Directory מיט באָאָטלאָגאָ פאָלדערס"

msgid "Display duration of the status messages (sec)"
msgstr "ווייַז געדויער פון די סטאַטוס אַרטיקלען (סעק)"

msgid "Easily switch between different bootlogos"
msgstr "לייכט באַשטימען צווישן פאַרשידענע באָאָטלאָגאָס"

msgid "Exclude"
msgstr "ויסשליסן"

msgid "Exit plugin without saving"
msgstr "אַרויסגאַנג פּלוגין אָן שפּאָרן"

msgid "FFmpeg is needed to generate thumbnails from the mvi files"
msgstr "FFmpeg איז דארף צו דזשענערייט טהומבנאַילס פון די mvi טעקעס"

msgid "FFmpeg ist missing, no preview pictures available - there is an option to install it in the stettings"
msgstr "FFmpeg איז פעלנדיק, קיין פאָרויסיקע ווייַזונג בילדער בנימצא - עס איז אַן אָפּציע צו ינסטאַלירן עס אין די סעטטינגס"

msgid "FFmpeg removed successfully"
msgstr "FFmpeg איז הצלחה אַוועקגענומען"

msgid "FFmpeg successfully installed"
msgstr "FFmpeg הצלחה אינסטאַלירן"

msgid "First delete the mvi-files of the current bootlogo then copy the files of the new one"
msgstr "ערשטער ויסמעקן די מווי טעקעס פון די קראַנט באָאָטלאָגאָ און נאָכמאַכן די טעקעס פון די נייַע"

msgid "Found bootlogos"
msgstr "געפֿונען באָאָטלאָגאָס"

msgid "Full screen view the selected bootlogo"
msgstr "גאַנץ פאַרשטעלן קוק די אויסגעקליבן באָאָטלאָגאָ"

msgid "Hide directories without 'mvi'-files"
msgstr "באַהאַלטן דירעקטעריז אָן 'mvi'-פילעס"

msgid "Hide empty directories"
msgstr "באַהאַלטן ליידיק דירעקטעריז"

msgid "How many seconds should status messages be displayed (1-60 sec)"
msgstr "ווי פילע סעקונדעס זאָל זיין געוויזן סטאַטוס אַרטיקלען (1-60 סעק)"

msgid "Include"
msgstr "אַרייַננעמען"

msgid "Include or exlude logo in random choice"
msgstr "אַרייַננעמען אָדער ויסשליסן לאָגאָ אין טראַפ - ברירה"

msgid "Included Screens"
msgstr "אַרייַנגערעכנט סקרינז"

msgid "Install/deinstall ffmpeg"
msgstr "ינסטאַלירן / נעם אַוועק ffmpeg"

msgid "Installation of FFmpeg failed"
msgstr "ינסטאַלירונג פון FFmpeg איז ניט אַנדערש"

msgid "No bootlogos found in directory"
msgstr "קיין באָאָטלאָגאָס געפֿונען אין דער וועגווייַזער"

msgid "OK"
msgstr "גוט"

msgid "Open settings"
msgstr "עפֿענען סעטטינגס"

msgid "Preview Logo"
msgstr "פאָרויסיקע ווייַזונג לאָגאָ"

msgid "Preview picture"
msgstr "פאָרויסיקע ווייַזונג בילד"

msgid "Random mode"
msgstr "טראַפ - מאָדע"

msgid "Random selection at startup disabled"
msgstr "טראַפ סעלעקציע ביי סטאַרטאַפּ פאַרקריפּלט"

msgid "Random selection at startup enabled"
msgstr "טראַפ סעלעקציע ביי סטאַרטאַפּ ענייבאַלד"

msgid "Save Changes and exit plugin"
msgstr "היט ענדערונגען און אַרויסגאַנג פּלוגין"

msgid "Search for folders with boot logos in this directory"
msgstr "זוכן פֿאַר פאָלדערס מיט שטיוול לאָגאָס אין דעם וועגווייַזער"

msgid "Which bootlogos should be displayed?"
msgstr "וואָס באָאָטלאָגאָס זאָל זיין געוויזן?"

msgid "Which logo should be displayed as a preview picture?"
msgstr "וואָס לאָגאָ זאָל זיין געוויזן ווי אַ פאָרויסיקע ווייַזונג בילד?"

msgid "[BootlogoChanger] activated new bootlogo"
msgstr "[BootlogoChanger] אַקטיווייטיד נייַ באָאָטלאָגאָ"

msgid "[BootlogoChanger] activating new bootlogo failed"
msgstr "[BootlogoChanger] אַקטאַווייטינג נייַ באָאָטלאָגאָ ניט אַנדערש"

msgid "[BootlogoChanger] copy failed"
msgstr "[BootlogoChanger] קאָפּיע ניט אַנדערש"

msgid "[BootlogoChanger] deleting old bootlogo files"
msgstr "[BootlogoChanger] ויסמעקן אַלט באָאָטלאָגאָ טעקעס"

msgid "[BootlogoChanger] deleting previewPicture"
msgstr "[BootlogoChanger] ויסמעקן פּריוויו בילד"

msgid "[BootlogoChanger] ffmpeg not found"
msgstr "[BootlogoChanger] ffmpeg ניט געפֿונען"

msgid "[BootlogoChanger] found Bootlogos"
msgstr "[BootlogoChanger] געפֿונען Bootlogos"

msgid "[BootlogoChanger] found ffmpeg"
msgstr "[BootlogoChanger] געפֿונען ffmpeg"

msgid "[BootlogoChanger] no bootlogos for randomization selected"
msgstr "[BootlogoChanger] קיין באָאָטלאָגאָס פֿאַר ראַנדאַמיזיישאַן אויסגעקליבן"

msgid "[BootlogoChanger] previewPicture changed"
msgstr "[BootlogoChanger] פּריוויו בילד געביטן"

msgid "[BootlogoChanger] randomization of bootlogos activated"
msgstr "[BootlogoChanger] ראַנדאַמיזיישאַן פון באָאָטלאָגאָס אַקטיווייטיד"

msgid "[BootlogoChanger] randomization of bootlogos deactivated"
msgstr "[BootlogoChanger] ראַנדאַמיזיישאַן פון באָאָטלאָגאָס דיאַקטיווייטיד"

msgid "[BootlogoChanger] randomization: bootlogo found"
msgstr "[BootlogoChanger] ראַנדאָמיזאַטיאָן: באָאָטלאָגאָ געפֿונען"

msgid "[BootlogoChanger] selected bootlogos"
msgstr "[BootlogoChanger] אויסגעקליבן באָאָטלאָגאָס"

msgid "deinstall"
msgstr "נעם אַוועק"

msgid "found"
msgstr "געפונען"

msgid "install"
msgstr "ינסטאַלירן"

msgid "missing"
msgstr "פעלנדיק"

msgid "off"
msgstr "אַוועק"

msgid "on"
msgstr "אויף"
