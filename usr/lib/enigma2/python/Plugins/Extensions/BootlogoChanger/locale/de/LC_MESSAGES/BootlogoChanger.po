msgid "Activate the debug-output on console"
msgstr "Aktivieren Sie die Debug-Ausgabe auf der Konsole"

msgid "Bootlogo is excluded from random selection"
msgstr "Bootlogo ist von der Zufallsauswahl ausgeschlossen"

msgid "Bootlogo is included in random selection"
msgstr "Bootlogo ist in der Zufallsauswahl enthalten"

msgid "Cancel"
msgstr "Stornieren"

msgid "Choose random bootlogo at the start of the box"
msgstr "Wählen Sie am Anfang des Felds ein zufälliges Bootlogo aus"

msgid "Copy logofiles failed"
msgstr "Logodateien konnten nicht kopiert werden"

msgid "Current bootlogo"
msgstr "Aktuelles Bootlogo"

msgid "Debugmode"
msgstr "Debug-Modus"

msgid "Deinstallation of FFmpeg failed"
msgstr "Die Deinstallation von FFmpeg ist fehlgeschlagen"

msgid "Delete current mvi-files before changing bootlogo"
msgstr "Löschen Sie die aktuellen MVI-Dateien, bevor Sie das Bootlogo ändern"

msgid "Directory with bootlogo folders"
msgstr "Verzeichnis mit Bootlogo-Ordnern"

msgid "Display duration of the status messages (sec)"
msgstr "Anzeigedauer der Statusmeldungen (Sek)"

msgid "Easily switch between different bootlogos"
msgstr "Wechseln Sie einfach zwischen verschiedenen Bootlogos"

msgid "Exclude"
msgstr "Ausschließen"

msgid "Exit plugin without saving"
msgstr "Beenden Sie das Plugin ohne zu speichern"

msgid "FFmpeg is needed to generate thumbnails from the mvi files"
msgstr "FFmpeg wird benötigt, um Miniaturansichten aus den MVI-Dateien zu generieren"

msgid "FFmpeg ist missing, no preview pictures available - there is an option to install it in the stettings"
msgstr "FFmpeg fehlt, keine Vorschaubilder verfügbar - es gibt eine Option, es in den Einstellungen zu installieren"

msgid "FFmpeg removed successfully"
msgstr "FFmpeg erfolgreich entfernt"

msgid "FFmpeg successfully installed"
msgstr "FFmpeg erfolgreich installiert"

msgid "First delete the mvi-files of the current bootlogo then copy the files of the new one"
msgstr "Löschen Sie zuerst die MVI-Dateien des aktuellen Bootlogos und kopieren Sie dann die Dateien des neuen"

msgid "Found bootlogos"
msgstr "Bootlogos gefunden"

msgid "Full screen view the selected bootlogo"
msgstr "Vollbildansicht des ausgewählten Bootlogos"

msgid "Hide directories without 'mvi'-files"
msgstr "Verzeichnisse ohne 'mvi'-Dateien ausblenden"

msgid "Hide empty directories"
msgstr "Leere Verzeichnisse ausblenden"

msgid "How many seconds should status messages be displayed (1-60 sec)"
msgstr "Wie viele Sekunden sollen Statusmeldungen angezeigt werden (1-60 Sek.)"

msgid "Include"
msgstr "Enthalten"

msgid "Include or exlude logo in random choice"
msgstr "Logo in zufälliger Auswahl einschließen oder ausschließen"

msgid "Included Screens"
msgstr "Enthaltene Bildschirme"

msgid "Install/deinstall ffmpeg"
msgstr ""

msgid "Installation of FFmpeg failed"
msgstr "Die Installation von FFmpeg ist fehlgeschlagen"

msgid "No bootlogos found in directory"
msgstr "Im Verzeichnis wurden keine Bootlogos gefunden"

msgid "OK"
msgstr ""

msgid "Open settings"
msgstr "Einstellungen öffnen"

msgid "Preview Logo"
msgstr "Vorschau des Logos"

msgid "Preview picture"
msgstr "Vorschaubild"

msgid "Random mode"
msgstr "Zufallsmodus"

msgid "Random selection at startup disabled"
msgstr "Zufällige Auswahl beim Start deaktiviert"

msgid "Random selection at startup enabled"
msgstr "Zufällige Auswahl beim Start aktiviert"

msgid "Save Changes and exit plugin"
msgstr "Speichern Sie die Änderungen und beenden Sie das Plugin"

msgid "Search for folders with boot logos in this directory"
msgstr "Suchen Sie in diesem Verzeichnis nach Ordnern mit Boot-Logos"

msgid "Which bootlogos should be displayed?"
msgstr "Welche Bootlogos sollen angezeigt werden?"

msgid "Which logo should be displayed as a preview picture?"
msgstr "Welches Logo soll als Vorschaubild angezeigt werden?"

msgid "[BootlogoChanger] activated new bootlogo"
msgstr "[BootlogoChanger] hat neues Bootlogo aktiviert"

msgid "[BootlogoChanger] activating new bootlogo failed"
msgstr "[BootlogoChanger] Die Aktivierung des neuen Bootlogos ist fehlgeschlagen"

msgid "[BootlogoChanger] copy failed"
msgstr "Das Kopieren von [BootlogoChanger] ist fehlgeschlagen"

msgid "[BootlogoChanger] deleting old bootlogo files"
msgstr "[BootlogoChanger] löscht alte Bootlogo-Dateien"

msgid "[BootlogoChanger] deleting previewPicture"
msgstr "[BootlogoChanger] löscht das Vorschaubild"

msgid "[BootlogoChanger] ffmpeg not found"
msgstr "[BootlogoChanger] ffmpeg nicht gefunden"

msgid "[BootlogoChanger] found Bootlogos"
msgstr "[BootlogoChanger] hat Bootlogos gefunden"

msgid "[BootlogoChanger] found ffmpeg"
msgstr "[BootlogoChanger] hat ffmpeg gefunden"

msgid "[BootlogoChanger] no bootlogos for randomization selected"
msgstr "[BootlogoChanger] Keine Bootlogos für die Randomisierung ausgewählt"

msgid "[BootlogoChanger] previewPicture changed"
msgstr "[BootlogoChanger] Vorschaubild geändert"

msgid "[BootlogoChanger] randomization of bootlogos activated"
msgstr "[BootlogoChanger] Randomisierung der Bootlogos aktiviert"

msgid "[BootlogoChanger] randomization of bootlogos deactivated"
msgstr "[BootlogoChanger] Randomisierung von Bootlogos deaktiviert"

msgid "[BootlogoChanger] randomization: bootlogo found"
msgstr "[BootlogoChanger] Randomisierung: Bootlogo gefunden"

msgid "[BootlogoChanger] selected bootlogos"
msgstr "[BootlogoChanger] ausgewählte Bootlogos"

