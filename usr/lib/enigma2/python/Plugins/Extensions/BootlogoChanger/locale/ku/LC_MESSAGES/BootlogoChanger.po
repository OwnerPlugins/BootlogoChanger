msgid "Activate the debug-output on console"
msgstr "Li ser konsolê debug-derketina çalak bike"

msgid "Bootlogo is excluded from random selection"
msgstr "Bootlogo ji hilbijartina rasthatî nayê derxistin"

msgid "Bootlogo is included in random selection"
msgstr "Bootlogo di hilbijartina rasthatinî de tê de heye"

msgid "Cancel"
msgstr "Bişûndekirin"

msgid "Choose random bootlogo at the start of the box"
msgstr "Di destpêka qutîkê de bootlogoyek rasthatî hilbijêrin"

msgid "Copy logofiles failed"
msgstr "Kopîkirina pelên logoyê têk çû"

msgid "Current bootlogo"
msgstr "Bootlogoya niha"

msgid "Debugmode"
msgstr "Moda Debug"

msgid "Deinstallation of FFmpeg failed"
msgstr "Rakirina FFmpeg têk çû"

msgid "Delete current mvi-files before changing bootlogo"
msgstr "Berî ku bootlogo biguhezîne pelên mvi-ya heyî jêbirin"

msgid "Directory with bootlogo folders"
msgstr "Peldanka bi peldankên bootlogo"

msgid "Display duration of the status messages (sec)"
msgstr "Demjimêra peyamên statûyê nîşan bide (seq)"

msgid "Easily switch between different bootlogos"
msgstr "Bi hêsanî di navbera bootlogosên cûda de veguherînin"

msgid "Exclude"
msgstr "Jinavderxistin"

msgid "Exit plugin without saving"
msgstr "Bêyî tomarkirinê ji pêvekê derkeve"

msgid "FFmpeg is needed to generate thumbnails from the mvi files"
msgstr "FFmpeg hewce ye ku ji pelên mvi piçûkan çêbike"

msgid "FFmpeg ist missing, no preview pictures available - there is an option to install it in the stettings"
msgstr "FFmpeg wenda ye, wêneyên pêşdîtinê tune ne - vebijarkek heye ku wê di stûnan de saz bike"

msgid "FFmpeg removed successfully"
msgstr "FFmpeg bi serkeftî hate rakirin"

msgid "FFmpeg successfully installed"
msgstr "FFmpeg bi serkeftî hate saz kirin"

msgid "First delete the mvi-files of the current bootlogo then copy the files of the new one"
msgstr "Pêşî pelên mvi-ya bootlogo-ya heyî jêbirin û dûv re pelên ya nû kopî bikin"

msgid "Found bootlogos"
msgstr "Bootlogos hatin dîtin"

msgid "Full screen view the selected bootlogo"
msgstr "Bi tevahî dîmendera bootlogoya hilbijartî temaşe bikin"

msgid "Hide directories without 'mvi'-files"
msgstr "Derhêneran bêyî pelên 'mvi' veşêrin"

msgid "Hide empty directories"
msgstr "Derhênerên vala veşêrin"

msgid "How many seconds should status messages be displayed (1-60 sec)"
msgstr "Divê peyamên statûyê çend saniye werin xuyang kirin (1-60 çirk)"

msgid "Include"
msgstr "Linavxistin"

msgid "Include or exlude logo in random choice"
msgstr "Di bijartina rasthatî de logoyê têxin an derxin"

msgid "Included Screens"
msgstr "Screens Tevlî"

msgid "Install/deinstall ffmpeg"
msgstr "ffmpeg saz bikin/ rakirin"

msgid "Installation of FFmpeg failed"
msgstr "Sazkirina FFmpeg têk çû"

msgid "No bootlogos found in directory"
msgstr "Di pelrêçê de bootlogos nehat dîtin"

msgid "OK"
msgstr ""

msgid "Open settings"
msgstr "Mîhengan vekin"

msgid "Preview Logo"
msgstr "Pêşdîtin Logo"

msgid "Preview picture"
msgstr "Pêşdîtina wêneyê"

msgid "Random mode"
msgstr "mode Random"

msgid "Random selection at startup disabled"
msgstr "Hilbijartina rasthatî ya di destpêkê de neçalak bû"

msgid "Random selection at startup enabled"
msgstr "Hilbijartina rasthatî di destpêkê de çalak bû"

msgid "Save Changes and exit plugin"
msgstr "Guhertinan hilînin û ji pêvekê derkevin"

msgid "Search for folders with boot logos in this directory"
msgstr "Di vê peldankê de bi logoyên bootê bigerin"

msgid "Which bootlogos should be displayed?"
msgstr "Divê kîjan bootlogos bêne xuyang kirin?"

msgid "Which logo should be displayed as a preview picture?"
msgstr "Kîjan logo divê wekî wêneyek pêşdîtinê were xuyang kirin?"

msgid "[BootlogoChanger] activated new bootlogo"
msgstr "[BootlogoChanger] bootlogoya nû çalak kir"

msgid "[BootlogoChanger] activating new bootlogo failed"
msgstr "[BootlogoChanger] aktîvkirina bootloga nû têk çû"

msgid "[BootlogoChanger] copy failed"
msgstr "[BootlogoChanger] kopî bi ser neket"

msgid "[BootlogoChanger] deleting old bootlogo files"
msgstr "[BootlogoChanger] pelên bootlogo yên kevn jêbirin"

msgid "[BootlogoChanger] deleting previewPicture"
msgstr "[BootlogoChanger] pêşdîtinaPicture jêbirin"

msgid "[BootlogoChanger] ffmpeg not found"
msgstr "[BootlogoChanger] ffmpeg nehat dîtin"

msgid "[BootlogoChanger] found Bootlogos"
msgstr "[BootlogoChanger] Bootlogos dît"

msgid "[BootlogoChanger] found ffmpeg"
msgstr "[BootlogoChanger] ffmpeg hat dîtin"

msgid "[BootlogoChanger] no bootlogos for randomization selected"
msgstr "[BootlogoChanger] ji bo rasthatiniyê bootlogos nehat hilbijartin"

msgid "[BootlogoChanger] previewPicture changed"
msgstr "[BootlogoChanger] pêşdîtin Wêne guherî"

msgid "[BootlogoChanger] randomization of bootlogos activated"
msgstr "[BootlogoChanger] randomîzasyona bootlogos hate çalak kirin"

msgid "[BootlogoChanger] randomization of bootlogos deactivated"
msgstr "[BootlogoChanger] randomîzasyona bootlogos hat betalkirin"

msgid "[BootlogoChanger] randomization: bootlogo found"
msgstr "[BootlogoChanger] randomîzasyon: bootlogo hate dîtin"

msgid "[BootlogoChanger] selected bootlogos"
msgstr "[BootlogoChanger] bootlogos hilbijartî"

msgid "deinstall"
msgstr "rakirin"

msgid "found"
msgstr "dîtin"

msgid "install"
msgstr "lêkirin"

msgid "missing"
msgstr "wenda"

msgid "off"
msgstr "ji"

msgid "on"
msgstr "li"
