msgid "Activate the debug-output on console"
msgstr "Консольдегі отладтау шығысын іске қосыңыз"

msgid "Bootlogo is excluded from random selection"
msgstr "Bootlogo кездейсоқ таңдаудан шығарылады"

msgid "Bootlogo is included in random selection"
msgstr "Bootlogo кездейсоқ таңдауға кіреді"

msgid "Cancel"
msgstr "Бас тарту"

msgid "Choose random bootlogo at the start of the box"
msgstr "Қораптың басында кездейсоқ жүктеу логотипін таңдаңыз"

msgid "Copy logofiles failed"
msgstr "Логофилдерді көшіру сәтсіз аяқталды"

msgid "Current bootlogo"
msgstr "Ағымдағы жүктеу логотипі"

msgid "Debugmode"
msgstr "Түзету режимі"

msgid "Deinstallation of FFmpeg failed"
msgstr "FFmpeg орнату сәтсіз аяқталды"

msgid "Delete current mvi-files before changing bootlogo"
msgstr "Жүктеу логотипін өзгерту алдында ағымдағы mvi-файлдарды жойыңыз"

msgid "Directory with bootlogo folders"
msgstr "Bootlogo қалталары бар каталог"

msgid "Display duration of the status messages (sec)"
msgstr "Күй хабарларының ұзақтығын көрсету (сек)"

msgid "Easily switch between different bootlogos"
msgstr "Әртүрлі жүктеу логотиптері арасында оңай ауысыңыз"

msgid "Exclude"
msgstr "Алып тастау"

msgid "Exit plugin without saving"
msgstr "Плагинді сақтамай шығыңыз"

msgid "FFmpeg is needed to generate thumbnails from the mvi files"
msgstr "FFmpeg mvi файлдарынан нобайларды жасау үшін қажет"

msgid "FFmpeg ist missing, no preview pictures available - there is an option to install it in the stettings"
msgstr "FFmpeg жоқ, алдын ала қарау суреттері жоқ - оны параметрлерде орнату мүмкіндігі бар"

msgid "FFmpeg removed successfully"
msgstr "FFmpeg сәтті жойылды"

msgid "FFmpeg successfully installed"
msgstr "FFmpeg сәтті орнатылды"

msgid "First delete the mvi-files of the current bootlogo then copy the files of the new one"
msgstr "Алдымен ағымдағы жүктеу логотипінің mvi-файлдарын жойыңыз, содан кейін жаңасының файлдарын көшіріңіз"

msgid "Found bootlogos"
msgstr "Жүктеу логотиптері табылды"

msgid "Full screen view the selected bootlogo"
msgstr "Таңдалған жүктеу логотипін толық экранда көру"

msgid "Hide directories without 'mvi'-files"
msgstr "'mvi'-файлдары жоқ каталогтарды жасыру"

msgid "Hide empty directories"
msgstr "Бос каталогтарды жасыру"

msgid "How many seconds should status messages be displayed (1-60 sec)"
msgstr "Күй туралы хабарлар қанша секундта көрсетілуі керек (1-60 сек)"

msgid "Include"
msgstr "Қосу"

msgid "Include or exlude logo in random choice"
msgstr "Кездейсоқ таңдауда логотипті қосу немесе алып тастау"

msgid "Included Screens"
msgstr "Қосылған экрандар"

msgid "Install/deinstall ffmpeg"
msgstr "ffmpeg орнату/жою"

msgid "Installation of FFmpeg failed"
msgstr "FFmpeg орнату сәтсіз аяқталды"

msgid "No bootlogos found in directory"
msgstr "Каталогта ешқандай bootlogos табылмады"

msgid "OK"
msgstr "Жарайды"

msgid "Open settings"
msgstr "Параметрлерді ашыңыз"

msgid "Preview Logo"
msgstr "Логотипті алдын ала қарау"

msgid "Preview picture"
msgstr "Суретті алдын ала қарау"

msgid "Random mode"
msgstr "Кездейсоқ режим"

msgid "Random selection at startup disabled"
msgstr "Іске қосу кезінде кездейсоқ таңдау өшірілген"

msgid "Random selection at startup enabled"
msgstr "Іске қосу кезінде кездейсоқ таңдау қосулы"

msgid "Save Changes and exit plugin"
msgstr "Өзгерістерді сақтаңыз және плагиннен шығыңыз"

msgid "Search for folders with boot logos in this directory"
msgstr "Осы каталогтан жүктеу логотиптері бар қалталарды іздеңіз"

msgid "Which bootlogos should be displayed?"
msgstr "Қандай жүктеу логотиптерін көрсету керек?"

msgid "Which logo should be displayed as a preview picture?"
msgstr "Алдын ала қарау суреті ретінде қандай логотипті көрсету керек?"

msgid "[BootlogoChanger] activated new bootlogo"
msgstr "[BootlogoChanger] жаңа жүктеу логотипін белсендірді"

msgid "[BootlogoChanger] activating new bootlogo failed"
msgstr "[BootlogoChanger] жаңа жүктеу логотипін белсендіру сәтсіз аяқталды"

msgid "[BootlogoChanger] copy failed"
msgstr "[BootlogoChanger] көшірмесі орындалмады"

msgid "[BootlogoChanger] deleting old bootlogo files"
msgstr "[BootlogoChanger] ескі bootlogo файлдарын жою"

msgid "[BootlogoChanger] deleting previewPicture"
msgstr "[BootlogoChanger] алдын ала қарау суретін жою"

msgid "[BootlogoChanger] ffmpeg not found"
msgstr "[BootlogoChanger] ffmpeg табылмады"

msgid "[BootlogoChanger] found Bootlogos"
msgstr "[BootlogoChanger] Bootlogos тапты"

msgid "[BootlogoChanger] found ffmpeg"
msgstr "[BootlogoChanger] ffmpeg файлын тапты"

msgid "[BootlogoChanger] no bootlogos for randomization selected"
msgstr "[BootlogoChanger] рандомизацияға арналған жүктеу логотиптері таңдалмаған"

msgid "[BootlogoChanger] previewPicture changed"
msgstr "[BootlogoChanger] алдын ала қарауСурет өзгертілді"

msgid "[BootlogoChanger] randomization of bootlogos activated"
msgstr "[BootlogoChanger] жүктеу логотиптерінің рандомизациясы іске қосылды"

msgid "[BootlogoChanger] randomization of bootlogos deactivated"
msgstr "[BootlogoChanger] жүктеу логотиптерінің рандомизациясы өшірілді"

msgid "[BootlogoChanger] randomization: bootlogo found"
msgstr "[BootlogoChanger] рандомизациясы: жүктеу логотипі табылды"

msgid "[BootlogoChanger] selected bootlogos"
msgstr "[BootlogoChanger] таңдалған жүктеу логотиптері"

msgid "deinstall"
msgstr "жою"

msgid "found"
msgstr "табылды"

msgid "install"
msgstr "орнату"

msgid "missing"
msgstr "жоқ"

msgid "off"
msgstr "өшірулі"

msgid "on"
msgstr "қосулы"
