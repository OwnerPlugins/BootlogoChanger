msgid "Activate the debug-output on console"
msgstr "Aktivujte výstup ladění na konzole"

msgid "Bootlogo is excluded from random selection"
msgstr "Bootlogo je vyloučeno z náhodného výběru"

msgid "Bootlogo is included in random selection"
msgstr "Bootlogo je zahrnuto do náhodného výběru"

msgid "Cancel"
msgstr "Zrušit"

msgid "Choose random bootlogo at the start of the box"
msgstr "Vyberte náhodné bootlogo na začátku pole"

msgid "Copy logofiles failed"
msgstr "Kopírování souborů loga se nezdařilo"

msgid "Current bootlogo"
msgstr "Aktuální bootlogo"

msgid "Debugmode"
msgstr "Režim ladění"

msgid "Deinstallation of FFmpeg failed"
msgstr "Deinstalace FFmpeg se nezdařila"

msgid "Delete current mvi-files before changing bootlogo"
msgstr "Před změnou bootloga smažte aktuální mvi-soubory"

msgid "Directory with bootlogo folders"
msgstr "Adresář se složkami bootlogo"

msgid "Display duration of the status messages (sec)"
msgstr "Zobrazení doby trvání stavových zpráv (s)"

msgid "Easily switch between different bootlogos"
msgstr "Snadno přepínejte mezi různými bootlogy"

msgid "Exclude"
msgstr "Vyloučit"

msgid "Exit plugin without saving"
msgstr "Ukončit plugin bez uložení"

msgid "FFmpeg is needed to generate thumbnails from the mvi files"
msgstr "FFmpeg je potřeba pro generování náhledů ze souborů mvi"

msgid "FFmpeg ist missing, no preview pictures available - there is an option to install it in the stettings"
msgstr "Chybí FFmpeg, nejsou k dispozici žádné náhledové obrázky - v nastavení je možnost jej nainstalovat"

msgid "FFmpeg removed successfully"
msgstr "FFmpeg úspěšně odstraněn"

msgid "FFmpeg successfully installed"
msgstr "FFmpeg úspěšně nainstalován"

msgid "First delete the mvi-files of the current bootlogo then copy the files of the new one"
msgstr "Nejprve odstraňte soubory mvi aktuálního bootloga a poté zkopírujte soubory nového"

msgid "Found bootlogos"
msgstr "Nalezena bootloga"

msgid "Full screen view the selected bootlogo"
msgstr "Zobrazení vybraného bootloga na celé obrazovce"

msgid "Hide directories without 'mvi'-files"
msgstr "Skrýt adresáře bez souborů 'mvi'"

msgid "Hide empty directories"
msgstr "Skrýt prázdné adresáře"

msgid "How many seconds should status messages be displayed (1-60 sec)"
msgstr "Kolik sekund by se měly zobrazovat stavové zprávy (1-60 sekund)"

msgid "Include"
msgstr "Zahrnout"

msgid "Include or exlude logo in random choice"
msgstr "Zahrnout nebo vyloučit logo v náhodném výběru"

msgid "Included Screens"
msgstr "Zahrnuté obrazovky"

msgid "Install/deinstall ffmpeg"
msgstr "Nainstalujte/odinstalujte ffmpeg"

msgid "Installation of FFmpeg failed"
msgstr "Instalace FFmpeg se nezdařila"

msgid "No bootlogos found in directory"
msgstr "V adresáři nebyla nalezena žádná bootloga"

msgid "OK"
msgstr ""

msgid "Open settings"
msgstr "Otevřete nastavení"

msgid "Preview Logo"
msgstr "Náhled loga"

msgid "Preview picture"
msgstr "Náhledový obrázek"

msgid "Random mode"
msgstr "Náhodný režim"

msgid "Random selection at startup disabled"
msgstr "Náhodný výběr při spuštění zakázán"

msgid "Random selection at startup enabled"
msgstr "Náhodný výběr při spuštění povolen"

msgid "Save Changes and exit plugin"
msgstr "Uložte změny a ukončete plugin"

msgid "Search for folders with boot logos in this directory"
msgstr "Vyhledejte v tomto adresáři složky se zaváděcími logy"

msgid "Which bootlogos should be displayed?"
msgstr "Která bootloga by se měla zobrazovat?"

msgid "Which logo should be displayed as a preview picture?"
msgstr "Které logo by se mělo zobrazit jako náhledový obrázek?"

msgid "[BootlogoChanger] activated new bootlogo"
msgstr "[BootlogoChanger] aktivoval nové bootlogo"

msgid "[BootlogoChanger] activating new bootlogo failed"
msgstr "[BootlogoChanger] aktivace nového bootloga se nezdařila"

msgid "[BootlogoChanger] copy failed"
msgstr "Kopírování [BootlogoChanger] se nezdařilo"

msgid "[BootlogoChanger] deleting old bootlogo files"
msgstr "[BootlogoChanger] smazání starých souborů s bootlogem"

msgid "[BootlogoChanger] deleting previewPicture"
msgstr "[BootlogoChanger] smazání previewPicture"

msgid "[BootlogoChanger] ffmpeg not found"
msgstr "[BootlogoChanger] ffmpeg nenalezen"

msgid "[BootlogoChanger] found Bootlogos"
msgstr "[BootlogoChanger] našel Bootlogos"

msgid "[BootlogoChanger] found ffmpeg"
msgstr "[BootlogoChanger] nalezen ffmpeg"

msgid "[BootlogoChanger] no bootlogos for randomization selected"
msgstr "[BootlogoChanger] nebyla vybrána žádná bootloga pro randomizaci"

msgid "[BootlogoChanger] previewPicture changed"
msgstr "[BootlogoChanger] previewPicture změněn"

msgid "[BootlogoChanger] randomization of bootlogos activated"
msgstr "[BootlogoChanger] randomizace bootloga aktivována"

msgid "[BootlogoChanger] randomization of bootlogos deactivated"
msgstr "[BootlogoChanger] randomizace bootlog deaktivována"

msgid "[BootlogoChanger] randomization: bootlogo found"
msgstr "[BootlogoChanger] randomizace: bootlogo nalezeno"

msgid "[BootlogoChanger] selected bootlogos"
msgstr "[BootlogoChanger] vybraná bootloga"

msgid "deinstall"
msgstr "odinstalovat"

msgid "found"
msgstr "nalezeno"

msgid "install"
msgstr "instalovat"

msgid "missing"
msgstr "chybějící"

msgid "off"
msgstr "vypnuto"

msgid "on"
msgstr "na"
