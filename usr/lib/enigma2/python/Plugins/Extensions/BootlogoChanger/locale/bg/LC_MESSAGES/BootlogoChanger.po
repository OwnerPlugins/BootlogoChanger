msgid "Activate the debug-output on console"
msgstr "Активирайте изхода за отстраняване на грешки на конзолата"

msgid "Bootlogo is excluded from random selection"
msgstr "Bootlogo е изключено от произволния избор"

msgid "Bootlogo is included in random selection"
msgstr "Bootlogo е включено в произволния избор"

msgid "Cancel"
msgstr "Отказ"

msgid "Choose random bootlogo at the start of the box"
msgstr "Изберете произволно стартиращо лого в началото на кутията"

msgid "Copy logofiles failed"
msgstr "Неуспешно копиране на файлове с лого"

msgid "Current bootlogo"
msgstr "Текущо стартиращо лого"

msgid "Debugmode"
msgstr "Режим на отстраняване на грешки"

msgid "Deinstallation of FFmpeg failed"
msgstr "Деинсталирането на FFmpeg не бе успешно"

msgid "Delete current mvi-files before changing bootlogo"
msgstr "Изтрийте текущите mvi-файлове, преди да промените bootlogo"

msgid "Directory with bootlogo folders"
msgstr "Директория с папки bootlogo"

msgid "Display duration of the status messages (sec)"
msgstr "Продължителност на показване на съобщенията за статус (сек)"

msgid "Easily switch between different bootlogos"
msgstr "Лесно превключвайте между различни лога за стартиране"

msgid "Exclude"
msgstr "Изключете"

msgid "Exit plugin without saving"
msgstr "Излезте от приставката без запазване"

msgid "FFmpeg is needed to generate thumbnails from the mvi files"
msgstr "FFmpeg е необходим за генериране на миниатюри от mvi файловете"

msgid "FFmpeg ist missing, no preview pictures available - there is an option to install it in the stettings"
msgstr "FFmpeg липсва, няма налични снимки за преглед - има опция за инсталиране в настройките"

msgid "FFmpeg removed successfully"
msgstr "FFmpeg премахнат успешно"

msgid "FFmpeg successfully installed"
msgstr "FFmpeg е инсталиран успешно"

msgid "First delete the mvi-files of the current bootlogo then copy the files of the new one"
msgstr "Първо изтрийте mvi-файловете на текущото bootlogo, след което копирайте файловете на новото"

msgid "Found bootlogos"
msgstr "Намерени лога за стартиране"

msgid "Full screen view the selected bootlogo"
msgstr "Вижте на цял екран избраното лого за зареждане"

msgid "Hide directories without 'mvi'-files"
msgstr "Скриване на директории без 'mvi'-файлове"

msgid "Hide empty directories"
msgstr "Скриване на празни директории"

msgid "How many seconds should status messages be displayed (1-60 sec)"
msgstr "Колко секунди трябва да се показват съобщенията за състояние (1-60 сек)"

msgid "Include"
msgstr "Включете"

msgid "Include or exlude logo in random choice"
msgstr "Включете или изключете логото в случаен избор"

msgid "Included Screens"
msgstr "Включени екрани"

msgid "Install/deinstall ffmpeg"
msgstr "Инсталирайте/деинсталирайте ffmpeg"

msgid "Installation of FFmpeg failed"
msgstr "Неуспешно инсталиране на FFmpeg"

msgid "No bootlogos found in directory"
msgstr "В директорията няма намерени лога за стартиране"

msgid "OK"
msgstr "добре"

msgid "Open settings"
msgstr "Отворете настройките"

msgid "Preview Logo"
msgstr "Визуализация на логото"

msgid "Preview picture"
msgstr "Преглед на картина"

msgid "Random mode"
msgstr "Случаен режим"

msgid "Random selection at startup disabled"
msgstr "Произволният избор при стартиране е деактивиран"

msgid "Random selection at startup enabled"
msgstr "Произволният избор при стартиране е активиран"

msgid "Save Changes and exit plugin"
msgstr "Запазете промените и излезте от приставката"

msgid "Search for folders with boot logos in this directory"
msgstr "Търсете папки с лого за зареждане в тази директория"

msgid "Which bootlogos should be displayed?"
msgstr "Кои лога за стартиране трябва да се показват?"

msgid "Which logo should be displayed as a preview picture?"
msgstr "Кое лого трябва да се показва като картина за предварителен преглед?"

msgid "[BootlogoChanger] activated new bootlogo"
msgstr "[BootlogoChanger] активира ново лого за стартиране"

msgid "[BootlogoChanger] activating new bootlogo failed"
msgstr "[BootlogoChanger] неуспешно активиране на ново лого за стартиране"

msgid "[BootlogoChanger] copy failed"
msgstr "Неуспешно копиране на [BootlogoChanger]."

msgid "[BootlogoChanger] deleting old bootlogo files"
msgstr "[BootlogoChanger] изтриване на стари bootlogo файлове"

msgid "[BootlogoChanger] deleting previewPicture"
msgstr "[BootlogoChanger] изтриване на картина за предварителен преглед"

msgid "[BootlogoChanger] ffmpeg not found"
msgstr "[BootlogoChanger] ffmpeg не е намерен"

msgid "[BootlogoChanger] found Bootlogos"
msgstr "[BootlogoChanger] намери Bootlogos"

msgid "[BootlogoChanger] found ffmpeg"
msgstr "[BootlogoChanger] намери ffmpeg"

msgid "[BootlogoChanger] no bootlogos for randomization selected"
msgstr "[BootlogoChanger] няма избрани лога за стартиране за рандомизиране"

msgid "[BootlogoChanger] previewPicture changed"
msgstr "[BootlogoChanger] визуализация Снимката е променена"

msgid "[BootlogoChanger] randomization of bootlogos activated"
msgstr "[BootlogoChanger] рандомизацията на bootlogos е активирана"

msgid "[BootlogoChanger] randomization of bootlogos deactivated"
msgstr "[BootlogoChanger] дезактивирана рандомизация на bootlogos"

msgid "[BootlogoChanger] randomization: bootlogo found"
msgstr "[BootlogoChanger] рандомизиране: намерено bootlogo"

msgid "[BootlogoChanger] selected bootlogos"
msgstr "[BootlogoChanger] избрани лога за стартиране"

msgid "deinstall"
msgstr "деинсталиране"

msgid "found"
msgstr "намерени"

msgid "install"
msgstr "инсталирайте"

msgid "missing"
msgstr "липсва"

msgid "off"
msgstr "изключено"

msgid "on"
msgstr "на"
