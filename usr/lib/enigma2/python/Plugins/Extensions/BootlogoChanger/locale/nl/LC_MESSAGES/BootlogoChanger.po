msgid "Activate the debug-output on console"
msgstr "Activeer de debug-uitvoer op de console"

msgid "Bootlogo is excluded from random selection"
msgstr "Bootlogo is uitgesloten van willekeurige selectie"

msgid "Bootlogo is included in random selection"
msgstr "Bootlogo is opgenomen in willekeurige selectie"

msgid "Cancel"
msgstr "Annuleren"

msgid "Choose random bootlogo at the start of the box"
msgstr "Kies een willekeurig bootlogo aan het begin van het vak"

msgid "Copy logofiles failed"
msgstr "Het kopiëren van logobestanden is mislukt"

msgid "Current bootlogo"
msgstr "Huidig ​​bootlogo"

msgid "Debugmode"
msgstr "Debug-modus"

msgid "Deinstallation of FFmpeg failed"
msgstr "Het verwijderen van FFmpeg is mislukt"

msgid "Delete current mvi-files before changing bootlogo"
msgstr "Verwijder de huidige mvi-bestanden voordat u het bootlogo wijzigt"

msgid "Directory with bootlogo folders"
msgstr "Directory met bootlogo-mappen"

msgid "Display duration of the status messages (sec)"
msgstr "Weergaveduur van de statusmeldingen (sec)"

msgid "Easily switch between different bootlogos"
msgstr "Schakel eenvoudig tussen verschillende bootlogo's"

msgid "Exclude"
msgstr "Uitsluiten"

msgid "Exit plugin without saving"
msgstr "Sluit de plug-in af zonder op te slaan"

msgid "FFmpeg is needed to generate thumbnails from the mvi files"
msgstr "FFmpeg is nodig om miniaturen van de mvi-bestanden te genereren"

msgid "FFmpeg ist missing, no preview pictures available - there is an option to install it in the stettings"
msgstr "FFmpeg ontbreekt, er zijn geen voorbeeldafbeeldingen beschikbaar - er is een optie om het in de instellingen te installeren"

msgid "FFmpeg removed successfully"
msgstr "FFmpeg is succesvol verwijderd"

msgid "FFmpeg successfully installed"
msgstr "FFmpeg succesvol geïnstalleerd"

msgid "First delete the mvi-files of the current bootlogo then copy the files of the new one"
msgstr "Verwijder eerst de mvi-bestanden van het huidige bootlogo en kopieer vervolgens de bestanden van het nieuwe"

msgid "Found bootlogos"
msgstr "Bootlogo's gevonden"

msgid "Full screen view the selected bootlogo"
msgstr "Bekijk het geselecteerde opstartlogo op volledig scherm"

msgid "Hide directories without 'mvi'-files"
msgstr "Verberg mappen zonder 'mvi'-bestanden"

msgid "Hide empty directories"
msgstr "Verberg lege mappen"

msgid "How many seconds should status messages be displayed (1-60 sec)"
msgstr "Hoeveel seconden moeten statusberichten worden weergegeven (1-60 sec)"

msgid "Include"
msgstr "Erbij betrekken"

msgid "Include or exlude logo in random choice"
msgstr "Logo in willekeurige keuze opnemen of uitsluiten"

msgid "Included Screens"
msgstr "Inclusief schermen"

msgid "Install/deinstall ffmpeg"
msgstr "Installeer/verwijder ffmpeg"

msgid "Installation of FFmpeg failed"
msgstr "Installatie van FFmpeg is mislukt"

msgid "No bootlogos found in directory"
msgstr "Geen bootlogo's gevonden in de directory"

msgid "OK"
msgstr ""

msgid "Open settings"
msgstr "Instellingen openen"

msgid "Preview Logo"
msgstr "Voorbeeldlogo"

msgid "Preview picture"
msgstr "Voorbeeldafbeelding"

msgid "Random mode"
msgstr "Willekeurige modus"

msgid "Random selection at startup disabled"
msgstr "Willekeurige selectie bij opstarten uitgeschakeld"

msgid "Random selection at startup enabled"
msgstr "Willekeurige selectie bij opstarten ingeschakeld"

msgid "Save Changes and exit plugin"
msgstr "Wijzigingen opslaan en plug-in afsluiten"

msgid "Search for folders with boot logos in this directory"
msgstr "Zoek naar mappen met opstartlogo's in deze map"

msgid "Which bootlogos should be displayed?"
msgstr "Welke bootlogo's moeten worden weergegeven?"

msgid "Which logo should be displayed as a preview picture?"
msgstr "Welk logo moet als voorbeeldafbeelding worden weergegeven?"

msgid "[BootlogoChanger] activated new bootlogo"
msgstr "[BootlogoChanger] heeft een nieuw bootlogo geactiveerd"

msgid "[BootlogoChanger] activating new bootlogo failed"
msgstr "[BootlogoChanger] activeren van nieuw bootlogo mislukt"

msgid "[BootlogoChanger] copy failed"
msgstr "Het kopiëren van [BootlogoChanger] is mislukt"

msgid "[BootlogoChanger] deleting old bootlogo files"
msgstr "[BootlogoChanger] verwijdert oude bootlogo-bestanden"

msgid "[BootlogoChanger] deleting previewPicture"
msgstr "[BootlogoChanger] previewPicture verwijderen"

msgid "[BootlogoChanger] ffmpeg not found"
msgstr "[BootlogoChanger] ffmpeg niet gevonden"

msgid "[BootlogoChanger] found Bootlogos"
msgstr "[BootlogoChanger] heeft Bootlogo's gevonden"

msgid "[BootlogoChanger] found ffmpeg"
msgstr "[BootlogoChanger] heeft ffmpeg gevonden"

msgid "[BootlogoChanger] no bootlogos for randomization selected"
msgstr "[BootlogoChanger] geen bootlogo's voor randomisatie geselecteerd"

msgid "[BootlogoChanger] previewPicture changed"
msgstr "[BootlogoChanger] previewAfbeelding gewijzigd"

msgid "[BootlogoChanger] randomization of bootlogos activated"
msgstr "[BootlogoChanger] randomisatie van bootlogo's geactiveerd"

msgid "[BootlogoChanger] randomization of bootlogos deactivated"
msgstr "[BootlogoChanger] randomisatie van bootlogo's gedeactiveerd"

msgid "[BootlogoChanger] randomization: bootlogo found"
msgstr "[BootlogoChanger] randomisatie: bootlogo gevonden"

msgid "[BootlogoChanger] selected bootlogos"
msgstr "[BootlogoChanger] geselecteerde bootlogo's"

msgid "deinstall"
msgstr "verwijderen"

msgid "found"
msgstr "gevonden"

msgid "install"
msgstr "installeren"

msgid "missing"
msgstr "ontbreekt"

msgid "off"
msgstr "uit"

msgid "on"
msgstr "op"
