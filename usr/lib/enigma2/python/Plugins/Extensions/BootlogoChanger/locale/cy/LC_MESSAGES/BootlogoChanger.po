msgid "Activate the debug-output on console"
msgstr "Ysgogi'r allbwn dadfygio ar y consol"

msgid "Bootlogo is excluded from random selection"
msgstr "Mae Bootlogo wedi'i eithrio o ddewis ar hap"

msgid "Bootlogo is included in random selection"
msgstr "Mae Bootlogo wedi'i gynnwys mewn dewis ar hap"

msgid "Cancel"
msgstr "Canslo"

msgid "Choose random bootlogo at the start of the box"
msgstr "Dewiswch bootlogo ar hap ar ddechrau'r blwch"

msgid "Copy logofiles failed"
msgstr "Methwyd â chopïo ffeiliau logo"

msgid "Current bootlogo"
msgstr "Bootlogo cyfredol"

msgid "Debugmode"
msgstr "Modd dadfygio"

msgid "Deinstallation of FFmpeg failed"
msgstr "Methodd dadosod FFmpeg"

msgid "Delete current mvi-files before changing bootlogo"
msgstr "Dileu ffeiliau mvi cyfredol cyn newid bootlogo"

msgid "Directory with bootlogo folders"
msgstr "Cyfeiriadur gyda ffolderi bootlogo"

msgid "Display duration of the status messages (sec)"
msgstr "Arddangos hyd y negeseuon statws (eiliad)"

msgid "Easily switch between different bootlogos"
msgstr "Newid yn hawdd rhwng gwahanol bootlogos"

msgid "Exclude"
msgstr "Eithrio"

msgid "Exit plugin without saving"
msgstr "Gadael ategyn heb arbed"

msgid "FFmpeg is needed to generate thumbnails from the mvi files"
msgstr "Mae angen FFmpeg i gynhyrchu mân-luniau o'r ffeiliau mvi"

msgid "FFmpeg ist missing, no preview pictures available - there is an option to install it in the stettings"
msgstr "Mae FFmpeg ist ar goll, dim lluniau rhagolwg ar gael - mae opsiwn i'w osod yn y stettings"

msgid "FFmpeg removed successfully"
msgstr "Dileu FFmpeg yn llwyddiannus"

msgid "FFmpeg successfully installed"
msgstr "FFmpeg gosod yn llwyddiannus"

msgid "First delete the mvi-files of the current bootlogo then copy the files of the new one"
msgstr "Yn gyntaf dilëwch y mvi-files o'r bootlogo cyfredol ac yna copïwch ffeiliau'r un newydd"

msgid "Found bootlogos"
msgstr "Wedi dod o hyd i bootlogos"

msgid "Full screen view the selected bootlogo"
msgstr "Gweld sgrin lawn y bootlogo a ddewiswyd"

msgid "Hide directories without 'mvi'-files"
msgstr "Cuddio cyfeiriaduron heb 'mvi'-files"

msgid "Hide empty directories"
msgstr "Cuddio cyfeiriaduron gwag"

msgid "How many seconds should status messages be displayed (1-60 sec)"
msgstr "Sawl eiliad ddylai negeseuon statws gael eu harddangos (1-60 eiliad)"

msgid "Include"
msgstr "Cynnwysa"

msgid "Include or exlude logo in random choice"
msgstr "Cynnwys neu hepgor logo mewn dewis ar hap"

msgid "Included Screens"
msgstr "Sgriniau wedi'u Cynnwys"

msgid "Install/deinstall ffmpeg"
msgstr "Gosod/dadosod ffmpeg"

msgid "Installation of FFmpeg failed"
msgstr "Methodd gosod FFmpeg"

msgid "No bootlogos found in directory"
msgstr "Ni chanfuwyd bootlogos yn y cyfeiriadur"

msgid "OK"
msgstr "iawn"

msgid "Open settings"
msgstr "Agor gosodiadau"

msgid "Preview Logo"
msgstr "Logo Rhagolwg"

msgid "Preview picture"
msgstr "Rhagolwg llun"

msgid "Random mode"
msgstr "Modd ar hap"

msgid "Random selection at startup disabled"
msgstr "Dewis ar hap wrth gychwyn wedi'i analluogi"

msgid "Random selection at startup enabled"
msgstr "Wedi galluogi dewis ar hap wrth gychwyn"

msgid "Save Changes and exit plugin"
msgstr "Cadw Newidiadau ac ymadael ategyn"

msgid "Search for folders with boot logos in this directory"
msgstr "Chwiliwch am ffolderi gyda logos cychwyn yn y cyfeiriadur hwn"

msgid "Which bootlogos should be displayed?"
msgstr "Pa bootlogos ddylai gael eu harddangos?"

msgid "Which logo should be displayed as a preview picture?"
msgstr "Pa logo ddylai gael ei arddangos fel llun rhagolwg?"

msgid "[BootlogoChanger] activated new bootlogo"
msgstr "[BootlogoChanger] actifadu bootlogo newydd"

msgid "[BootlogoChanger] activating new bootlogo failed"
msgstr "[BootlogoChanger] actifadu bootlogo newydd wedi methu"

msgid "[BootlogoChanger] copy failed"
msgstr "[BootlogoChanger] copi wedi methu"

msgid "[BootlogoChanger] deleting old bootlogo files"
msgstr "[BootlogoChanger] yn dileu hen ffeiliau bootlogo"

msgid "[BootlogoChanger] deleting previewPicture"
msgstr "[BootlogoChanger] yn dileu previewPicture"

msgid "[BootlogoChanger] ffmpeg not found"
msgstr "[BootlogoChanger] ffmpeg heb ei ganfod"

msgid "[BootlogoChanger] found Bootlogos"
msgstr "[BootlogoChanger] dod o hyd i Bootlogos"

msgid "[BootlogoChanger] found ffmpeg"
msgstr "Daeth [BootlogoChanger] o hyd i ffmpeg"

msgid "[BootlogoChanger] no bootlogos for randomization selected"
msgstr "[BootlogoChanger] dim bootlogos ar gyfer hapnodi wedi'u dewis"

msgid "[BootlogoChanger] previewPicture changed"
msgstr "[BootlogoChanger] previewPicture wedi newid"

msgid "[BootlogoChanger] randomization of bootlogos activated"
msgstr "[BootlogoChanger] ar hap o bootlogos wedi'i actifadu"

msgid "[BootlogoChanger] randomization of bootlogos deactivated"
msgstr "[BootlogoChanger] dadactifadu bootlogos ar hap"

msgid "[BootlogoChanger] randomization: bootlogo found"
msgstr "[BootlogoChanger] ar hap: canfuwyd bootlogo"

msgid "[BootlogoChanger] selected bootlogos"
msgstr "[BootlogoChanger] bootlogos dethol"

msgid "deinstall"
msgstr "dadosod"

msgid "found"
msgstr "dod o hyd"

msgid "install"
msgstr "gosod"

msgid "missing"
msgstr "ar goll"

msgid "off"
msgstr "i ffwrdd"

msgid "on"
msgstr "ymlaen"
