msgid "Activate the debug-output on console"
msgstr "Aktiver feilsøkingsutgangen på konsollen"

msgid "Bootlogo is excluded from random selection"
msgstr "Bootlogo er ekskludert fra tilfeldig valg"

msgid "Bootlogo is included in random selection"
msgstr "Bootlogo er inkludert i tilfeldig utvalg"

msgid "Cancel"
msgstr "Kansellere"

msgid "Choose random bootlogo at the start of the box"
msgstr "Velg tilfeldig oppstartslogo i starten av boksen"

msgid "Copy logofiles failed"
msgstr "Kopiering av logofiler mislyktes"

msgid "Current bootlogo"
msgstr "Nåværende bootlogo"

msgid "Debugmode"
msgstr "Feilsøkingsmodus"

msgid "Deinstallation of FFmpeg failed"
msgstr "Avinstallering av FFmpeg mislyktes"

msgid "Delete current mvi-files before changing bootlogo"
msgstr "Slett gjeldende mvi-filer før du endrer bootlogo"

msgid "Directory with bootlogo folders"
msgstr "Katalog med bootlogomapper"

msgid "Display duration of the status messages (sec)"
msgstr "Vis varigheten av statusmeldingene (sek.)"

msgid "Easily switch between different bootlogos"
msgstr "Bytt enkelt mellom ulike bootlogoer"

msgid "Exclude"
msgstr "Utelukke"

msgid "Exit plugin without saving"
msgstr "Avslutt plugin uten å lagre"

msgid "FFmpeg is needed to generate thumbnails from the mvi files"
msgstr "FFmpeg er nødvendig for å generere miniatyrbilder fra mvi-filene"

msgid "FFmpeg ist missing, no preview pictures available - there is an option to install it in the stettings"
msgstr "FFmpeg mangler, ingen forhåndsvisningsbilder tilgjengelig - det er mulighet for å installere det i innstillingene"

msgid "FFmpeg removed successfully"
msgstr "FFmpeg ble fjernet"

msgid "FFmpeg successfully installed"
msgstr "FFmpeg ble installert"

msgid "First delete the mvi-files of the current bootlogo then copy the files of the new one"
msgstr "Slett først mvi-filene til gjeldende bootlogo og kopier deretter filene til den nye"

msgid "Found bootlogos"
msgstr "Fant bootlogoer"

msgid "Full screen view the selected bootlogo"
msgstr "Vis den valgte bootlogoen i full skjerm"

msgid "Hide directories without 'mvi'-files"
msgstr "Skjul kataloger uten 'mvi'-filer"

msgid "Hide empty directories"
msgstr "Skjul tomme kataloger"

msgid "How many seconds should status messages be displayed (1-60 sec)"
msgstr "Hvor mange sekunder skal statusmeldinger vises (1-60 sek)"

msgid "Include"
msgstr "Inkludere"

msgid "Include or exlude logo in random choice"
msgstr "Inkluder eller ekskluder logo i tilfeldig valg"

msgid "Included Screens"
msgstr "Inkludert skjermer"

msgid "Install/deinstall ffmpeg"
msgstr "Installer/avinstaller ffmpeg"

msgid "Installation of FFmpeg failed"
msgstr "Installasjon av FFmpeg mislyktes"

msgid "No bootlogos found in directory"
msgstr "Ingen bootlogoer funnet i katalogen"

msgid "OK"
msgstr ""

msgid "Open settings"
msgstr "Åpne innstillinger"

msgid "Preview Logo"
msgstr "Forhåndsvisningslogo"

msgid "Preview picture"
msgstr "Forhåndsvis bilde"

msgid "Random mode"
msgstr "Tilfeldig modus"

msgid "Random selection at startup disabled"
msgstr "Tilfeldig valg ved oppstart deaktivert"

msgid "Random selection at startup enabled"
msgstr "Tilfeldig valg ved oppstart aktivert"

msgid "Save Changes and exit plugin"
msgstr "Lagre endringer og avslutt plugin"

msgid "Search for folders with boot logos in this directory"
msgstr "Søk etter mapper med oppstartslogoer i denne katalogen"

msgid "Which bootlogos should be displayed?"
msgstr "Hvilke oppstartslogoer skal vises?"

msgid "Which logo should be displayed as a preview picture?"
msgstr "Hvilken logo skal vises som et forhåndsvisningsbilde?"

msgid "[BootlogoChanger] activated new bootlogo"
msgstr "[BootlogoChanger] aktiverte ny oppstartslogo"

msgid "[BootlogoChanger] activating new bootlogo failed"
msgstr "[BootlogoChanger] aktivering av ny oppstartslogo mislyktes"

msgid "[BootlogoChanger] copy failed"
msgstr "Kopiering av [BootlogoChanger] mislyktes"

msgid "[BootlogoChanger] deleting old bootlogo files"
msgstr "[BootlogoChanger] sletter gamle bootlogo-filer"

msgid "[BootlogoChanger] deleting previewPicture"
msgstr "[BootlogoChanger] sletter forhåndsvisningsbilde"

msgid "[BootlogoChanger] ffmpeg not found"
msgstr "[BootlogoChanger] ffmpeg ikke funnet"

msgid "[BootlogoChanger] found Bootlogos"
msgstr "[BootlogoChanger] fant Bootlogos"

msgid "[BootlogoChanger] found ffmpeg"
msgstr "[BootlogoChanger] funnet ffmpeg"

msgid "[BootlogoChanger] no bootlogos for randomization selected"
msgstr "[BootlogoChanger] ingen oppstartslogoer for randomisering er valgt"

msgid "[BootlogoChanger] previewPicture changed"
msgstr "[BootlogoChanger] forhåndsvisning Bilde endret"

msgid "[BootlogoChanger] randomization of bootlogos activated"
msgstr "[BootlogoChanger] randomisering av bootlogoer aktivert"

msgid "[BootlogoChanger] randomization of bootlogos deactivated"
msgstr "[BootlogoChanger] randomisering av bootlogoer deaktivert"

msgid "[BootlogoChanger] randomization: bootlogo found"
msgstr "[BootlogoChanger] randomisering: bootlogo funnet"

msgid "[BootlogoChanger] selected bootlogos"
msgstr "[BootlogoChanger] valgte oppstartslogoer"

msgid "deinstall"
msgstr "avinstallere"

msgid "found"
msgstr "funnet"

msgid "install"
msgstr "installere"

msgid "missing"
msgstr "savnet"

msgid "off"
msgstr "av"

msgid "on"
msgstr "på"
