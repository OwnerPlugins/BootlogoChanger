msgid "Activate the debug-output on console"
msgstr "कन्सोलवर डीबग-आउटपुट सक्रिय करा"

msgid "Bootlogo is excluded from random selection"
msgstr "बूटलोगो यादृच्छिक निवडीमधून वगळले आहे"

msgid "Bootlogo is included in random selection"
msgstr "बूटलोगो यादृच्छिक निवडीमध्ये समाविष्ट आहे"

msgid "Cancel"
msgstr "रद्द करा"

msgid "Choose random bootlogo at the start of the box"
msgstr "बॉक्सच्या सुरुवातीला यादृच्छिक बूटलोगो निवडा"

msgid "Copy logofiles failed"
msgstr "लोगोफाईल्स कॉपी करणे अयशस्वी झाले"

msgid "Current bootlogo"
msgstr "वर्तमान बूटलोगो"

msgid "Debugmode"
msgstr "डीबग मोड"

msgid "Deinstallation of FFmpeg failed"
msgstr "FFmpeg ची स्थापना अयशस्वी"

msgid "Delete current mvi-files before changing bootlogo"
msgstr "बूटलोगो बदलण्यापूर्वी वर्तमान mvi-फाईल्स हटवा"

msgid "Directory with bootlogo folders"
msgstr "बूटलॉगो फोल्डर्ससह निर्देशिका"

msgid "Display duration of the status messages (sec)"
msgstr "स्थिती संदेशांचा कालावधी प्रदर्शित करा (से)"

msgid "Easily switch between different bootlogos"
msgstr "विविध बूटलॉगो दरम्यान सहजपणे स्विच करा"

msgid "Exclude"
msgstr "वगळा"

msgid "Exit plugin without saving"
msgstr "सेव्ह न करता प्लगइनमधून बाहेर पडा"

msgid "FFmpeg is needed to generate thumbnails from the mvi files"
msgstr "Mvi फाइल्समधून लघुप्रतिमा तयार करण्यासाठी FFmpeg आवश्यक आहे"

msgid "FFmpeg ist missing, no preview pictures available - there is an option to install it in the stettings"
msgstr "FFmpeg गहाळ आहे, कोणतेही पूर्वावलोकन चित्र उपलब्ध नाही - ते स्टेटिंगमध्ये स्थापित करण्याचा पर्याय आहे"

msgid "FFmpeg removed successfully"
msgstr "FFmpeg यशस्वीरित्या काढले"

msgid "FFmpeg successfully installed"
msgstr "FFmpeg यशस्वीरित्या स्थापित"

msgid "First delete the mvi-files of the current bootlogo then copy the files of the new one"
msgstr "प्रथम सध्याच्या बूटलोगोच्या mvi-फाईल्स डिलीट करा नंतर नवीन फाइल्स कॉपी करा"

msgid "Found bootlogos"
msgstr "बूटलॉग सापडले"

msgid "Full screen view the selected bootlogo"
msgstr "निवडलेला बूटलोगो पूर्ण स्क्रीन पहा"

msgid "Hide directories without 'mvi'-files"
msgstr "'mvi'-फाईल्सशिवाय निर्देशिका लपवा"

msgid "Hide empty directories"
msgstr "रिक्त निर्देशिका लपवा"

msgid "How many seconds should status messages be displayed (1-60 sec)"
msgstr "स्थिती संदेश किती सेकंदात प्रदर्शित केले जावेत (1-60 सेकंद)"

msgid "Include"
msgstr "समाविष्ट करा"

msgid "Include or exlude logo in random choice"
msgstr "यादृच्छिक निवडीमध्ये लोगो समाविष्ट करा किंवा वगळा"

msgid "Included Screens"
msgstr "समाविष्ट स्क्रीन"

msgid "Install/deinstall ffmpeg"
msgstr "ffmpeg स्थापित/विस्थापित करा"

msgid "Installation of FFmpeg failed"
msgstr "FFmpeg ची स्थापना अयशस्वी"

msgid "No bootlogos found in directory"
msgstr "निर्देशिकेत कोणतेही बूटलॉग आढळले नाहीत"

msgid "OK"
msgstr "ठीक आहे"

msgid "Open settings"
msgstr "सेटिंग्ज उघडा"

msgid "Preview Logo"
msgstr "लोगोचे पूर्वावलोकन करा"

msgid "Preview picture"
msgstr "चित्राचे पूर्वावलोकन करा"

msgid "Random mode"
msgstr "यादृच्छिक मोड"

msgid "Random selection at startup disabled"
msgstr "स्टार्टअपवर यादृच्छिक निवड अक्षम केली"

msgid "Random selection at startup enabled"
msgstr "स्टार्टअपवर यादृच्छिक निवड सक्षम केली"

msgid "Save Changes and exit plugin"
msgstr "बदल जतन करा आणि प्लगइनमधून बाहेर पडा"

msgid "Search for folders with boot logos in this directory"
msgstr "या निर्देशिकेत बूट लोगो असलेले फोल्डर शोधा"

msgid "Which bootlogos should be displayed?"
msgstr "कोणते बूटलॉग प्रदर्शित केले जावे?"

msgid "Which logo should be displayed as a preview picture?"
msgstr "पूर्वावलोकन चित्र म्हणून कोणता लोगो प्रदर्शित करावा?"

msgid "[BootlogoChanger] activated new bootlogo"
msgstr "[BootlogoChanger] नवीन बूटलोगो सक्रिय केला"

msgid "[BootlogoChanger] activating new bootlogo failed"
msgstr "[BootlogoChanger] नवीन बूटलोगो सक्रिय करणे अयशस्वी झाले"

msgid "[BootlogoChanger] copy failed"
msgstr "[BotlogoChanger] कॉपी अयशस्वी"

msgid "[BootlogoChanger] deleting old bootlogo files"
msgstr "[BootlogoChanger] जुन्या बूटलोगो फाइल्स हटवणे"

msgid "[BootlogoChanger] deleting previewPicture"
msgstr "[BootlogoChanger] previewPicture हटवत आहे"

msgid "[BootlogoChanger] ffmpeg not found"
msgstr "[BotlogoChanger] ffmpeg आढळले नाही"

msgid "[BootlogoChanger] found Bootlogos"
msgstr "[BootlogoChanger] Bootlogos आढळले"

msgid "[BootlogoChanger] found ffmpeg"
msgstr "[BootlogoChanger] ffmpeg आढळले"

msgid "[BootlogoChanger] no bootlogos for randomization selected"
msgstr "[BootlogoChanger] यादृच्छिकीकरणासाठी कोणतेही बूटलोगो निवडलेले नाहीत"

msgid "[BootlogoChanger] previewPicture changed"
msgstr "[BotlogoChanger] पूर्वावलोकन चित्र बदलले"

msgid "[BootlogoChanger] randomization of bootlogos activated"
msgstr "[BootlogoChanger] बूटलॉगोचे यादृच्छिकीकरण सक्रिय केले"

msgid "[BootlogoChanger] randomization of bootlogos deactivated"
msgstr "[BootlogoChanger] बूटलॉगोचे यादृच्छिकीकरण निष्क्रिय केले"

msgid "[BootlogoChanger] randomization: bootlogo found"
msgstr "[BootlogoChanger] यादृच्छिकीकरण: बूटलोगो सापडला"

msgid "[BootlogoChanger] selected bootlogos"
msgstr "[BootlogoChanger] निवडलेले बूटलोगो"

msgid "deinstall"
msgstr "विस्थापित करा"

msgid "found"
msgstr "आढळले"

msgid "install"
msgstr "स्थापित करा"

msgid "missing"
msgstr "गहाळ"

msgid "off"
msgstr "बंद"

msgid "on"
msgstr "वर"
