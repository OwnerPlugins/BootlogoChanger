msgid "Activate the debug-output on console"
msgstr "Aktivirajte debug-output na konzoli"

msgid "Bootlogo is excluded from random selection"
msgstr "Bootlogo je isključen iz slučajnog odabira"

msgid "Bootlogo is included in random selection"
msgstr "Bootlogo je uključen u slučajni odabir"

msgid "Cancel"
msgstr "Otkazati"

msgid "Choose random bootlogo at the start of the box"
msgstr "Odaberite slučajni bootlogo na početku okvira"

msgid "Copy logofiles failed"
msgstr "Kopiranje datoteka logotipa nije uspjelo"

msgid "Current bootlogo"
msgstr "Trenutačni bootlogo"

msgid "Debugmode"
msgstr "Način otklanjanja pogrešaka"

msgid "Deinstallation of FFmpeg failed"
msgstr "Deinstalacija FFmpeg nije uspjela"

msgid "Delete current mvi-files before changing bootlogo"
msgstr "Izbrišite trenutne mvi-datoteke prije promjene bootloga"

msgid "Directory with bootlogo folders"
msgstr "Direktorij s bootlogo mapama"

msgid "Display duration of the status messages (sec)"
msgstr "Trajanje prikaza statusnih poruka (sek.)"

msgid "Easily switch between different bootlogos"
msgstr "Jednostavno prebacivanje između različitih bootloga"

msgid "Exclude"
msgstr "Isključi"

msgid "Exit plugin without saving"
msgstr "Izađi iz dodatka bez spremanja"

msgid "FFmpeg is needed to generate thumbnails from the mvi files"
msgstr "FFmpeg je potreban za generiranje sličica iz mvi datoteka"

msgid "FFmpeg ist missing, no preview pictures available - there is an option to install it in the stettings"
msgstr "FFmpeg nedostaje, nema dostupnih slika za pregled - postoji opcija za instaliranje u postavkama"

msgid "FFmpeg removed successfully"
msgstr "FFmpeg je uspješno uklonjen"

msgid "FFmpeg successfully installed"
msgstr "FFmpeg je uspješno instaliran"

msgid "First delete the mvi-files of the current bootlogo then copy the files of the new one"
msgstr "Prvo izbrišite mvi-datoteke trenutnog bootloga, a zatim kopirajte datoteke novog"

msgid "Found bootlogos"
msgstr "Pronađen bootlogo"

msgid "Full screen view the selected bootlogo"
msgstr "Prikaz odabranog logotipa za pokretanje na cijelom zaslonu"

msgid "Hide directories without 'mvi'-files"
msgstr "Sakrij direktorije bez 'mvi'-datoteka"

msgid "Hide empty directories"
msgstr "Sakrij prazne imenike"

msgid "How many seconds should status messages be displayed (1-60 sec)"
msgstr "Koliko sekundi trebaju biti prikazane statusne poruke (1-60 s)"

msgid "Include"
msgstr "Uključiti"

msgid "Include or exlude logo in random choice"
msgstr "Uključi ili isključi logotip u nasumičnom izboru"

msgid "Included Screens"
msgstr "Uključeni zasloni"

msgid "Install/deinstall ffmpeg"
msgstr "Instalirajte/deinstalirajte ffmpeg"

msgid "Installation of FFmpeg failed"
msgstr "Instalacija FFmpeg nije uspjela"

msgid "No bootlogos found in directory"
msgstr "Nema logotipa za pokretanje u direktoriju"

msgid "OK"
msgstr "U REDU"

msgid "Open settings"
msgstr "Otvori postavke"

msgid "Preview Logo"
msgstr "Pregledajte logotip"

msgid "Preview picture"
msgstr "Pregled slike"

msgid "Random mode"
msgstr "Nasumični način rada"

msgid "Random selection at startup disabled"
msgstr "Nasumični odabir pri pokretanju onemogućen"

msgid "Random selection at startup enabled"
msgstr "Nasumični odabir pri pokretanju omogućen"

msgid "Save Changes and exit plugin"
msgstr "Spremite promjene i izađite iz dodatka"

msgid "Search for folders with boot logos in this directory"
msgstr "Potražite mape s logotipima za pokretanje u ovom direktoriju"

msgid "Which bootlogos should be displayed?"
msgstr "Koji bi logotipi za pokretanje trebali biti prikazani?"

msgid "Which logo should be displayed as a preview picture?"
msgstr "Koji logo treba prikazati kao sliku za pregled?"

msgid "[BootlogoChanger] activated new bootlogo"
msgstr "[BootlogoChanger] je aktivirao novi bootlogo"

msgid "[BootlogoChanger] activating new bootlogo failed"
msgstr "[BootlogoChanger] aktiviranje novog bootloga nije uspjelo"

msgid "[BootlogoChanger] copy failed"
msgstr "Kopiranje [BootlogoChanger] nije uspjelo"

msgid "[BootlogoChanger] deleting old bootlogo files"
msgstr "[BootlogoChanger] brisanje starih bootlogo datoteka"

msgid "[BootlogoChanger] deleting previewPicture"
msgstr "[BootlogoChanger] brisanje slike za pregled"

msgid "[BootlogoChanger] ffmpeg not found"
msgstr "[BootlogoChanger] ffmpeg nije pronađen"

msgid "[BootlogoChanger] found Bootlogos"
msgstr "[BootlogoChanger] je pronašao Bootlogove"

msgid "[BootlogoChanger] found ffmpeg"
msgstr "[BootlogoChanger] je pronašao ffmpeg"

msgid "[BootlogoChanger] no bootlogos for randomization selected"
msgstr "[BootlogoChanger] nema odabranih logotipa za pokretanje za nasumično odabiranje"

msgid "[BootlogoChanger] previewPicture changed"
msgstr "[BootlogoChanger] pregled Slika promijenjena"

msgid "[BootlogoChanger] randomization of bootlogos activated"
msgstr "[BootlogoChanger] randomizacija bootlogova aktivirana"

msgid "[BootlogoChanger] randomization of bootlogos deactivated"
msgstr "[BootlogoChanger] randomizacija bootlogova deaktivirana"

msgid "[BootlogoChanger] randomization: bootlogo found"
msgstr "[BootlogoChanger] randomizacija: bootlogo pronađen"

msgid "[BootlogoChanger] selected bootlogos"
msgstr "[BootlogoChanger] odabrani logotipi za pokretanje"

msgid "deinstall"
msgstr "deinstalirati"

msgid "found"
msgstr "pronašao"

msgid "install"
msgstr "instalirati"

msgid "missing"
msgstr "nedostaje"

msgid "off"
msgstr "isključeno"

msgid "on"
msgstr "na"
