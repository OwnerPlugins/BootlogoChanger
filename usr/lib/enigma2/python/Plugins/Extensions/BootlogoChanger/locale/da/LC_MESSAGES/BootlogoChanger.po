msgid "Activate the debug-output on console"
msgstr "Aktiver debug-outputtet på konsollen"

msgid "Bootlogo is excluded from random selection"
msgstr "Bootlogo er udelukket fra tilfældigt valg"

msgid "Bootlogo is included in random selection"
msgstr "Bootlogo er inkluderet i tilfældigt udvalg"

msgid "Cancel"
msgstr "Ophæve"

msgid "Choose random bootlogo at the start of the box"
msgstr "Vælg tilfældigt bootlogo i starten af ​​boksen"

msgid "Copy logofiles failed"
msgstr "Kopiering af logofiler mislykkedes"

msgid "Current bootlogo"
msgstr "Nuværende bootlogo"

msgid "Debugmode"
msgstr "Fejlretningstilstand"

msgid "Deinstallation of FFmpeg failed"
msgstr "Afinstallation af FFmpeg mislykkedes"

msgid "Delete current mvi-files before changing bootlogo"
msgstr "Slet aktuelle mvi-filer før du ændrer bootlogo"

msgid "Directory with bootlogo folders"
msgstr "Katalog med bootlogomapper"

msgid "Display duration of the status messages (sec)"
msgstr "Vis varigheden af ​​statusmeddelelserne (sek.)"

msgid "Easily switch between different bootlogos"
msgstr "Skift nemt mellem forskellige bootlogoer"

msgid "Exclude"
msgstr "Udelukke"

msgid "Exit plugin without saving"
msgstr "Afslut plugin uden at gemme"

msgid "FFmpeg is needed to generate thumbnails from the mvi files"
msgstr "FFmpeg er nødvendig for at generere thumbnails fra mvi-filerne"

msgid "FFmpeg ist missing, no preview pictures available - there is an option to install it in the stettings"
msgstr "FFmpeg mangler, ingen forhåndsvisningsbilleder tilgængelige - der er mulighed for at installere det i indstillingerne"

msgid "FFmpeg removed successfully"
msgstr "FFmpeg blev fjernet"

msgid "FFmpeg successfully installed"
msgstr "FFmpeg installeret"

msgid "First delete the mvi-files of the current bootlogo then copy the files of the new one"
msgstr "Slet først mvi-filerne for det aktuelle bootlogo og kopier derefter filerne til det nye"

msgid "Found bootlogos"
msgstr "Fandt bootlogoer"

msgid "Full screen view the selected bootlogo"
msgstr "Vis det valgte bootlogo i fuld skærm"

msgid "Hide directories without 'mvi'-files"
msgstr "Skjul mapper uden 'mvi'-filer"

msgid "Hide empty directories"
msgstr "Skjul tomme mapper"

msgid "How many seconds should status messages be displayed (1-60 sec)"
msgstr "Hvor mange sekunder skal statusmeddelelser vises (1-60 sek.)"

msgid "Include"
msgstr "Omfatte"

msgid "Include or exlude logo in random choice"
msgstr "Medtag eller udelad logo i tilfældigt valg"

msgid "Included Screens"
msgstr "Medfølgende skærme"

msgid "Install/deinstall ffmpeg"
msgstr "Installer/afinstaller ffmpeg"

msgid "Installation of FFmpeg failed"
msgstr "Installation af FFmpeg mislykkedes"

msgid "No bootlogos found in directory"
msgstr "Ingen bootlogoer fundet i mappen"

msgid "OK"
msgstr ""

msgid "Open settings"
msgstr "Åbn indstillinger"

msgid "Preview Logo"
msgstr "Forhåndsvisning af logo"

msgid "Preview picture"
msgstr "Forhåndsvisning af billede"

msgid "Random mode"
msgstr "Tilfældig tilstand"

msgid "Random selection at startup disabled"
msgstr "Tilfældigt valg ved opstart deaktiveret"

msgid "Random selection at startup enabled"
msgstr "Tilfældigt valg ved opstart aktiveret"

msgid "Save Changes and exit plugin"
msgstr "Gem ændringer og afslut plugin"

msgid "Search for folders with boot logos in this directory"
msgstr "Søg efter mapper med opstartslogoer i denne mappe"

msgid "Which bootlogos should be displayed?"
msgstr "Hvilke bootlogoer skal vises?"

msgid "Which logo should be displayed as a preview picture?"
msgstr "Hvilket logo skal vises som et eksempelbillede?"

msgid "[BootlogoChanger] activated new bootlogo"
msgstr "[BootlogoChanger] aktiverede nyt bootlogo"

msgid "[BootlogoChanger] activating new bootlogo failed"
msgstr "[BootlogoChanger] aktivering af nyt bootlogo mislykkedes"

msgid "[BootlogoChanger] copy failed"
msgstr "Kopiering af [BootlogoChanger] mislykkedes"

msgid "[BootlogoChanger] deleting old bootlogo files"
msgstr "[BootlogoChanger] sletter gamle bootlogo-filer"

msgid "[BootlogoChanger] deleting previewPicture"
msgstr "[BootlogoChanger] sletter previewPicture"

msgid "[BootlogoChanger] ffmpeg not found"
msgstr "[BootlogoChanger] ffmpeg ikke fundet"

msgid "[BootlogoChanger] found Bootlogos"
msgstr "[BootlogoChanger] fandt Bootlogos"

msgid "[BootlogoChanger] found ffmpeg"
msgstr "[BootlogoChanger] fundet ffmpeg"

msgid "[BootlogoChanger] no bootlogos for randomization selected"
msgstr "[BootlogoChanger] ingen bootlogoer til randomisering er valgt"

msgid "[BootlogoChanger] previewPicture changed"
msgstr "[BootlogoChanger] previewBillede ændret"

msgid "[BootlogoChanger] randomization of bootlogos activated"
msgstr "[BootlogoChanger] randomisering af bootlogoer aktiveret"

msgid "[BootlogoChanger] randomization of bootlogos deactivated"
msgstr "[BootlogoChanger] randomisering af bootlogoer deaktiveret"

msgid "[BootlogoChanger] randomization: bootlogo found"
msgstr "[BootlogoChanger] randomisering: bootlogo fundet"

msgid "[BootlogoChanger] selected bootlogos"
msgstr "[BootlogoChanger] valgte bootlogoer"

msgid "deinstall"
msgstr "afinstallere"

msgid "found"
msgstr "fundet"

msgid "install"
msgstr "installere"

msgid "missing"
msgstr "manglende"

msgid "off"
msgstr "slukket"

msgid "on"
msgstr "på"
