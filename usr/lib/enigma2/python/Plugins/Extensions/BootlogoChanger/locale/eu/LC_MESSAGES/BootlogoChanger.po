msgid "Activate the debug-output on console"
msgstr "Aktibatu arazte-irteera kontsolan"

msgid "Bootlogo is excluded from random selection"
msgstr "Bootlogo ausazko hautapenetik kanpo geratzen da"

msgid "Bootlogo is included in random selection"
msgstr "Bootlogo ausazko hautapenean sartzen da"

msgid "Cancel"
msgstr "Utzi"

msgid "Choose random bootlogo at the start of the box"
msgstr "Aukeratu ausazko bootlogoa koadroaren hasieran"

msgid "Copy logofiles failed"
msgstr "Ezin izan dira kopiatu logotipo-fitxategiak"

msgid "Current bootlogo"
msgstr "Oraingo bootlogoa"

msgid "Debugmode"
msgstr "Arazte modua"

msgid "Deinstallation of FFmpeg failed"
msgstr "Huts egin du FFmpeg desinstalatu"

msgid "Delete current mvi-files before changing bootlogo"
msgstr "Ezabatu uneko mvi-fitxategiak bootlogoa aldatu aurretik"

msgid "Directory with bootlogo folders"
msgstr "Bootlogo karpetekin direktorioa"

msgid "Display duration of the status messages (sec)"
msgstr "Bistaratu egoera-mezuen iraupena (seg)"

msgid "Easily switch between different bootlogos"
msgstr "Erraz aldatu bootlogo ezberdinen artean"

msgid "Exclude"
msgstr "Baztertu"

msgid "Exit plugin without saving"
msgstr "Irten plugina gorde gabe"

msgid "FFmpeg is needed to generate thumbnails from the mvi files"
msgstr "FFmpeg behar da mvi fitxategietatik miniaturak sortzeko"

msgid "FFmpeg ist missing, no preview pictures available - there is an option to install it in the stettings"
msgstr "FFmpeg falta da, ez dago aurrebista argazkirik eskuragarri - ezarpenetan instalatzeko aukera dago"

msgid "FFmpeg removed successfully"
msgstr "FFmpeg behar bezala kendu da"

msgid "FFmpeg successfully installed"
msgstr "FFmpeg behar bezala instalatu da"

msgid "First delete the mvi-files of the current bootlogo then copy the files of the new one"
msgstr "Lehenik eta behin, ezabatu uneko bootlogoaren mvi-fitxategiak eta gero kopiatu berriaren fitxategiak"

msgid "Found bootlogos"
msgstr "Bootlogoak aurkitu dira"

msgid "Full screen view the selected bootlogo"
msgstr "Pantaila osoan ikusi hautatutako abioko logoa"

msgid "Hide directories without 'mvi'-files"
msgstr "Ezkutatu direktorioa 'mvi'-fitxategirik gabe"

msgid "Hide empty directories"
msgstr "Ezkutatu direktorio hutsak"

msgid "How many seconds should status messages be displayed (1-60 sec)"
msgstr "Zenbat segundo bistaratu behar diren egoera-mezuak (1-60 segundo)"

msgid "Include"
msgstr "Sartu"

msgid "Include or exlude logo in random choice"
msgstr "Sartu edo kendu logotipoa ausazko aukeran"

msgid "Included Screens"
msgstr "Sartutako pantailak"

msgid "Install/deinstall ffmpeg"
msgstr "Instalatu/desinstalatu ffmpeg"

msgid "Installation of FFmpeg failed"
msgstr "FFmpeg instalazioak huts egin du"

msgid "No bootlogos found in directory"
msgstr "Ez da abiarazte-logorik aurkitu direktorioan"

msgid "OK"
msgstr "Ados"

msgid "Open settings"
msgstr "Ireki ezarpenak"

msgid "Preview Logo"
msgstr "Aurreikusi logotipoa"

msgid "Preview picture"
msgstr "Aurrebista argazkia"

msgid "Random mode"
msgstr "Ausazko modua"

msgid "Random selection at startup disabled"
msgstr "Abiaraztean ausazko hautaketa desgaituta dago"

msgid "Random selection at startup enabled"
msgstr "Abiaraztean ausazko hautaketa gaituta dago"

msgid "Save Changes and exit plugin"
msgstr "Gorde aldaketak eta irten plugina"

msgid "Search for folders with boot logos in this directory"
msgstr "Bilatu direktorio honetan abioko logotipoak dituzten karpetak"

msgid "Which bootlogos should be displayed?"
msgstr "Zein abiarazte-logo erakutsi behar dira?"

msgid "Which logo should be displayed as a preview picture?"
msgstr "Zein logotipo bistaratu behar da aurrebista-irudi gisa?"

msgid "[BootlogoChanger] activated new bootlogo"
msgstr "[BootlogoChanger] bootlogo berria aktibatu du"

msgid "[BootlogoChanger] activating new bootlogo failed"
msgstr "[BootlogoChanger] huts egin du bootlogo berria aktibatu"

msgid "[BootlogoChanger] copy failed"
msgstr "[BootlogoChanger] kopiak huts egin du"

msgid "[BootlogoChanger] deleting old bootlogo files"
msgstr "[BootlogoChanger] bootlogo fitxategi zaharrak ezabatzen ditu"

msgid "[BootlogoChanger] deleting previewPicture"
msgstr "[BootlogoChanger] aurrebista Irudia ezabatzen"

msgid "[BootlogoChanger] ffmpeg not found"
msgstr "[BootlogoChanger] ffmpeg ez da aurkitu"

msgid "[BootlogoChanger] found Bootlogos"
msgstr "[BootlogoChanger] Bootlogoak aurkitu ditu"

msgid "[BootlogoChanger] found ffmpeg"
msgstr "[BootlogoChanger] ffmpeg aurkitu du"

msgid "[BootlogoChanger] no bootlogos for randomization selected"
msgstr "[BootlogoChanger] ez dago hautatutako ausazko abiarazterako logorik"

msgid "[BootlogoChanger] previewPicture changed"
msgstr "[BootlogoChanger] aurrebista Irudia aldatu da"

msgid "[BootlogoChanger] randomization of bootlogos activated"
msgstr "[BootlogoChanger] bootlogoen ausazko banaketa aktibatuta dago"

msgid "[BootlogoChanger] randomization of bootlogos deactivated"
msgstr "[BootlogoChanger] bootlogoen aleatorizazioa desaktibatu da"

msgid "[BootlogoChanger] randomization: bootlogo found"
msgstr "[BootlogoChanger] ausazko banaketa: bootlogo aurkitu da"

msgid "[BootlogoChanger] selected bootlogos"
msgstr "[BootlogoChanger] hautatutako abioko logotipoak"

msgid "deinstall"
msgstr "desinstalatu"

msgid "found"
msgstr "aurkitu"

msgid "install"
msgstr "instalatu"

msgid "missing"
msgstr "faltan"

msgid "off"
msgstr "itzali"

msgid "on"
msgstr ""
