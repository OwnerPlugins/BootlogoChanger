msgid "Activate the debug-output on console"
msgstr "Активирајте излаз за отклањање грешака на конзоли"

msgid "Bootlogo is excluded from random selection"
msgstr "Боотлого је искључен из случајног избора"

msgid "Bootlogo is included in random selection"
msgstr "Боотлого је укључен у случајни избор"

msgid "Cancel"
msgstr "Откажи"

msgid "Choose random bootlogo at the start of the box"
msgstr "Изаберите насумични боотлого на почетку оквира"

msgid "Copy logofiles failed"
msgstr "Копирање логофајлова није успело"

msgid "Current bootlogo"
msgstr "Тренутни боотлого"

msgid "Debugmode"
msgstr "Режим за отклањање грешака"

msgid "Deinstallation of FFmpeg failed"
msgstr "Деинсталација ФФмпег-а није успела"

msgid "Delete current mvi-files before changing bootlogo"
msgstr "Избришите тренутне мви-фајлове пре промене боотлого-а"

msgid "Directory with bootlogo folders"
msgstr "Директоријум са боотлого фолдерима"

msgid "Display duration of the status messages (sec)"
msgstr "Трајање приказа статусних порука (сек.)"

msgid "Easily switch between different bootlogos"
msgstr "Лако се пребаците између различитих логотипа за покретање"

msgid "Exclude"
msgstr "Искључи"

msgid "Exit plugin without saving"
msgstr "Изађите из додатка без чувања"

msgid "FFmpeg is needed to generate thumbnails from the mvi files"
msgstr "ФФмпег је потребан за генерисање сличица из мви датотека"

msgid "FFmpeg ist missing, no preview pictures available - there is an option to install it in the stettings"
msgstr "ФФмпег недостаје, нема доступних слика за преглед - постоји опција да га инсталирате у подешавањима"

msgid "FFmpeg removed successfully"
msgstr "ФФмпег је успешно уклоњен"

msgid "FFmpeg successfully installed"
msgstr "ФФмпег је успешно инсталиран"

msgid "First delete the mvi-files of the current bootlogo then copy the files of the new one"
msgstr "Прво избришите мви-датотеке тренутног боотлого-а, а затим копирајте датотеке новог"

msgid "Found bootlogos"
msgstr "Фоунд боотлогос"

msgid "Full screen view the selected bootlogo"
msgstr "Прегледајте изабрани лого за покретање преко целог екрана"

msgid "Hide directories without 'mvi'-files"
msgstr "Сакриј директоријуме без 'мви'-датотека"

msgid "Hide empty directories"
msgstr "Сакриј празне директоријуме"

msgid "How many seconds should status messages be displayed (1-60 sec)"
msgstr "Колико секунди треба да се приказују статусне поруке (1-60 секунди)"

msgid "Include"
msgstr "Укључи"

msgid "Include or exlude logo in random choice"
msgstr "Укључите или искључите лого у насумичном избору"

msgid "Included Screens"
msgstr "Укључени екрани"

msgid "Install/deinstall ffmpeg"
msgstr "Инсталирајте/деинсталирајте ффмпег"

msgid "Installation of FFmpeg failed"
msgstr "Инсталација ФФмпег-а није успела"

msgid "No bootlogos found in directory"
msgstr "Ниједан лого за покретање није пронађен у директоријуму"

msgid "OK"
msgstr "ОК"

msgid "Open settings"
msgstr "Отворите подешавања"

msgid "Preview Logo"
msgstr "Превиев Лого"

msgid "Preview picture"
msgstr "Преглед слике"

msgid "Random mode"
msgstr "Случајни режим"

msgid "Random selection at startup disabled"
msgstr "Насумични избор при покретању је онемогућен"

msgid "Random selection at startup enabled"
msgstr "Омогућен је случајни избор при покретању"

msgid "Save Changes and exit plugin"
msgstr "Сачувај промене и изађи из додатка"

msgid "Search for folders with boot logos in this directory"
msgstr "Потражите фасцикле са логом за покретање у овом директоријуму"

msgid "Which bootlogos should be displayed?"
msgstr "Који логотипи за покретање треба да буду приказани?"

msgid "Which logo should be displayed as a preview picture?"
msgstr "Који лого треба да буде приказан као слика за преглед?"

msgid "[BootlogoChanger] activated new bootlogo"
msgstr "[БоотлогоЦхангер] је активирао нови боотлого"

msgid "[BootlogoChanger] activating new bootlogo failed"
msgstr "[БоотлогоЦхангер] активирање новог боотлого није успело"

msgid "[BootlogoChanger] copy failed"
msgstr "[БоотлогоЦхангер] копирање није успело"

msgid "[BootlogoChanger] deleting old bootlogo files"
msgstr "[БоотлогоЦхангер] брисање старих боотлого датотека"

msgid "[BootlogoChanger] deleting previewPicture"
msgstr "[БоотлогоЦхангер] брисање превиевПицтуре"

msgid "[BootlogoChanger] ffmpeg not found"
msgstr "[БоотлогоЦхангер] ффмпег није пронађен"

msgid "[BootlogoChanger] found Bootlogos"
msgstr "[БоотлогоЦхангер] је пронашао Боотлого"

msgid "[BootlogoChanger] found ffmpeg"
msgstr "[БоотлогоЦхангер] је пронађен ффмпег"

msgid "[BootlogoChanger] no bootlogos for randomization selected"
msgstr "[БоотлогоЦхангер] није изабран ниједан боотлого за рандомизацију"

msgid "[BootlogoChanger] previewPicture changed"
msgstr "[БоотлогоЦхангер] превиевСлика је промењена"

msgid "[BootlogoChanger] randomization of bootlogos activated"
msgstr "[БоотлогоЦхангер] активирана рандомизација боотлого-а"

msgid "[BootlogoChanger] randomization of bootlogos deactivated"
msgstr "[БоотлогоЦхангер] рандомизација боотлогоса је деактивирана"

msgid "[BootlogoChanger] randomization: bootlogo found"
msgstr "[БоотлогоЦхангер] рандомизација: боотлого пронађен"

msgid "[BootlogoChanger] selected bootlogos"
msgstr "[БоотлогоЦхангер] изабрани логотипи за покретање"

msgid "deinstall"
msgstr "деинсталирати"

msgid "found"
msgstr "пронађено"

msgid "install"
msgstr "инсталирати"

msgid "missing"
msgstr "недостаје"

msgid "off"
msgstr "искључено"

msgid "on"
msgstr "на"
