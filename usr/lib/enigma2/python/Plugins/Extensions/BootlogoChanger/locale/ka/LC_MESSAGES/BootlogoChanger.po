msgid "Activate the debug-output on console"
msgstr "გაააქტიურეთ გამართვის გამომავალი კონსოლზე"

msgid "Bootlogo is excluded from random selection"
msgstr "Bootlogo გამორიცხულია შემთხვევითი შერჩევისგან"

msgid "Bootlogo is included in random selection"
msgstr "Bootlogo შედის შემთხვევით შერჩევაში"

msgid "Cancel"
msgstr "გაუქმება"

msgid "Choose random bootlogo at the start of the box"
msgstr "აირჩიეთ შემთხვევითი bootlogo ყუთის დასაწყისში"

msgid "Copy logofiles failed"
msgstr "ლოგოფაილების კოპირება ვერ მოხერხდა"

msgid "Current bootlogo"
msgstr "მიმდინარე bootlogo"

msgid "Debugmode"
msgstr "გამართვის რეჟიმი"

msgid "Deinstallation of FFmpeg failed"
msgstr "FFmpeg-ის დეინსტალაცია ვერ მოხერხდა"

msgid "Delete current mvi-files before changing bootlogo"
msgstr "წაშალეთ მიმდინარე mvi ფაილები bootlogo-ს შეცვლამდე"

msgid "Directory with bootlogo folders"
msgstr "დირექტორია bootlogo საქაღალდეებით"

msgid "Display duration of the status messages (sec)"
msgstr "სტატუსის შეტყობინებების ხანგრძლივობის ჩვენება (წმ)"

msgid "Easily switch between different bootlogos"
msgstr "მარტივად გადართეთ სხვადასხვა ბუტლოგოს შორის"

msgid "Exclude"
msgstr "გამორიცხეთ"

msgid "Exit plugin without saving"
msgstr "მოდულიდან გასვლა შენახვის გარეშე"

msgid "FFmpeg is needed to generate thumbnails from the mvi files"
msgstr "FFmpeg საჭიროა mvi ფაილებიდან მინიატურების გენერირებისთვის"

msgid "FFmpeg ist missing, no preview pictures available - there is an option to install it in the stettings"
msgstr "FFmpeg აკლია, წინასწარი გადახედვის სურათები არ არის ხელმისაწვდომი - არის პარამეტრებში მისი ინსტალაციის ვარიანტი"

msgid "FFmpeg removed successfully"
msgstr "FFmpeg წარმატებით წაიშალა"

msgid "FFmpeg successfully installed"
msgstr "FFmpeg წარმატებით დაინსტალირდა"

msgid "First delete the mvi-files of the current bootlogo then copy the files of the new one"
msgstr "ჯერ წაშალეთ მიმდინარე bootlogo-ის mvi-ფაილები, შემდეგ დააკოპირეთ ახალი ფაილები"

msgid "Found bootlogos"
msgstr "ნაპოვნია ბუტლოგოები"

msgid "Full screen view the selected bootlogo"
msgstr "სრული ეკრანის ნახვა არჩეული bootlogo"

msgid "Hide directories without 'mvi'-files"
msgstr "დამალე დირექტორიები 'mvi'-ფაილების გარეშე"

msgid "Hide empty directories"
msgstr "ცარიელი დირექტორიების დამალვა"

msgid "How many seconds should status messages be displayed (1-60 sec)"
msgstr "რამდენი წამი უნდა იყოს ნაჩვენები სტატუსის შეტყობინებები (1-60 წმ)"

msgid "Include"
msgstr "ჩართეთ"

msgid "Include or exlude logo in random choice"
msgstr "ლოგოს ჩართვა ან გამორიცხვა შემთხვევით არჩევანში"

msgid "Included Screens"
msgstr "მოყვება ეკრანები"

msgid "Install/deinstall ffmpeg"
msgstr "დააინსტალირეთ/წაშალეთ ffmpeg"

msgid "Installation of FFmpeg failed"
msgstr "FFmpeg-ის ინსტალაცია ვერ მოხერხდა"

msgid "No bootlogos found in directory"
msgstr "დირექტორიაში არ მოიძებნა bootlogos"

msgid "OK"
msgstr ""

msgid "Open settings"
msgstr "გახსენით პარამეტრები"

msgid "Preview Logo"
msgstr "ლოგოს გადახედვა"

msgid "Preview picture"
msgstr "სურათის გადახედვა"

msgid "Random mode"
msgstr "შემთხვევითი რეჟიმი"

msgid "Random selection at startup disabled"
msgstr "გაშვებისას შემთხვევითი შერჩევა გამორთულია"

msgid "Random selection at startup enabled"
msgstr "გაშვებისას შემთხვევითი შერჩევა ჩართულია"

msgid "Save Changes and exit plugin"
msgstr "შეინახეთ ცვლილებები და გამოდით დანამატიდან"

msgid "Search for folders with boot logos in this directory"
msgstr "მოძებნეთ საქაღალდეები ჩატვირთვის ლოგოებით ამ დირექტორიაში"

msgid "Which bootlogos should be displayed?"
msgstr "რომელი bootlogos უნდა იყოს ნაჩვენები?"

msgid "Which logo should be displayed as a preview picture?"
msgstr "რომელი ლოგო უნდა იყოს ნაჩვენები წინასწარი სურათის სახით?"

msgid "[BootlogoChanger] activated new bootlogo"
msgstr "[BootlogoChanger]-მა გააქტიურა ახალი ჩატვირთვის ლოგო"

msgid "[BootlogoChanger] activating new bootlogo failed"
msgstr "[BootlogoChanger]-ის ახალი ჩატვირთვის გააქტიურება ვერ მოხერხდა"

msgid "[BootlogoChanger] copy failed"
msgstr "[BootlogoChanger] კოპირება ვერ მოხერხდა"

msgid "[BootlogoChanger] deleting old bootlogo files"
msgstr "[BootlogoChanger] ძველი bootlogo ფაილების წაშლა"

msgid "[BootlogoChanger] deleting previewPicture"
msgstr "[BootlogoChanger] იშლება გადახედვის სურათი"

msgid "[BootlogoChanger] ffmpeg not found"
msgstr "[BootlogoChanger] ffmpeg ვერ მოიძებნა"

msgid "[BootlogoChanger] found Bootlogos"
msgstr "[BootlogoChanger] იპოვა Bootlogos"

msgid "[BootlogoChanger] found ffmpeg"
msgstr "[BootlogoChanger] ნაპოვნია ffmpeg"

msgid "[BootlogoChanger] no bootlogos for randomization selected"
msgstr "[BootlogoChanger] არ არის არჩეული რანდომიზაციისთვის ბუტლოგოები"

msgid "[BootlogoChanger] previewPicture changed"
msgstr "[BootlogoChanger] previewსურათი შეიცვალა"

msgid "[BootlogoChanger] randomization of bootlogos activated"
msgstr "[BootlogoChanger] გააქტიურებულია bootlogos-ის რანდომიზაცია"

msgid "[BootlogoChanger] randomization of bootlogos deactivated"
msgstr "[BootlogoChanger] bootlogos-ის რანდომიზაცია გამორთულია"

msgid "[BootlogoChanger] randomization: bootlogo found"
msgstr "[BootlogoChanger] რანდომიზაცია: ნაპოვნია bootlogo"

msgid "[BootlogoChanger] selected bootlogos"
msgstr "[BootlogoChanger] არჩეული bootlogos"

msgid "deinstall"
msgstr "დეინსტალაცია"

msgid "found"
msgstr "ნაპოვნია"

msgid "install"
msgstr "დააინსტალირეთ"

msgid "missing"
msgstr "დაკარგული"

msgid "off"
msgstr "გამორთულია"

msgid "on"
msgstr ""
