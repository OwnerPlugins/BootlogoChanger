msgid "Activate the debug-output on console"
msgstr "Activar la salida de depuración en la consola."

msgid "Bootlogo is excluded from random selection"
msgstr "Bootlogo está excluido de la selección aleatoria"

msgid "Bootlogo is included in random selection"
msgstr "Bootlogo está incluido en la selección aleatoria."

msgid "Cancel"
msgstr "Cancelar"

msgid "Choose random bootlogo at the start of the box"
msgstr "Elija un logotipo de arranque aleatorio al comienzo del cuadro"

msgid "Copy logofiles failed"
msgstr "Error al copiar archivos de logotipo"

msgid "Current bootlogo"
msgstr "Logotipo de arranque actual"

msgid "Debugmode"
msgstr "Modo de depuración"

msgid "Deinstallation of FFmpeg failed"
msgstr "Falló la desinstalación de FFmpeg"

msgid "Delete current mvi-files before changing bootlogo"
msgstr "Elimine los archivos mvi actuales antes de cambiar el logotipo de arranque"

msgid "Directory with bootlogo folders"
msgstr "Directorio con carpetas bootlogo"

msgid "Display duration of the status messages (sec)"
msgstr "Duración de la visualización de los mensajes de estado (seg.)"

msgid "Easily switch between different bootlogos"
msgstr "Cambia fácilmente entre diferentes logotipos de arranque"

msgid "Exclude"
msgstr "Excluir"

msgid "Exit plugin without saving"
msgstr "Salir del complemento sin guardar"

msgid "FFmpeg is needed to generate thumbnails from the mvi files"
msgstr "Se necesita FFmpeg para generar miniaturas de los archivos mvi"

msgid "FFmpeg ist missing, no preview pictures available - there is an option to install it in the stettings"
msgstr "Falta FFmpeg, no hay imágenes de vista previa disponibles; hay una opción para instalarlo en la configuración"

msgid "FFmpeg removed successfully"
msgstr "FFmpeg eliminado con éxito"

msgid "FFmpeg successfully installed"
msgstr "FFmpeg instalado exitosamente"

msgid "First delete the mvi-files of the current bootlogo then copy the files of the new one"
msgstr "Primero elimine los archivos mvi del logotipo de arranque actual y luego copie los archivos del nuevo"

msgid "Found bootlogos"
msgstr "Logotipos de arranque encontrados"

msgid "Full screen view the selected bootlogo"
msgstr "Ver en pantalla completa el logotipo de arranque seleccionado"

msgid "Hide directories without 'mvi'-files"
msgstr "Ocultar directorios sin archivos 'mvi'"

msgid "Hide empty directories"
msgstr "Ocultar directorios vacíos"

msgid "How many seconds should status messages be displayed (1-60 sec)"
msgstr "¿Cuántos segundos deben mostrarse los mensajes de estado (1-60 segundos)?"

msgid "Include"
msgstr "Incluir"

msgid "Include or exlude logo in random choice"
msgstr "Incluir o excluir logotipo en elección aleatoria"

msgid "Included Screens"
msgstr "Pantallas incluidas"

msgid "Install/deinstall ffmpeg"
msgstr "Instalar/desinstalar ffmpeg"

msgid "Installation of FFmpeg failed"
msgstr "La instalación de FFmpeg falló"

msgid "No bootlogos found in directory"
msgstr "No se encontraron logos de arranque en el directorio"

msgid "OK"
msgstr "DE ACUERDO"

msgid "Open settings"
msgstr "Abrir configuración"

msgid "Preview Logo"
msgstr "Vista previa del logotipo"

msgid "Preview picture"
msgstr "Vista previa de imagen"

msgid "Random mode"
msgstr "Modo aleatorio"

msgid "Random selection at startup disabled"
msgstr "Selección aleatoria al inicio deshabilitada"

msgid "Random selection at startup enabled"
msgstr "Selección aleatoria al inicio habilitada"

msgid "Save Changes and exit plugin"
msgstr "Guardar cambios y salir del complemento"

msgid "Search for folders with boot logos in this directory"
msgstr "Busque carpetas con logotipos de arranque en este directorio"

msgid "Which bootlogos should be displayed?"
msgstr "¿Qué logotipos de arranque deberían mostrarse?"

msgid "Which logo should be displayed as a preview picture?"
msgstr "¿Qué logotipo debería mostrarse como imagen de vista previa?"

msgid "[BootlogoChanger] activated new bootlogo"
msgstr "[BootlogoChanger] activó el nuevo logo de arranque"

msgid "[BootlogoChanger] activating new bootlogo failed"
msgstr "[BootlogoChanger] falló al activar el nuevo logo de arranque"

msgid "[BootlogoChanger] copy failed"
msgstr "Error al copiar [BootlogoChanger]"

msgid "[BootlogoChanger] deleting old bootlogo files"
msgstr "[BootlogoChanger] eliminando archivos antiguos de bootlogo"

msgid "[BootlogoChanger] deleting previewPicture"
msgstr "[BootlogoChanger] eliminando imagen previa"

msgid "[BootlogoChanger] ffmpeg not found"
msgstr "[BootlogoChanger] ffmpeg no encontrado"

msgid "[BootlogoChanger] found Bootlogos"
msgstr "[BootlogoChanger] encontró Bootlogos"

msgid "[BootlogoChanger] found ffmpeg"
msgstr "[BootlogoChanger] encontró ffmpeg"

msgid "[BootlogoChanger] no bootlogos for randomization selected"
msgstr "[BootlogoChanger] no se han seleccionado logotipos de arranque para aleatorización"

msgid "[BootlogoChanger] previewPicture changed"
msgstr "Vista previa de [BootlogoChanger] Imagen modificada"

msgid "[BootlogoChanger] randomization of bootlogos activated"
msgstr "[BootlogoChanger] aleatorización de bootlogos activada"

msgid "[BootlogoChanger] randomization of bootlogos deactivated"
msgstr "[BootlogoChanger] aleatorización de logos de arranque desactivada"

msgid "[BootlogoChanger] randomization: bootlogo found"
msgstr "[BootlogoChanger] aleatorización: se encontró el logotipo de arranque"

msgid "[BootlogoChanger] selected bootlogos"
msgstr "[BootlogoChanger] logotipos de arranque seleccionados"

msgid "deinstall"
msgstr "desinstalar"

msgid "found"
msgstr "encontró"

msgid "install"
msgstr "instalar"

msgid "missing"
msgstr "desaparecido"

msgid "off"
msgstr "apagado"

msgid "on"
msgstr "en"
