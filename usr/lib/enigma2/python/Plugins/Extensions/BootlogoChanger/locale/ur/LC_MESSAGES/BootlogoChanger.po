msgid "Activate the debug-output on console"
msgstr "کنسول پر ڈیبگ آؤٹ پٹ کو چالو کریں۔"

msgid "Bootlogo is excluded from random selection"
msgstr "بوٹلوگو کو بے ترتیب انتخاب سے خارج کر دیا گیا ہے۔"

msgid "Bootlogo is included in random selection"
msgstr "بوٹلوگو بے ترتیب انتخاب میں شامل ہے۔"

msgid "Cancel"
msgstr "منسوخ کریں۔"

msgid "Choose random bootlogo at the start of the box"
msgstr "باکس کے شروع میں بے ترتیب بوٹلوگو کا انتخاب کریں۔"

msgid "Copy logofiles failed"
msgstr "لوگو فائلز کاپی کرنے میں ناکام"

msgid "Current bootlogo"
msgstr "موجودہ بوٹلوگو"

msgid "Debugmode"
msgstr "ڈیبگ موڈ"

msgid "Deinstallation of FFmpeg failed"
msgstr "FFmpeg کی انسٹالیشن ناکام ہو گئی۔"

msgid "Delete current mvi-files before changing bootlogo"
msgstr "بوٹلوگو کو تبدیل کرنے سے پہلے موجودہ ایم وی آئی فائلوں کو حذف کریں۔"

msgid "Directory with bootlogo folders"
msgstr "بوٹلوگو فولڈرز کے ساتھ ڈائرکٹری"

msgid "Display duration of the status messages (sec)"
msgstr "اسٹیٹس میسجز کا دورانیہ دکھائیں (سیکنڈ)"

msgid "Easily switch between different bootlogos"
msgstr "مختلف بوٹلوگو کے درمیان آسانی سے سوئچ کریں۔"

msgid "Exclude"
msgstr "خارج کرنا"

msgid "Exit plugin without saving"
msgstr "محفوظ کیے بغیر پلگ ان سے باہر نکلیں۔"

msgid "FFmpeg is needed to generate thumbnails from the mvi files"
msgstr "Mvi فائلوں سے تھمب نیلز بنانے کے لیے FFmpeg کی ضرورت ہے۔"

msgid "FFmpeg ist missing, no preview pictures available - there is an option to install it in the stettings"
msgstr "FFmpeg غائب ہے، کوئی پیش نظارہ تصویر دستیاب نہیں ہے - اسے سٹیٹنگز میں انسٹال کرنے کا آپشن موجود ہے"

msgid "FFmpeg removed successfully"
msgstr "FFmpeg کامیابی کے ساتھ ہٹا دیا گیا۔"

msgid "FFmpeg successfully installed"
msgstr "FFmpeg کامیابی سے انسٹال ہو گیا۔"

msgid "First delete the mvi-files of the current bootlogo then copy the files of the new one"
msgstr "پہلے موجودہ بوٹلوگو کی ایم وی فائلز کو ڈیلیٹ کریں پھر نئی فائلز کو کاپی کریں۔"

msgid "Found bootlogos"
msgstr "بوٹلوگوز ملے"

msgid "Full screen view the selected bootlogo"
msgstr "منتخب بوٹلوگو کو پوری اسکرین دیکھیں"

msgid "Hide directories without 'mvi'-files"
msgstr "'mvi' فائلوں کے بغیر ڈائریکٹریز چھپائیں۔"

msgid "Hide empty directories"
msgstr "خالی ڈائریکٹریز چھپائیں۔"

msgid "How many seconds should status messages be displayed (1-60 sec)"
msgstr "اسٹیٹس میسجز کو کتنے سیکنڈ میں دکھایا جانا چاہیے (1-60 سیکنڈ)"

msgid "Include"
msgstr "شامل کریں۔"

msgid "Include or exlude logo in random choice"
msgstr "بے ترتیب انتخاب میں لوگو شامل کریں یا خارج کریں۔"

msgid "Included Screens"
msgstr "شامل سکرین"

msgid "Install/deinstall ffmpeg"
msgstr "ffmpeg انسٹال/ان انسٹال کریں۔"

msgid "Installation of FFmpeg failed"
msgstr "FFmpeg کی تنصیب ناکام ہو گئی۔"

msgid "No bootlogos found in directory"
msgstr "ڈائریکٹری میں کوئی بوٹلوگو نہیں ملا"

msgid "OK"
msgstr "ٹھیک ہے"

msgid "Open settings"
msgstr "ترتیبات کھولیں۔"

msgid "Preview Logo"
msgstr "لوگو کا پیش نظارہ کریں۔"

msgid "Preview picture"
msgstr "پیش نظارہ تصویر"

msgid "Random mode"
msgstr "بے ترتیب موڈ"

msgid "Random selection at startup disabled"
msgstr "آغاز پر بے ترتیب انتخاب کو غیر فعال کر دیا گیا۔"

msgid "Random selection at startup enabled"
msgstr "سٹارٹ اپ پر بے ترتیب انتخاب فعال ہے۔"

msgid "Save Changes and exit plugin"
msgstr "تبدیلیاں محفوظ کریں اور پلگ ان سے باہر نکلیں۔"

msgid "Search for folders with boot logos in this directory"
msgstr "اس ڈائریکٹری میں بوٹ لوگو والے فولڈرز تلاش کریں۔"

msgid "Which bootlogos should be displayed?"
msgstr "کون سے بوٹلوگو دکھائے جائیں؟"

msgid "Which logo should be displayed as a preview picture?"
msgstr "کون سا لوگو پیش نظارہ تصویر کے طور پر ظاہر کیا جانا چاہئے؟"

msgid "[BootlogoChanger] activated new bootlogo"
msgstr "[BootlogoChanger] نیا بوٹلوگو چالو کیا گیا۔"

msgid "[BootlogoChanger] activating new bootlogo failed"
msgstr "[BootlogoChanger] نئے بوٹلوگو کو چالو کرنا ناکام ہو گیا۔"

msgid "[BootlogoChanger] copy failed"
msgstr "[BotlogoChanger] کاپی ناکام ہو گئی۔"

msgid "[BootlogoChanger] deleting old bootlogo files"
msgstr "بوٹلوگو چینجر پرانی بوٹلوگو فائلوں کو حذف کرنا"

msgid "[BootlogoChanger] deleting previewPicture"
msgstr "[بوٹلوگو چینجر] پیش نظارہ تصویر کو حذف کرنا"

msgid "[BootlogoChanger] ffmpeg not found"
msgstr "[BotlogoChanger] ffmpeg نہیں ملا"

msgid "[BootlogoChanger] found Bootlogos"
msgstr "[BootlogoChanger] کو Bootlogos ملا"

msgid "[BootlogoChanger] found ffmpeg"
msgstr "[BotlogoChanger] ffmpeg ملا"

msgid "[BootlogoChanger] no bootlogos for randomization selected"
msgstr "[BootlogoChanger] بے ترتیب کاری کے لیے کوئی بوٹلوگو منتخب نہیں کیا گیا۔"

msgid "[BootlogoChanger] previewPicture changed"
msgstr "[BotlogoChanger] پیش نظارہ تصویر کو تبدیل کر دیا گیا۔"

msgid "[BootlogoChanger] randomization of bootlogos activated"
msgstr "[BotlogoChanger] بوٹلوگوس کی بے ترتیب کاری کو چالو کیا گیا۔"

msgid "[BootlogoChanger] randomization of bootlogos deactivated"
msgstr "[BotlogoChanger] بوٹ لاگو کی بے ترتیبی کو غیر فعال کر دیا گیا۔"

msgid "[BootlogoChanger] randomization: bootlogo found"
msgstr "[BootlogoChanger] randomization: bootlogo ملا"

msgid "[BootlogoChanger] selected bootlogos"
msgstr "[BotlogoChanger] منتخب کردہ بوٹلوگو"

msgid "deinstall"
msgstr "ان انسٹال"

msgid "found"
msgstr "پایا"

msgid "install"
msgstr "انسٹال کریں"

msgid "missing"
msgstr "لاپتہ"

msgid "off"
msgstr "بند"

msgid "on"
msgstr "پر"
