msgid "Activate the debug-output on console"
msgstr "Консол дээрх дибаг гаралтыг идэвхжүүлнэ үү"

msgid "Bootlogo is excluded from random selection"
msgstr "Bootlogo нь санамсаргүй сонголтоос хасагдсан"

msgid "Bootlogo is included in random selection"
msgstr "Bootlogo нь санамсаргүй сонголтонд багтсан болно"

msgid "Cancel"
msgstr "Цуцлах"

msgid "Choose random bootlogo at the start of the box"
msgstr "Хайрцагны эхэнд санамсаргүй ачаалах логог сонгоно уу"

msgid "Copy logofiles failed"
msgstr "Лого файлуудыг хуулж чадсангүй"

msgid "Current bootlogo"
msgstr "Одоогийн ачаалах лого"

msgid "Debugmode"
msgstr "Дибаг хийх горим"

msgid "Deinstallation of FFmpeg failed"
msgstr "FFmpeg-г устгаж чадсангүй"

msgid "Delete current mvi-files before changing bootlogo"
msgstr "Ачаалах логог өөрчлөхөөс өмнө одоогийн mvi файлуудыг устгана уу"

msgid "Directory with bootlogo folders"
msgstr "Bootlogo хавтас бүхий лавлах"

msgid "Display duration of the status messages (sec)"
msgstr "Статусын мессежийн үргэлжлэх хугацааг харуулах (сек)"

msgid "Easily switch between different bootlogos"
msgstr "Өөр өөр ачаалах логог хооронд хялбархан сольж болно"

msgid "Exclude"
msgstr "Орхих"

msgid "Exit plugin without saving"
msgstr "Залгаасыг хадгалахгүйгээр гаргана уу"

msgid "FFmpeg is needed to generate thumbnails from the mvi files"
msgstr "FFmpeg нь mvi файлуудаас өнгөц зураг үүсгэхэд хэрэгтэй"

msgid "FFmpeg ist missing, no preview pictures available - there is an option to install it in the stettings"
msgstr "FFmpeg байхгүй, урьдчилан үзэх зураг байхгүй байна - үүнийг тохиргоонд суулгах сонголт байна."

msgid "FFmpeg removed successfully"
msgstr "FFmpeg амжилттай устгагдсан"

msgid "FFmpeg successfully installed"
msgstr "FFmpeg амжилттай суулгалаа"

msgid "First delete the mvi-files of the current bootlogo then copy the files of the new one"
msgstr "Эхлээд одоо байгаа bootlogo-ийн mvi-файлуудыг устгаад шинэ файлуудыг хуулна"

msgid "Found bootlogos"
msgstr "Bootlogos олсон"

msgid "Full screen view the selected bootlogo"
msgstr "Сонгосон ачаалах логог бүтэн дэлгэцээр харах"

msgid "Hide directories without 'mvi'-files"
msgstr "'mvi' файлгүй сангуудыг нуу"

msgid "Hide empty directories"
msgstr "Хоосон сангуудыг нуух"

msgid "How many seconds should status messages be displayed (1-60 sec)"
msgstr "Статусын мессежийг хэдэн секунд харуулах ёстой вэ (1-60 сек)"

msgid "Include"
msgstr "оруулах"

msgid "Include or exlude logo in random choice"
msgstr "Санамсаргүй сонголтоор лого оруулах эсвэл хасах"

msgid "Included Screens"
msgstr "Оруулсан дэлгэцүүд"

msgid "Install/deinstall ffmpeg"
msgstr "ffmpeg суулгах/устгах"

msgid "Installation of FFmpeg failed"
msgstr "FFmpeg суулгаж чадсангүй"

msgid "No bootlogos found in directory"
msgstr "Лавлахад bootlogos олдсонгүй"

msgid "OK"
msgstr ""

msgid "Open settings"
msgstr "Тохиргоог нээх"

msgid "Preview Logo"
msgstr "Логог урьдчилан харах"

msgid "Preview picture"
msgstr "Зургийг урьдчилан үзэх"

msgid "Random mode"
msgstr "Санамсаргүй горим"

msgid "Random selection at startup disabled"
msgstr "Эхлэх үед санамсаргүй сонголтыг идэвхгүй болгосон"

msgid "Random selection at startup enabled"
msgstr "Эхлэх үед санамсаргүй сонголт идэвхжсэн"

msgid "Save Changes and exit plugin"
msgstr "Өөрчлөлтүүдийг хадгалаад залгаасаас гарна уу"

msgid "Search for folders with boot logos in this directory"
msgstr "Энэ лавлахаас ачаалах лого бүхий хавтас хайх"

msgid "Which bootlogos should be displayed?"
msgstr "Ямар ачаалагч логог харуулах ёстой вэ?"

msgid "Which logo should be displayed as a preview picture?"
msgstr "Урьдчилан харах зураг болгон ямар логог харуулах ёстой вэ?"

msgid "[BootlogoChanger] activated new bootlogo"
msgstr "[BootlogoChanger] шинэ ачаалах логог идэвхжүүлсэн"

msgid "[BootlogoChanger] activating new bootlogo failed"
msgstr "[BootlogoChanger] шинэ ачаалах логог идэвхжүүлж чадсангүй"

msgid "[BootlogoChanger] copy failed"
msgstr "[BootlogoChanger] хуулж чадсангүй"

msgid "[BootlogoChanger] deleting old bootlogo files"
msgstr "[BootlogoChanger] хуучин bootlogo файлуудыг устгаж байна"

msgid "[BootlogoChanger] deleting previewPicture"
msgstr "[BootlogoChanger] урьдчилан харах зургийг устгаж байна"

msgid "[BootlogoChanger] ffmpeg not found"
msgstr "[BootlogoChanger] ffmpeg олдсонгүй"

msgid "[BootlogoChanger] found Bootlogos"
msgstr "[BootlogoChanger] Bootlogos-ыг олсон"

msgid "[BootlogoChanger] found ffmpeg"
msgstr "[BootlogoChanger] ffmpeg-г оллоо"

msgid "[BootlogoChanger] no bootlogos for randomization selected"
msgstr "[BootlogoChanger] санамсаргүй байдлаар сонгох ачаалагч логог сонгоогүй"

msgid "[BootlogoChanger] previewPicture changed"
msgstr "[BootlogoChanger] урьдчилан харахЗураг өөрчлөгдсөн"

msgid "[BootlogoChanger] randomization of bootlogos activated"
msgstr "[BootlogoChanger] ачаалах логог санамсаргүй байдлаар идэвхжүүлсэн"

msgid "[BootlogoChanger] randomization of bootlogos deactivated"
msgstr "[BootlogoChanger] ачаалагчийн санамсаргүй тохиргоо идэвхгүй болсон"

msgid "[BootlogoChanger] randomization: bootlogo found"
msgstr "[BootlogoChanger] санамсаргүй: bootlogo олдлоо"

msgid "[BootlogoChanger] selected bootlogos"
msgstr "[BootlogoChanger] ачаалах логог сонгосон"

msgid "deinstall"
msgstr "устгах"

msgid "found"
msgstr "олдсон"

msgid "install"
msgstr "суулгах"

msgid "missing"
msgstr "алга"

msgid "off"
msgstr "унтраах"

msgid "on"
msgstr "дээр"
