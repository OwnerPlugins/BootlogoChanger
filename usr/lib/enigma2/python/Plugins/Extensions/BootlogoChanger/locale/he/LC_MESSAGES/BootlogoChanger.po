msgid "Activate the debug-output on console"
msgstr "הפעל את פלט ניפוי הבאגים במסוף"

msgid "Bootlogo is excluded from random selection"
msgstr "אתחוללוגו אינו נכלל בבחירה אקראית"

msgid "Bootlogo is included in random selection"
msgstr "אתחול כלול בבחירה אקראית"

msgid "Cancel"
msgstr "לְבַטֵל"

msgid "Choose random bootlogo at the start of the box"
msgstr "בחר בלוגו אקראי בתחילת התיבה"

msgid "Copy logofiles failed"
msgstr "העתקת קובצי לוגו נכשלה"

msgid "Current bootlogo"
msgstr "לוגו אתחול נוכחי"

msgid "Debugmode"
msgstr "מצב ניפוי באגים"

msgid "Deinstallation of FFmpeg failed"
msgstr "הסרת ההתקנה של FFmpeg נכשלה"

msgid "Delete current mvi-files before changing bootlogo"
msgstr "מחק קבצי mvi נוכחיים לפני שינוי האתחול"

msgid "Directory with bootlogo folders"
msgstr "ספרייה עם תיקיות אתחול"

msgid "Display duration of the status messages (sec)"
msgstr "הצגת משך הודעות המצב (שניות)"

msgid "Easily switch between different bootlogos"
msgstr "מעבר בקלות בין סמלי אתחול שונים"

msgid "Exclude"
msgstr "אל תכלול"

msgid "Exit plugin without saving"
msgstr "צא מהפלאגין מבלי לשמור"

msgid "FFmpeg is needed to generate thumbnails from the mvi files"
msgstr "יש צורך ב-FFmpeg כדי ליצור תמונות ממוזערות מקבצי ה-mvi"

msgid "FFmpeg ist missing, no preview pictures available - there is an option to install it in the stettings"
msgstr "FFmpeg חסר, אין תמונות תצוגה מקדימה זמינות - יש אפשרות להתקין אותו בהגדרות"

msgid "FFmpeg removed successfully"
msgstr "FFmpeg הוסר בהצלחה"

msgid "FFmpeg successfully installed"
msgstr "FFmpeg הותקן בהצלחה"

msgid "First delete the mvi-files of the current bootlogo then copy the files of the new one"
msgstr "תחילה מחק את קבצי ה-mvi של האתחול הנוכחי ואז העתק את הקבצים של הקובץ החדש"

msgid "Found bootlogos"
msgstr "נמצאו סמלי אתחול"

msgid "Full screen view the selected bootlogo"
msgstr "הצג את לוגו האתחול שנבחר במסך מלא"

msgid "Hide directories without 'mvi'-files"
msgstr "הסתר ספריות ללא קבצי 'mvi'"

msgid "Hide empty directories"
msgstr "הסתר ספריות ריקות"

msgid "How many seconds should status messages be displayed (1-60 sec)"
msgstr "כמה שניות צריך להציג הודעות סטטוס (1-60 שניות)"

msgid "Include"
msgstr "לִכלוֹל"

msgid "Include or exlude logo in random choice"
msgstr "כלול או אי הכללה של לוגו בבחירה אקראית"

msgid "Included Screens"
msgstr "מסכים כלולים"

msgid "Install/deinstall ffmpeg"
msgstr "התקן/הסר את ההתקנה של ffmpeg"

msgid "Installation of FFmpeg failed"
msgstr "ההתקנה של FFmpeg נכשלה"

msgid "No bootlogos found in directory"
msgstr "לא נמצאו סמלי אתחול בספרייה"

msgid "OK"
msgstr "בְּסֵדֶר"

msgid "Open settings"
msgstr "פתח את ההגדרות"

msgid "Preview Logo"
msgstr "לוגו תצוגה מקדימה"

msgid "Preview picture"
msgstr "תצוגה מקדימה של תמונה"

msgid "Random mode"
msgstr "מצב אקראי"

msgid "Random selection at startup disabled"
msgstr "בחירה אקראית בעת ההפעלה מושבתת"

msgid "Random selection at startup enabled"
msgstr "בחירה אקראית בעת ההפעלה מופעלת"

msgid "Save Changes and exit plugin"
msgstr "שמור שינויים וצא מהפלאגין"

msgid "Search for folders with boot logos in this directory"
msgstr "חפש תיקיות עם סמלי אתחול בספרייה זו"

msgid "Which bootlogos should be displayed?"
msgstr "אילו סמלי אתחול צריך להיות מוצג?"

msgid "Which logo should be displayed as a preview picture?"
msgstr "איזה לוגו צריך להיות מוצג כתמונת תצוגה מקדימה?"

msgid "[BootlogoChanger] activated new bootlogo"
msgstr "[BootlogoChanger] הפעילה את לוגו האתחול החדש"

msgid "[BootlogoChanger] activating new bootlogo failed"
msgstr "[BootlogoChanger] הפעלת לוגו אתחול חדש נכשלה"

msgid "[BootlogoChanger] copy failed"
msgstr "העתקה של [BootlogoChanger] נכשלה"

msgid "[BootlogoChanger] deleting old bootlogo files"
msgstr "[BootlogoChanger] מוחק קבצי אתחול ישנים"

msgid "[BootlogoChanger] deleting previewPicture"
msgstr "[BootlogoChanger] מוחק תצוגה מקדימה"

msgid "[BootlogoChanger] ffmpeg not found"
msgstr "[BootlogoChanger] ffmpeg לא נמצא"

msgid "[BootlogoChanger] found Bootlogos"
msgstr "[BootlogoChanger] מצא את Bootlogos"

msgid "[BootlogoChanger] found ffmpeg"
msgstr "[BootlogoChanger] נמצא ffmpeg"

msgid "[BootlogoChanger] no bootlogos for randomization selected"
msgstr "[BootlogoChanger] לא נבחרו סמלי אתחול לאקראיות"

msgid "[BootlogoChanger] previewPicture changed"
msgstr "[BootlogoChanger] תצוגה מקדימה התמונה השתנתה"

msgid "[BootlogoChanger] randomization of bootlogos activated"
msgstr "[BootlogoChanger] אקראית של סמלי אתחול הופעל"

msgid "[BootlogoChanger] randomization of bootlogos deactivated"
msgstr "[BootlogoChanger] אקראית של סמלי אתחול מושבת"

msgid "[BootlogoChanger] randomization: bootlogo found"
msgstr "[BootlogoChanger] אקראיות: אתחול נמצא"

msgid "[BootlogoChanger] selected bootlogos"
msgstr "[BootlogoChanger] סמלי האתחול שנבחרו"

msgid "deinstall"
msgstr "להסיר את ההתקנה"

msgid "found"
msgstr "נמצא"

msgid "install"
msgstr "לְהַתְקִין"

msgid "missing"
msgstr "חָסֵר"

msgid "off"
msgstr "כבוי"

msgid "on"
msgstr "עַל"
