msgid "Activate the debug-output on console"
msgstr "Aktivirajte izhod za odpravljanje napak na konzoli"

msgid "Bootlogo is excluded from random selection"
msgstr "Bootlogo je izključen iz naključnega izbora"

msgid "Bootlogo is included in random selection"
msgstr "Bootlogo je vključen v naključni izbor"

msgid "Cancel"
msgstr "Prekliči"

msgid "Choose random bootlogo at the start of the box"
msgstr "Izberite naključni zagonski logotip na začetku polja"

msgid "Copy logofiles failed"
msgstr "Kopiranje datotek logotipa ni uspelo"

msgid "Current bootlogo"
msgstr "Trenutni zagonski logotip"

msgid "Debugmode"
msgstr "Način odpravljanja napak"

msgid "Deinstallation of FFmpeg failed"
msgstr "Odstranitev FFmpeg ni uspela"

msgid "Delete current mvi-files before changing bootlogo"
msgstr "Izbrišite trenutne datoteke mvi, preden spremenite zagonski logotip"

msgid "Directory with bootlogo folders"
msgstr "Imenik z mapami bootlogo"

msgid "Display duration of the status messages (sec)"
msgstr "Trajanje prikaza statusnih sporočil (s)"

msgid "Easily switch between different bootlogos"
msgstr "Preprosto preklapljajte med različnimi zagonskimi logotipi"

msgid "Exclude"
msgstr "Izključi"

msgid "Exit plugin without saving"
msgstr "Zaprite vtičnik brez shranjevanja"

msgid "FFmpeg is needed to generate thumbnails from the mvi files"
msgstr "FFmpeg je potreben za ustvarjanje sličic iz datotek mvi"

msgid "FFmpeg ist missing, no preview pictures available - there is an option to install it in the stettings"
msgstr "FFmpeg manjka, slike za predogled niso na voljo - obstaja možnost namestitve v nastavitvah"

msgid "FFmpeg removed successfully"
msgstr "FFmpeg je bil uspešno odstranjen"

msgid "FFmpeg successfully installed"
msgstr "FFmpeg uspešno nameščen"

msgid "First delete the mvi-files of the current bootlogo then copy the files of the new one"
msgstr "Najprej izbrišite mvi-datoteke trenutnega zagonskega logotipa, nato kopirajte datoteke novega"

msgid "Found bootlogos"
msgstr "Najdeni zagonski logotipi"

msgid "Full screen view the selected bootlogo"
msgstr "Celozaslonski ogled izbranega zagonskega logotipa"

msgid "Hide directories without 'mvi'-files"
msgstr "Skrij imenike brez 'mvi'-datotek"

msgid "Hide empty directories"
msgstr "Skrij prazne imenike"

msgid "How many seconds should status messages be displayed (1-60 sec)"
msgstr "Koliko sekund naj bodo prikazana sporočila o stanju (1–60 s)"

msgid "Include"
msgstr "Vključi"

msgid "Include or exlude logo in random choice"
msgstr "Vključite ali izključite logotip v naključno izbiro"

msgid "Included Screens"
msgstr "Vključeni zasloni"

msgid "Install/deinstall ffmpeg"
msgstr "Namestite/odstranite ffmpeg"

msgid "Installation of FFmpeg failed"
msgstr "Namestitev FFmpeg ni uspela"

msgid "No bootlogos found in directory"
msgstr "V imeniku ni bilo najdenih zagonskih logotipov"

msgid "OK"
msgstr ""

msgid "Open settings"
msgstr "Odprite nastavitve"

msgid "Preview Logo"
msgstr "Predogled logotipa"

msgid "Preview picture"
msgstr "Predogled slike"

msgid "Random mode"
msgstr "Naključni način"

msgid "Random selection at startup disabled"
msgstr "Naključna izbira ob zagonu onemogočena"

msgid "Random selection at startup enabled"
msgstr "Omogočena naključna izbira ob zagonu"

msgid "Save Changes and exit plugin"
msgstr "Shranite spremembe in zaprite vtičnik"

msgid "Search for folders with boot logos in this directory"
msgstr "V tem imeniku poiščite mape z zagonskimi logotipi"

msgid "Which bootlogos should be displayed?"
msgstr "Kateri zagonski logotipi naj bodo prikazani?"

msgid "Which logo should be displayed as a preview picture?"
msgstr "Kateri logotip naj bo prikazan kot slika za predogled?"

msgid "[BootlogoChanger] activated new bootlogo"
msgstr "[BootlogoChanger] je aktiviral nov zagonski logotip"

msgid "[BootlogoChanger] activating new bootlogo failed"
msgstr "[BootlogoChanger] aktiviranje novega zagonskega logotipa ni uspelo"

msgid "[BootlogoChanger] copy failed"
msgstr "Kopiranje [BootlogoChanger] ni uspelo"

msgid "[BootlogoChanger] deleting old bootlogo files"
msgstr "[BootlogoChanger] brisanje starih datotek bootlogo"

msgid "[BootlogoChanger] deleting previewPicture"
msgstr "[BootlogoChanger] brisanje predogleda slike"

msgid "[BootlogoChanger] ffmpeg not found"
msgstr "[BootlogoChanger] ffmpeg ni bil najden"

msgid "[BootlogoChanger] found Bootlogos"
msgstr "[BootlogoChanger] je našel Bootlogos"

msgid "[BootlogoChanger] found ffmpeg"
msgstr "[BootlogoChanger] je našel ffmpeg"

msgid "[BootlogoChanger] no bootlogos for randomization selected"
msgstr "[BootlogoChanger] izbran ni noben zagonski logotip za naključno izbiro"

msgid "[BootlogoChanger] previewPicture changed"
msgstr "[BootlogoChanger] predogledSlika spremenjena"

msgid "[BootlogoChanger] randomization of bootlogos activated"
msgstr "[BootlogoChanger] aktivirana naključna razvrstitev zagonskih logotipov"

msgid "[BootlogoChanger] randomization of bootlogos deactivated"
msgstr "[BootlogoChanger] naključna izbira zagonskih logotipov deaktivirana"

msgid "[BootlogoChanger] randomization: bootlogo found"
msgstr "[BootlogoChanger] naključna izbira: bootlogo najden"

msgid "[BootlogoChanger] selected bootlogos"
msgstr "[BootlogoChanger] izbrani zagonski logotipi"

msgid "deinstall"
msgstr "odstraniti"

msgid "found"
msgstr "našel"

msgid "install"
msgstr "namestite"

msgid "missing"
msgstr "manjka"

msgid "off"
msgstr "izklopljeno"

msgid "on"
msgstr "na"
