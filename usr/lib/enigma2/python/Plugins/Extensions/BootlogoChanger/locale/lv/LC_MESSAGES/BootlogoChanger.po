msgid "Activate the debug-output on console"
msgstr "Konsolē aktivizējiet atkļūdošanas izvadi"

msgid "Bootlogo is excluded from random selection"
msgstr "Bootlogo tiek izslēgts no nejaušās atlases"

msgid "Bootlogo is included in random selection"
msgstr "Bootlogo ir iekļauts nejaušā atlasē"

msgid "Cancel"
msgstr "Atcelt"

msgid "Choose random bootlogo at the start of the box"
msgstr "Lodziņa sākumā izvēlieties nejaušu sāknēšanas logotipu"

msgid "Copy logofiles failed"
msgstr "Logofailu kopēšana neizdevās"

msgid "Current bootlogo"
msgstr "Pašreizējais sāknēšanas logotips"

msgid "Debugmode"
msgstr "Atkļūdošanas režīms"

msgid "Deinstallation of FFmpeg failed"
msgstr "FFmpeg atinstalēšana neizdevās"

msgid "Delete current mvi-files before changing bootlogo"
msgstr "Pirms sāknēšanas logotipa maiņas izdzēsiet pašreizējos mvi failus"

msgid "Directory with bootlogo folders"
msgstr "Direktorija ar bootlogo mapēm"

msgid "Display duration of the status messages (sec)"
msgstr "Statusa ziņojumu rādīšanas ilgums (s)"

msgid "Easily switch between different bootlogos"
msgstr "Viegli pārslēdzieties starp dažādiem sāknēšanas logotipiem"

msgid "Exclude"
msgstr "Izslēgt"

msgid "Exit plugin without saving"
msgstr "Iziet no spraudņa, nesaglabājot"

msgid "FFmpeg is needed to generate thumbnails from the mvi files"
msgstr "FFmpeg ir nepieciešams, lai ģenerētu sīktēlus no mvi failiem"

msgid "FFmpeg ist missing, no preview pictures available - there is an option to install it in the stettings"
msgstr "Trūkst FFmpeg, priekšskatījuma attēli nav pieejami - ir iespēja to instalēt iestatījumos"

msgid "FFmpeg removed successfully"
msgstr "FFmpeg veiksmīgi noņemts"

msgid "FFmpeg successfully installed"
msgstr "FFmpeg veiksmīgi instalēts"

msgid "First delete the mvi-files of the current bootlogo then copy the files of the new one"
msgstr "Vispirms izdzēsiet pašreizējā sāknēšanas logotipa mvi failus, pēc tam kopējiet jaunā sāknēšanas logotipa failus"

msgid "Found bootlogos"
msgstr "Atrasti bootlogos"

msgid "Full screen view the selected bootlogo"
msgstr "Pilnekrāna skats atlasītajā sāknēšanas logotipā"

msgid "Hide directories without 'mvi'-files"
msgstr "Slēpt direktorijus bez 'mvi' failiem"

msgid "Hide empty directories"
msgstr "Slēpt tukšus direktorijus"

msgid "How many seconds should status messages be displayed (1-60 sec)"
msgstr "Cik sekundes ir jāparāda statusa ziņojumi (1–60 s)"

msgid "Include"
msgstr "Iekļaut"

msgid "Include or exlude logo in random choice"
msgstr "Iekļaut vai izslēgt logotipu nejaušā izvēlē"

msgid "Included Screens"
msgstr "Iekļautie ekrāni"

msgid "Install/deinstall ffmpeg"
msgstr "Instalējiet/atinstalējiet ffmpeg"

msgid "Installation of FFmpeg failed"
msgstr "FFmpeg instalēšana neizdevās"

msgid "No bootlogos found in directory"
msgstr "Direktorijā nav atrasts neviens sāknēšanas logotips"

msgid "OK"
msgstr "Labi"

msgid "Open settings"
msgstr "Atveriet iestatījumus"

msgid "Preview Logo"
msgstr "Priekšskatījuma logotips"

msgid "Preview picture"
msgstr "Priekšskatījuma attēls"

msgid "Random mode"
msgstr "Izlases režīms"

msgid "Random selection at startup disabled"
msgstr "Nejauša atlase startēšanas laikā ir atspējota"

msgid "Random selection at startup enabled"
msgstr "Ir iespējota nejauša izvēle startēšanas laikā"

msgid "Save Changes and exit plugin"
msgstr "Saglabājiet izmaiņas un izejiet no spraudņa"

msgid "Search for folders with boot logos in this directory"
msgstr "Šajā direktorijā meklējiet mapes ar sāknēšanas logotipiem"

msgid "Which bootlogos should be displayed?"
msgstr "Kādi sāknēšanas logotipi ir jāparāda?"

msgid "Which logo should be displayed as a preview picture?"
msgstr "Kurš logotips ir jāparāda kā priekšskatījuma attēls?"

msgid "[BootlogoChanger] activated new bootlogo"
msgstr "[BootlogoChanger] aktivizēja jaunu sāknēšanas logotipu"

msgid "[BootlogoChanger] activating new bootlogo failed"
msgstr "[BootlogoChanger] neizdevās aktivizēt jauno sāknēšanas logotipu"

msgid "[BootlogoChanger] copy failed"
msgstr "[BootlogoChanger] kopēšana neizdevās"

msgid "[BootlogoChanger] deleting old bootlogo files"
msgstr "[BootlogoChanger] dzēš vecos bootlogo failus"

msgid "[BootlogoChanger] deleting previewPicture"
msgstr "[BootlogoChanger] dzēš priekšskatījuma attēlu"

msgid "[BootlogoChanger] ffmpeg not found"
msgstr "[BootlogoChanger] ffmpeg nav atrasts"

msgid "[BootlogoChanger] found Bootlogos"
msgstr "[BootlogoChanger] atrada Bootlogos"

msgid "[BootlogoChanger] found ffmpeg"
msgstr "[BootlogoChanger] atrada ffmpeg"

msgid "[BootlogoChanger] no bootlogos for randomization selected"
msgstr "[BootlogoChanger] nejaušināšanai nav atlasīti sāknēšanas logotipi"

msgid "[BootlogoChanger] previewPicture changed"
msgstr "[BootlogoChanger] priekšskatījums Attēls mainīts"

msgid "[BootlogoChanger] randomization of bootlogos activated"
msgstr "[BootlogoChanger] ir aktivizēta sāknēšanas logotipu nejaušināšana"

msgid "[BootlogoChanger] randomization of bootlogos deactivated"
msgstr "[BootlogoChanger] sāknēšanas logotipu randomizācija ir deaktivizēta"

msgid "[BootlogoChanger] randomization: bootlogo found"
msgstr "[BootlogoChanger] randomizācija: atrasts bootlogo"

msgid "[BootlogoChanger] selected bootlogos"
msgstr "[BootlogoChanger] atlasītie sāknēšanas logotipi"

msgid "deinstall"
msgstr "atinstalēt"

msgid "found"
msgstr "atrasts"

msgid "install"
msgstr "instalēt"

msgid "missing"
msgstr "trūkst"

msgid "off"
msgstr "izslēgts"

msgid "on"
msgstr "ieslēgts"
