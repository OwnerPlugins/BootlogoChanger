msgid "Activate the debug-output on console"
msgstr "ಕನ್ಸೋಲ್‌ನಲ್ಲಿ ಡೀಬಗ್-ಔಟ್‌ಪುಟ್ ಅನ್ನು ಸಕ್ರಿಯಗೊಳಿಸಿ"

msgid "Bootlogo is excluded from random selection"
msgstr "ಯಾದೃಚ್ಛಿಕ ಆಯ್ಕೆಯಿಂದ Bootlogo ಅನ್ನು ಹೊರಗಿಡಲಾಗಿದೆ"

msgid "Bootlogo is included in random selection"
msgstr "ಯಾದೃಚ್ಛಿಕ ಆಯ್ಕೆಯಲ್ಲಿ ಬೂಟ್ಲೋಗೋವನ್ನು ಸೇರಿಸಲಾಗಿದೆ"

msgid "Cancel"
msgstr "ರದ್ದುಮಾಡು"

msgid "Choose random bootlogo at the start of the box"
msgstr "ಪೆಟ್ಟಿಗೆಯ ಪ್ರಾರಂಭದಲ್ಲಿ ಯಾದೃಚ್ಛಿಕ ಬೂಟ್ಲೋಗೋವನ್ನು ಆಯ್ಕೆಮಾಡಿ"

msgid "Copy logofiles failed"
msgstr "ಲೋಗೋಫೈಲ್‌ಗಳನ್ನು ನಕಲಿಸಲು ವಿಫಲವಾಗಿದೆ"

msgid "Current bootlogo"
msgstr "ಪ್ರಸ್ತುತ ಬೂಟ್ಲೋಗೋ"

msgid "Debugmode"
msgstr "ಡೀಬಗ್ ಮೋಡ್"

msgid "Deinstallation of FFmpeg failed"
msgstr "FFmpeg ನ ಅಸ್ಥಾಪನೆ ವಿಫಲವಾಗಿದೆ"

msgid "Delete current mvi-files before changing bootlogo"
msgstr "ಬೂಟ್‌ಲೋಗೋವನ್ನು ಬದಲಾಯಿಸುವ ಮೊದಲು ಪ್ರಸ್ತುತ mvi-ಫೈಲ್‌ಗಳನ್ನು ಅಳಿಸಿ"

msgid "Directory with bootlogo folders"
msgstr "ಬೂಟ್ಲೋಗೋ ಫೋಲ್ಡರ್ಗಳೊಂದಿಗೆ ಡೈರೆಕ್ಟರಿ"

msgid "Display duration of the status messages (sec)"
msgstr "ಸ್ಥಿತಿ ಸಂದೇಶಗಳ ಪ್ರದರ್ಶನ ಅವಧಿ (ಸೆಕೆಂಡು)"

msgid "Easily switch between different bootlogos"
msgstr "ವಿವಿಧ ಬೂಟ್ಲೋಗೊಗಳ ನಡುವೆ ಸುಲಭವಾಗಿ ಬದಲಿಸಿ"

msgid "Exclude"
msgstr "ಹೊರಗಿಡಿ"

msgid "Exit plugin without saving"
msgstr "ಉಳಿಸದೆ ಪ್ಲಗಿನ್‌ನಿಂದ ನಿರ್ಗಮಿಸಿ"

msgid "FFmpeg is needed to generate thumbnails from the mvi files"
msgstr "mvi ಫೈಲ್‌ಗಳಿಂದ ಥಂಬ್‌ನೇಲ್‌ಗಳನ್ನು ರಚಿಸಲು FFmpeg ಅಗತ್ಯವಿದೆ"

msgid "FFmpeg ist missing, no preview pictures available - there is an option to install it in the stettings"
msgstr "FFmpeg ಕಾಣೆಯಾಗಿದೆ, ಯಾವುದೇ ಪೂರ್ವವೀಕ್ಷಣೆ ಚಿತ್ರಗಳು ಲಭ್ಯವಿಲ್ಲ - ಇದನ್ನು ಸೆಟ್ಟಿಂಗ್‌ಗಳಲ್ಲಿ ಸ್ಥಾಪಿಸಲು ಒಂದು ಆಯ್ಕೆ ಇದೆ"

msgid "FFmpeg removed successfully"
msgstr "FFmpeg ಅನ್ನು ಯಶಸ್ವಿಯಾಗಿ ತೆಗೆದುಹಾಕಲಾಗಿದೆ"

msgid "FFmpeg successfully installed"
msgstr "FFmpeg ಯಶಸ್ವಿಯಾಗಿ ಸ್ಥಾಪಿಸಲಾಗಿದೆ"

msgid "First delete the mvi-files of the current bootlogo then copy the files of the new one"
msgstr "ಮೊದಲು ಪ್ರಸ್ತುತ ಬೂಟ್‌ಲೋಗೋದ mvi-ಫೈಲ್‌ಗಳನ್ನು ಅಳಿಸಿ ನಂತರ ಹೊಸ ಫೈಲ್‌ಗಳನ್ನು ನಕಲಿಸಿ"

msgid "Found bootlogos"
msgstr "ಬೂಟ್‌ಲೋಗೋಗಳು ಕಂಡುಬಂದಿವೆ"

msgid "Full screen view the selected bootlogo"
msgstr "ಆಯ್ಕೆಮಾಡಿದ ಬೂಟ್‌ಲೋಗೋವನ್ನು ಪೂರ್ಣ ಪರದೆಯಲ್ಲಿ ವೀಕ್ಷಿಸಿ"

msgid "Hide directories without 'mvi'-files"
msgstr "'mvi'-ಫೈಲ್‌ಗಳಿಲ್ಲದೆ ಡೈರೆಕ್ಟರಿಗಳನ್ನು ಮರೆಮಾಡಿ"

msgid "Hide empty directories"
msgstr "ಖಾಲಿ ಡೈರೆಕ್ಟರಿಗಳನ್ನು ಮರೆಮಾಡಿ"

msgid "How many seconds should status messages be displayed (1-60 sec)"
msgstr "ಸ್ಥಿತಿ ಸಂದೇಶಗಳನ್ನು ಎಷ್ಟು ಸೆಕೆಂಡುಗಳು ಪ್ರದರ್ಶಿಸಬೇಕು (1-60 ಸೆಕೆಂಡ್)"

msgid "Include"
msgstr "ಸೇರಿಸಿ"

msgid "Include or exlude logo in random choice"
msgstr "ಯಾದೃಚ್ಛಿಕ ಆಯ್ಕೆಯಲ್ಲಿ ಲೋಗೋವನ್ನು ಸೇರಿಸಿ ಅಥವಾ ಹೊರಗಿಡಿ"

msgid "Included Screens"
msgstr "ಒಳಗೊಂಡಿರುವ ಪರದೆಗಳು"

msgid "Install/deinstall ffmpeg"
msgstr "ffmpeg ಅನ್ನು ಸ್ಥಾಪಿಸಿ/ಅಸ್ಥಾಪಿಸಿ"

msgid "Installation of FFmpeg failed"
msgstr "FFmpeg ಸ್ಥಾಪನೆ ವಿಫಲವಾಗಿದೆ"

msgid "No bootlogos found in directory"
msgstr "ಡೈರೆಕ್ಟರಿಯಲ್ಲಿ ಯಾವುದೇ ಬೂಟ್ಲೋಗೊಗಳು ಕಂಡುಬಂದಿಲ್ಲ"

msgid "OK"
msgstr "ಸರಿ"

msgid "Open settings"
msgstr "ಸೆಟ್ಟಿಂಗ್‌ಗಳನ್ನು ತೆರೆಯಿರಿ"

msgid "Preview Logo"
msgstr "ಪೂರ್ವವೀಕ್ಷಣೆ ಲೋಗೋ"

msgid "Preview picture"
msgstr "ಪೂರ್ವವೀಕ್ಷಣೆ ಚಿತ್ರ"

msgid "Random mode"
msgstr "ಯಾದೃಚ್ಛಿಕ ಮೋಡ್"

msgid "Random selection at startup disabled"
msgstr "ಪ್ರಾರಂಭದಲ್ಲಿ ಯಾದೃಚ್ಛಿಕ ಆಯ್ಕೆಯನ್ನು ನಿಷ್ಕ್ರಿಯಗೊಳಿಸಲಾಗಿದೆ"

msgid "Random selection at startup enabled"
msgstr "ಪ್ರಾರಂಭದಲ್ಲಿ ಯಾದೃಚ್ಛಿಕ ಆಯ್ಕೆಯನ್ನು ಸಕ್ರಿಯಗೊಳಿಸಲಾಗಿದೆ"

msgid "Save Changes and exit plugin"
msgstr "ಬದಲಾವಣೆಗಳನ್ನು ಉಳಿಸಿ ಮತ್ತು ಪ್ಲಗಿನ್‌ನಿಂದ ನಿರ್ಗಮಿಸಿ"

msgid "Search for folders with boot logos in this directory"
msgstr "ಈ ಡೈರೆಕ್ಟರಿಯಲ್ಲಿ ಬೂಟ್ ಲೋಗೋಗಳೊಂದಿಗೆ ಫೋಲ್ಡರ್‌ಗಳಿಗಾಗಿ ಹುಡುಕಿ"

msgid "Which bootlogos should be displayed?"
msgstr "ಯಾವ ಬೂಟ್ಲೋಗೊಗಳನ್ನು ಪ್ರದರ್ಶಿಸಬೇಕು?"

msgid "Which logo should be displayed as a preview picture?"
msgstr "ಯಾವ ಲೋಗೋವನ್ನು ಪೂರ್ವವೀಕ್ಷಣೆ ಚಿತ್ರವಾಗಿ ಪ್ರದರ್ಶಿಸಬೇಕು?"

msgid "[BootlogoChanger] activated new bootlogo"
msgstr "[BootlogoChanger] ಹೊಸ ಬೂಟ್‌ಲೋಗೋವನ್ನು ಸಕ್ರಿಯಗೊಳಿಸಲಾಗಿದೆ"

msgid "[BootlogoChanger] activating new bootlogo failed"
msgstr "[BootlogoChanger] ಹೊಸ ಬೂಟ್‌ಲೋಗೋವನ್ನು ಸಕ್ರಿಯಗೊಳಿಸಲು ವಿಫಲವಾಗಿದೆ"

msgid "[BootlogoChanger] copy failed"
msgstr "[BootlogoChanger] ನಕಲು ವಿಫಲವಾಗಿದೆ"

msgid "[BootlogoChanger] deleting old bootlogo files"
msgstr "[BootlogoChanger] ಹಳೆಯ ಬೂಟ್‌ಲೋಗೋ ಫೈಲ್‌ಗಳನ್ನು ಅಳಿಸಲಾಗುತ್ತಿದೆ"

msgid "[BootlogoChanger] deleting previewPicture"
msgstr "[BootlogoChanger] ಪೂರ್ವವೀಕ್ಷಣೆ ಚಿತ್ರವನ್ನು ಅಳಿಸಲಾಗುತ್ತಿದೆ"

msgid "[BootlogoChanger] ffmpeg not found"
msgstr "[BootlogoChanger] ffmpeg ಕಂಡುಬಂದಿಲ್ಲ"

msgid "[BootlogoChanger] found Bootlogos"
msgstr "[BootlogoChanger] Bootlogos ಕಂಡುಬಂದಿದೆ"

msgid "[BootlogoChanger] found ffmpeg"
msgstr "[BootlogoChanger] ffmpeg ಕಂಡುಬಂದಿದೆ"

msgid "[BootlogoChanger] no bootlogos for randomization selected"
msgstr "[BootlogoChanger] ಯಾದೃಚ್ಛಿಕತೆಗಾಗಿ ಯಾವುದೇ ಬೂಟ್ಲೋಗೋಗಳನ್ನು ಆಯ್ಕೆಮಾಡಲಾಗಿಲ್ಲ"

msgid "[BootlogoChanger] previewPicture changed"
msgstr "[BootlogoChanger] ಪೂರ್ವವೀಕ್ಷಣೆ ಚಿತ್ರ ಬದಲಾಗಿದೆ"

msgid "[BootlogoChanger] randomization of bootlogos activated"
msgstr "[BootlogoChanger] ಬೂಟ್‌ಲೋಗೋಗಳ ಯಾದೃಚ್ಛಿಕೀಕರಣವನ್ನು ಸಕ್ರಿಯಗೊಳಿಸಲಾಗಿದೆ"

msgid "[BootlogoChanger] randomization of bootlogos deactivated"
msgstr "[BootlogoChanger] ಬೂಟ್‌ಲೋಗೋಗಳ ಯಾದೃಚ್ಛಿಕೀಕರಣವನ್ನು ನಿಷ್ಕ್ರಿಯಗೊಳಿಸಲಾಗಿದೆ"

msgid "[BootlogoChanger] randomization: bootlogo found"
msgstr "[BootlogoChanger] ಯಾದೃಚ್ಛಿಕತೆ: bootlogo ಕಂಡುಬಂದಿದೆ"

msgid "[BootlogoChanger] selected bootlogos"
msgstr "[BootlogoChanger] ಆಯ್ಕೆಮಾಡಿದ ಬೂಟ್‌ಲೋಗೊಗಳು"

msgid "deinstall"
msgstr "ಅಸ್ಥಾಪಿಸು"

msgid "found"
msgstr "ಕಂಡುಬಂದಿದೆ"

msgid "install"
msgstr "ಸ್ಥಾಪಿಸಿ"

msgid "missing"
msgstr "ಕಾಣೆಯಾಗಿದೆ"

msgid "off"
msgstr "ಆಫ್"

msgid "on"
msgstr "ಮೇಲೆ"
