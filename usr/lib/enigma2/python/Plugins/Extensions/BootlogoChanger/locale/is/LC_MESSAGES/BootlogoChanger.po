msgid "Activate the debug-output on console"
msgstr "Virkjaðu kembiforritið á stjórnborðinu"

msgid "Bootlogo is excluded from random selection"
msgstr "Bootlogo er útilokað frá handahófsvali"

msgid "Bootlogo is included in random selection"
msgstr "Bootlogo er innifalið í handahófsvali"

msgid "Cancel"
msgstr "Hætta við"

msgid "Choose random bootlogo at the start of the box"
msgstr "Veldu handahófskennt bootlogo í upphafi kassans"

msgid "Copy logofiles failed"
msgstr "Mistókst að afrita lógóskrár"

msgid "Current bootlogo"
msgstr "Núverandi bootlogo"

msgid "Debugmode"
msgstr "Villuleitarstilling"

msgid "Deinstallation of FFmpeg failed"
msgstr "Mistókst að fjarlægja FFmpeg"

msgid "Delete current mvi-files before changing bootlogo"
msgstr "Eyddu núverandi mvi-skrám áður en þú breytir bootlogo"

msgid "Directory with bootlogo folders"
msgstr "Skrá með bootlogo möppum"

msgid "Display duration of the status messages (sec)"
msgstr "Sýna lengd stöðuskilaboða (sek.)"

msgid "Easily switch between different bootlogos"
msgstr "Skiptu auðveldlega á milli mismunandi bootlogo"

msgid "Exclude"
msgstr "Útiloka"

msgid "Exit plugin without saving"
msgstr "Lokaðu viðbótinni án þess að vista"

msgid "FFmpeg is needed to generate thumbnails from the mvi files"
msgstr "FFmpeg er nauðsynlegt til að búa til smámyndir úr mvi skránum"

msgid "FFmpeg ist missing, no preview pictures available - there is an option to install it in the stettings"
msgstr "FFmpeg vantar, engar forskoðunarmyndir í boði - það er möguleiki að setja það upp í stillingunum"

msgid "FFmpeg removed successfully"
msgstr "FFmpeg tókst að fjarlægja"

msgid "FFmpeg successfully installed"
msgstr "FFmpeg sett upp"

msgid "First delete the mvi-files of the current bootlogo then copy the files of the new one"
msgstr "Eyddu fyrst mvi-skrám núverandi ræsimerkisins og afritaðu síðan skrárnar af því nýja"

msgid "Found bootlogos"
msgstr "Fann bootlogo"

msgid "Full screen view the selected bootlogo"
msgstr "Skoðaðu valið ræsimerki á öllum skjánum"

msgid "Hide directories without 'mvi'-files"
msgstr "Fela möppur án 'mvi'-skráa"

msgid "Hide empty directories"
msgstr "Fela tómar möppur"

msgid "How many seconds should status messages be displayed (1-60 sec)"
msgstr "Hversu margar sekúndur ættu stöðuskilaboð að birtast (1-60 sekúndur)"

msgid "Include"
msgstr "Taka með"

msgid "Include or exlude logo in random choice"
msgstr "Hafa með eða útiloka lógó í handahófsvali"

msgid "Included Screens"
msgstr "Skjár fylgja með"

msgid "Install/deinstall ffmpeg"
msgstr "Settu upp/fjarlægðu ffmpeg"

msgid "Installation of FFmpeg failed"
msgstr "Uppsetning á FFmpeg mistókst"

msgid "No bootlogos found in directory"
msgstr "Engin ræsimerki fundust í möppunni"

msgid "OK"
msgstr "Allt í lagi"

msgid "Open settings"
msgstr "Opnaðu stillingar"

msgid "Preview Logo"
msgstr "Forskoðunarmerki"

msgid "Preview picture"
msgstr "Forskoða mynd"

msgid "Random mode"
msgstr "Tilviljunarkennd stilling"

msgid "Random selection at startup disabled"
msgstr "Slembival við ræsingu óvirkt"

msgid "Random selection at startup enabled"
msgstr "Slembival við ræsingu virkt"

msgid "Save Changes and exit plugin"
msgstr "Vista breytingar og lokaðu viðbótinni"

msgid "Search for folders with boot logos in this directory"
msgstr "Leitaðu að möppum með ræsimerkjum í þessari möppu"

msgid "Which bootlogos should be displayed?"
msgstr "Hvaða bootlogo ætti að birta?"

msgid "Which logo should be displayed as a preview picture?"
msgstr "Hvaða lógó ætti að birta sem forskoðunarmynd?"

msgid "[BootlogoChanger] activated new bootlogo"
msgstr "[BootlogoChanger] virkjaði nýtt ræsimerki"

msgid "[BootlogoChanger] activating new bootlogo failed"
msgstr "[BootlogoChanger] mistókst að virkja nýtt ræsimerki"

msgid "[BootlogoChanger] copy failed"
msgstr "[BootlogoChanger] afritun mistókst"

msgid "[BootlogoChanger] deleting old bootlogo files"
msgstr "[BootlogoChanger] eyðir gömlum ræsimerkjaskrám"

msgid "[BootlogoChanger] deleting previewPicture"
msgstr "[BootlogoChanger] eyðir forskoðunarmynd"

msgid "[BootlogoChanger] ffmpeg not found"
msgstr "[BootlogoChanger] ffmpeg fannst ekki"

msgid "[BootlogoChanger] found Bootlogos"
msgstr "[BootlogoChanger] fann Bootlogos"

msgid "[BootlogoChanger] found ffmpeg"
msgstr "[BootlogoChanger] fannst ffmpeg"

msgid "[BootlogoChanger] no bootlogos for randomization selected"
msgstr "[BootlogoChanger] engin ræsimerki fyrir slembival valin"

msgid "[BootlogoChanger] previewPicture changed"
msgstr "[BootlogoChanger] forskoðun Mynd breytt"

msgid "[BootlogoChanger] randomization of bootlogos activated"
msgstr "[BootlogoChanger] slembival ræsimerkja virkjuð"

msgid "[BootlogoChanger] randomization of bootlogos deactivated"
msgstr "[BootlogoChanger] slembival ræsimerkja óvirk"

msgid "[BootlogoChanger] randomization: bootlogo found"
msgstr "[BootlogoChanger] slembival: bootlogo fannst"

msgid "[BootlogoChanger] selected bootlogos"
msgstr "[BootlogoChanger] valin bootlogo"

msgid "deinstall"
msgstr "fjarlægja"

msgid "found"
msgstr "fannst"

msgid "install"
msgstr "setja upp"

msgid "missing"
msgstr "vantar"

msgid "off"
msgstr "af"

msgid "on"
msgstr "á"
