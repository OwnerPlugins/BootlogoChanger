msgid "Activate the debug-output on console"
msgstr "Aktivizoni daljen e korrigjimit në tastierë"

msgid "Bootlogo is excluded from random selection"
msgstr "Bootlogo është i përjashtuar nga përzgjedhja e rastësishme"

msgid "Bootlogo is included in random selection"
msgstr "Bootlogo përfshihet në përzgjedhjen e rastësishme"

msgid "Cancel"
msgstr "Anulo"

msgid "Choose random bootlogo at the start of the box"
msgstr "Zgjidhni bootlogon e rastësishme në fillim të kutisë"

msgid "Copy logofiles failed"
msgstr "Kopjimi i skedarëve logo dështoi"

msgid "Current bootlogo"
msgstr "Bootlogu aktual"

msgid "Debugmode"
msgstr "Modaliteti i korrigjimit"

msgid "Deinstallation of FFmpeg failed"
msgstr "Deinstalimi i FFmpeg dështoi"

msgid "Delete current mvi-files before changing bootlogo"
msgstr "Fshini skedarët aktual mvi përpara se të ndryshoni bootlogo"

msgid "Directory with bootlogo folders"
msgstr "Drejtori me dosje bootlogo"

msgid "Display duration of the status messages (sec)"
msgstr "Shfaq kohëzgjatjen e mesazheve të statusit (sek.)"

msgid "Easily switch between different bootlogos"
msgstr "Kaloni lehtësisht midis bootlogëve të ndryshëm"

msgid "Exclude"
msgstr "Përjashtoni"

msgid "Exit plugin without saving"
msgstr "Dilni nga shtojca pa e ruajtur"

msgid "FFmpeg is needed to generate thumbnails from the mvi files"
msgstr "FFmpeg nevojitet për të gjeneruar miniaturë nga skedarët mvi"

msgid "FFmpeg ist missing, no preview pictures available - there is an option to install it in the stettings"
msgstr "FFmpeg mungon, nuk ka fotografi paraprake të disponueshme - ekziston një opsion për ta instaluar atë në parametrat"

msgid "FFmpeg removed successfully"
msgstr "FFmpeg u hoq me sukses"

msgid "FFmpeg successfully installed"
msgstr "FFmpeg u instalua me sukses"

msgid "First delete the mvi-files of the current bootlogo then copy the files of the new one"
msgstr "Fillimisht fshini skedarët mvi të bootlogo-së aktuale dhe më pas kopjoni skedarët e të riut"

msgid "Found bootlogos"
msgstr "U gjetën bootlogët"

msgid "Full screen view the selected bootlogo"
msgstr "Shikoni në ekran të plotë bootlogun e zgjedhur"

msgid "Hide directories without 'mvi'-files"
msgstr "Fshih drejtoritë pa skedarë 'mvi'"

msgid "Hide empty directories"
msgstr "Fshih drejtoritë boshe"

msgid "How many seconds should status messages be displayed (1-60 sec)"
msgstr "Sa sekonda duhet të shfaqen mesazhet e statusit (1-60 sek)"

msgid "Include"
msgstr "Përfshijnë"

msgid "Include or exlude logo in random choice"
msgstr "Përfshini ose përjashtoni logon në zgjedhje të rastësishme"

msgid "Included Screens"
msgstr "Ekranet e përfshirë"

msgid "Install/deinstall ffmpeg"
msgstr "Instaloni/çinstaloni ffmpeg"

msgid "Installation of FFmpeg failed"
msgstr "Instalimi i FFmpeg dështoi"

msgid "No bootlogos found in directory"
msgstr "Nuk u gjet asnjë bootlogo në drejtori"

msgid "OK"
msgstr ""

msgid "Open settings"
msgstr "Hap cilësimet"

msgid "Preview Logo"
msgstr "Preview logo"

msgid "Preview picture"
msgstr "Shiko paraprakisht foton"

msgid "Random mode"
msgstr "Mënyra e rastësishme"

msgid "Random selection at startup disabled"
msgstr "Zgjedhja e rastësishme në nisje është çaktivizuar"

msgid "Random selection at startup enabled"
msgstr "Zgjedhja e rastësishme në nisje është aktivizuar"

msgid "Save Changes and exit plugin"
msgstr "Ruani Ndryshimet dhe dilni nga shtojca"

msgid "Search for folders with boot logos in this directory"
msgstr "Kërkoni dosje me logot e nisjes në këtë direktori"

msgid "Which bootlogos should be displayed?"
msgstr "Cilat bootlogo duhet të shfaqen?"

msgid "Which logo should be displayed as a preview picture?"
msgstr "Cila logo duhet të shfaqet si një pamje paraprake?"

msgid "[BootlogoChanger] activated new bootlogo"
msgstr "[BootlogoChanger] aktivizoi një bootlog të ri"

msgid "[BootlogoChanger] activating new bootlogo failed"
msgstr "Aktivizimi i [BootlogoChanger] dështoi"

msgid "[BootlogoChanger] copy failed"
msgstr "Kopjimi i [BootlogoChanger] dështoi"

msgid "[BootlogoChanger] deleting old bootlogo files"
msgstr "[BootlogoChanger] duke fshirë skedarët e vjetër bootlogo"

msgid "[BootlogoChanger] deleting previewPicture"
msgstr "[BootlogoChanger] po fshin pamjen paraprake të figurës"

msgid "[BootlogoChanger] ffmpeg not found"
msgstr "[BootlogoChanger] ffmpeg nuk u gjet"

msgid "[BootlogoChanger] found Bootlogos"
msgstr "[BootlogoChanger] gjeti Bootlogos"

msgid "[BootlogoChanger] found ffmpeg"
msgstr "[BootlogoChanger] u gjet ffmpeg"

msgid "[BootlogoChanger] no bootlogos for randomization selected"
msgstr "[BootlogoChanger] nuk janë zgjedhur bootloge për randomizim"

msgid "[BootlogoChanger] previewPicture changed"
msgstr "Parapamje [BootlogoChanger] Figura ndryshoi"

msgid "[BootlogoChanger] randomization of bootlogos activated"
msgstr "[BootlogoChanger] aktivizimi i rastësishëm i bootlogos"

msgid "[BootlogoChanger] randomization of bootlogos deactivated"
msgstr "[BootlogoChanger] çaktivizimi i rastësishëm i bootlogos"

msgid "[BootlogoChanger] randomization: bootlogo found"
msgstr "[BootlogoChanger] randomization: bootlogo u gjet"

msgid "[BootlogoChanger] selected bootlogos"
msgstr "[BootlogoChanger] bootlogot e zgjedhura"

msgid "deinstall"
msgstr "çinstaloni"

msgid "found"
msgstr "gjetur"

msgid "install"
msgstr "instaloni"

msgid "missing"
msgstr "i zhdukur"

msgid "off"
msgstr "fikur"

msgid "on"
msgstr "në"
