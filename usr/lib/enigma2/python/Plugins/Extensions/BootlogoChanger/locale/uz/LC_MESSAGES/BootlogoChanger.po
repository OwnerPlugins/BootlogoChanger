msgid "Activate the debug-output on console"
msgstr "Konsolda disk raskadrovka chiqishni faollashtiring"

msgid "Bootlogo is excluded from random selection"
msgstr "Bootlogo tasodifiy tanlovdan chiqarib tashlangan"

msgid "Bootlogo is included in random selection"
msgstr "Bootlogo tasodifiy tanlovga kiritilgan"

msgid "Cancel"
msgstr "Bekor qilish"

msgid "Choose random bootlogo at the start of the box"
msgstr "Qutining boshida tasodifiy yuklash logotipini tanlang"

msgid "Copy logofiles failed"
msgstr "Logofayllardan nusxa ko‘chirilmadi"

msgid "Current bootlogo"
msgstr "Joriy yuklash logotipi"

msgid "Debugmode"
msgstr "Nosozliklarni tuzatish rejimi"

msgid "Deinstallation of FFmpeg failed"
msgstr "FFmpegni oʻchirib tashlab boʻlmadi"

msgid "Delete current mvi-files before changing bootlogo"
msgstr "Bootlogo-ni o'zgartirishdan oldin joriy mvi-fayllarni o'chiring"

msgid "Directory with bootlogo folders"
msgstr "Bootlogo papkalari bilan katalog"

msgid "Display duration of the status messages (sec)"
msgstr "Holat xabarlarini ko'rsatish davomiyligi (sek.)"

msgid "Easily switch between different bootlogos"
msgstr "Turli yuklash logotiplari o'rtasida osongina almashing"

msgid "Exclude"
msgstr "Cheklash"

msgid "Exit plugin without saving"
msgstr "Plaginni saqlamasdan chiqing"

msgid "FFmpeg is needed to generate thumbnails from the mvi files"
msgstr "FFmpeg mvi fayllaridan eskizlarni yaratish uchun kerak"

msgid "FFmpeg ist missing, no preview pictures available - there is an option to install it in the stettings"
msgstr "FFmpeg yo'q, oldindan ko'rish rasmlari mavjud emas - uni sozlamalarda o'rnatish imkoniyati mavjud"

msgid "FFmpeg removed successfully"
msgstr "FFmpeg muvaffaqiyatli olib tashlandi"

msgid "FFmpeg successfully installed"
msgstr "FFmpeg muvaffaqiyatli o'rnatildi"

msgid "First delete the mvi-files of the current bootlogo then copy the files of the new one"
msgstr "Avval joriy yuklash logotipining mvi-fayllarini o'chiring, keyin yangisining fayllarini nusxalang"

msgid "Found bootlogos"
msgstr "Bootloglar topildi"

msgid "Full screen view the selected bootlogo"
msgstr "Tanlangan yuklash logotipini toʻliq ekranda koʻrish"

msgid "Hide directories without 'mvi'-files"
msgstr "'mvi'-fayllarsiz kataloglarni yashirish"

msgid "Hide empty directories"
msgstr "Bo'sh kataloglarni yashirish"

msgid "How many seconds should status messages be displayed (1-60 sec)"
msgstr "Holat xabarlari necha soniya davomida ko'rsatilishi kerak (1-60 sek)"

msgid "Include"
msgstr "O'z ichiga oladi"

msgid "Include or exlude logo in random choice"
msgstr "Tasodifiy tanlovga logotip qo'shing yoki chiqarib tashlang"

msgid "Included Screens"
msgstr "Kiritilgan ekranlar"

msgid "Install/deinstall ffmpeg"
msgstr "Ffmpeg-ni o'rnatish/o'chirish"

msgid "Installation of FFmpeg failed"
msgstr "FFmpeg o'rnatilmadi"

msgid "No bootlogos found in directory"
msgstr "Katalogda hech qanday yuklash logotipi topilmadi"

msgid "OK"
msgstr "KELISHDIKMI"

msgid "Open settings"
msgstr "Sozlamalarni oching"

msgid "Preview Logo"
msgstr "Logotipni oldindan ko'rish"

msgid "Preview picture"
msgstr "Rasmni oldindan ko'rish"

msgid "Random mode"
msgstr "Tasodifiy rejim"

msgid "Random selection at startup disabled"
msgstr "Ishga tushirishda tasodifiy tanlash o'chirilgan"

msgid "Random selection at startup enabled"
msgstr "Ishga tushirishda tasodifiy tanlash yoqilgan"

msgid "Save Changes and exit plugin"
msgstr "O'zgarishlarni saqlang va plagindan chiqing"

msgid "Search for folders with boot logos in this directory"
msgstr "Ushbu katalogda yuklash logotiplari bo'lgan papkalarni qidiring"

msgid "Which bootlogos should be displayed?"
msgstr "Qaysi yuklash logotiplari ko'rsatilishi kerak?"

msgid "Which logo should be displayed as a preview picture?"
msgstr "Oldindan ko'rish rasmi sifatida qaysi logotip ko'rsatilishi kerak?"

msgid "[BootlogoChanger] activated new bootlogo"
msgstr "[BootlogoChanger] yangi yuklash logotipini faollashtirdi"

msgid "[BootlogoChanger] activating new bootlogo failed"
msgstr "[BootlogoChanger] yangi yuklash logotipini faollashtirib boʻlmadi"

msgid "[BootlogoChanger] copy failed"
msgstr "[BootlogoChanger] nusxasi amalga oshmadi"

msgid "[BootlogoChanger] deleting old bootlogo files"
msgstr "[BootlogoChanger] eski bootlogo fayllarini o'chirish"

msgid "[BootlogoChanger] deleting previewPicture"
msgstr "[BootlogoChanger] previewPicture oʻchirilmoqda"

msgid "[BootlogoChanger] ffmpeg not found"
msgstr "[BootlogoChanger] ffmpeg topilmadi"

msgid "[BootlogoChanger] found Bootlogos"
msgstr "[BootlogoChanger] Bootlogos-ni topdi"

msgid "[BootlogoChanger] found ffmpeg"
msgstr "[BootlogoChanger] ffmpeg topdi"

msgid "[BootlogoChanger] no bootlogos for randomization selected"
msgstr "[BootlogoChanger] randomizatsiya uchun hech qanday yuklash logotipi tanlanmagan"

msgid "[BootlogoChanger] previewPicture changed"
msgstr "[BootlogoChanger] oldindan koʻrish Rasm oʻzgartirildi"

msgid "[BootlogoChanger] randomization of bootlogos activated"
msgstr "[BootlogoChanger] yuklash logotiplarini tasodifiylashtirish faollashtirilgan"

msgid "[BootlogoChanger] randomization of bootlogos deactivated"
msgstr "[BootlogoChanger] yuklash logotiplarini tasodifiylashtirish o'chirilgan"

msgid "[BootlogoChanger] randomization: bootlogo found"
msgstr "[BootlogoChanger] randomizatsiyasi: bootlogo topildi"

msgid "[BootlogoChanger] selected bootlogos"
msgstr "[BootlogoChanger] yuklash logotiplarini tanladi"

msgid "deinstall"
msgstr "o'chirish"

msgid "found"
msgstr "topildi"

msgid "install"
msgstr "o'rnatish"

msgid "missing"
msgstr "yo'qolgan"

msgid "off"
msgstr "o'chirilgan"

msgid "on"
msgstr "yoqilgan"
