msgid "Activate the debug-output on console"
msgstr "Актывуйце выснову адладкі на кансолі"

msgid "Bootlogo is excluded from random selection"
msgstr "Bootlogo выключаны з выпадковага выбару"

msgid "Bootlogo is included in random selection"
msgstr "Bootlogo уключаны ў выпадковы выбар"

msgid "Cancel"
msgstr "Адмяніць"

msgid "Choose random bootlogo at the start of the box"
msgstr "Выберыце выпадковы лагатып загрузкі ў пачатку скрынкі"

msgid "Copy logofiles failed"
msgstr "Не атрымалася скапіраваць файлы лагатыпаў"

msgid "Current bootlogo"
msgstr "Актуальны лагатып загрузкі"

msgid "Debugmode"
msgstr "Рэжым адладкі"

msgid "Deinstallation of FFmpeg failed"
msgstr "Не атрымалася выдаліць FFmpeg"

msgid "Delete current mvi-files before changing bootlogo"
msgstr "Выдаліце ​​бягучыя mvi-файлы, перш чым змяняць лагатып загрузкі"

msgid "Directory with bootlogo folders"
msgstr "Каталог з тэчкамі bootlogo"

msgid "Display duration of the status messages (sec)"
msgstr "Працягласць адлюстравання паведамленняў аб стане (сек)"

msgid "Easily switch between different bootlogos"
msgstr "Лёгка пераключайцеся паміж рознымі загрузнымі лагатыпамі"

msgid "Exclude"
msgstr "Выключыць"

msgid "Exit plugin without saving"
msgstr "Выйсці з плагіна без захавання"

msgid "FFmpeg is needed to generate thumbnails from the mvi files"
msgstr "FFmpeg неабходны для стварэння мініяцюр з файлаў mvi"

msgid "FFmpeg ist missing, no preview pictures available - there is an option to install it in the stettings"
msgstr "FFmpeg адсутнічае, выявы папярэдняга прагляду адсутнічаюць - ёсць магчымасць усталяваць яго ў наладах"

msgid "FFmpeg removed successfully"
msgstr "FFmpeg паспяхова выдалены"

msgid "FFmpeg successfully installed"
msgstr "FFmpeg паспяхова ўсталяваны"

msgid "First delete the mvi-files of the current bootlogo then copy the files of the new one"
msgstr "Спачатку выдаліце ​​mvi-файлы бягучага загрузнага лагатыпа, затым скапіруйце файлы новага"

msgid "Found bootlogos"
msgstr "Знойдзены загрузныя лагатыпы"

msgid "Full screen view the selected bootlogo"
msgstr "Поўнаэкранны прагляд выбранага загрузнага лагатыпа"

msgid "Hide directories without 'mvi'-files"
msgstr "Схаваць каталогі без 'mvi'-файлаў"

msgid "Hide empty directories"
msgstr "Схаваць пустыя каталогі"

msgid "How many seconds should status messages be displayed (1-60 sec)"
msgstr "Колькі секунд павінны адлюстроўвацца паведамленні аб стане (1-60 секунд)"

msgid "Include"
msgstr "Уключыць"

msgid "Include or exlude logo in random choice"
msgstr "Уключыць або выключыць лагатып у выпадковым выбары"

msgid "Included Screens"
msgstr "Уключаныя экраны"

msgid "Install/deinstall ffmpeg"
msgstr "Усталяваць/выдаліць ffmpeg"

msgid "Installation of FFmpeg failed"
msgstr "Збой усталявання FFmpeg"

msgid "No bootlogos found in directory"
msgstr "У каталогу не знойдзены лагатыпы загрузкі"

msgid "OK"
msgstr "добра"

msgid "Open settings"
msgstr "Адкрыйце налады"

msgid "Preview Logo"
msgstr "Папярэдні прагляд лагатыпа"

msgid "Preview picture"
msgstr "Папярэдні прагляд малюнка"

msgid "Random mode"
msgstr "Выпадковы рэжым"

msgid "Random selection at startup disabled"
msgstr "Выпадковы выбар пры запуску адключаны"

msgid "Random selection at startup enabled"
msgstr "Выпадковы выбар пры запуску ўключаны"

msgid "Save Changes and exit plugin"
msgstr "Захаваць змены і выйсці з плагіна"

msgid "Search for folders with boot logos in this directory"
msgstr "Шукайце папкі з лагатыпамі загрузкі ў гэтым каталогу"

msgid "Which bootlogos should be displayed?"
msgstr "Якія загрузныя лагатыпы павінны адлюстроўвацца?"

msgid "Which logo should be displayed as a preview picture?"
msgstr "Які лагатып павінен быць паказаны ў якасці выявы папярэдняга прагляду?"

msgid "[BootlogoChanger] activated new bootlogo"
msgstr "[BootlogoChanger] актываваў новы лагатып загрузкі"

msgid "[BootlogoChanger] activating new bootlogo failed"
msgstr "[BootlogoChanger] не ўдалося актываваць новы лагатып загрузкі"

msgid "[BootlogoChanger] copy failed"
msgstr "Памылка капіравання [BootlogoChanger]."

msgid "[BootlogoChanger] deleting old bootlogo files"
msgstr "[BootlogoChanger] выдаленне старых файлаў bootlogo"

msgid "[BootlogoChanger] deleting previewPicture"
msgstr "[BootlogoChanger] выдаленне PreviewPicture"

msgid "[BootlogoChanger] ffmpeg not found"
msgstr "[BootlogoChanger] ffmpeg не знойдзены"

msgid "[BootlogoChanger] found Bootlogos"
msgstr "[BootlogoChanger] знайшоў Bootlogos"

msgid "[BootlogoChanger] found ffmpeg"
msgstr "[BootlogoChanger] знайшоў ffmpeg"

msgid "[BootlogoChanger] no bootlogos for randomization selected"
msgstr "[BootlogoChanger] не выбраны лагатыпы загрузкі для рандомізацыі"

msgid "[BootlogoChanger] previewPicture changed"
msgstr "[BootlogoChanger] папярэдні праглядВыява зменена"

msgid "[BootlogoChanger] randomization of bootlogos activated"
msgstr "[BootlogoChanger] уключана рандомізацыя лагатыпаў загрузкі"

msgid "[BootlogoChanger] randomization of bootlogos deactivated"
msgstr "[BootlogoChanger] рандомізацыя загрузных лагатыпаў адключана"

msgid "[BootlogoChanger] randomization: bootlogo found"
msgstr "[BootlogoChanger] рандомізацыя: bootlogo знойдзены"

msgid "[BootlogoChanger] selected bootlogos"
msgstr "[BootlogoChanger] выбраныя лагатыпы загрузкі"

msgid "deinstall"
msgstr "выдаліць"

msgid "found"
msgstr "знойдзены"

msgid "install"
msgstr "ўсталяваць"

msgid "missing"
msgstr "адсутнічае"

msgid "off"
msgstr "выключаны"

msgid "on"
msgstr "на"
