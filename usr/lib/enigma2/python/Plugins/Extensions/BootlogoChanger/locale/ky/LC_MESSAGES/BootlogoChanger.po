msgid "Activate the debug-output on console"
msgstr "Консолдогу мүчүлүштүктөрдү чыгарууну активдештирүү"

msgid "Bootlogo is excluded from random selection"
msgstr "Bootlogo кокус тандоодон чыгарылган"

msgid "Bootlogo is included in random selection"
msgstr "Bootlogo кокус тандоого кирет"

msgid "Cancel"
msgstr "Жокко чыгаруу"

msgid "Choose random bootlogo at the start of the box"
msgstr "кутучанын башында туш келди жүктөө логотип тандоо"

msgid "Copy logofiles failed"
msgstr "Логофилдерди көчүрүү ишке ашкан жок"

msgid "Current bootlogo"
msgstr "Учурдагы жүктөө логотиби"

msgid "Debugmode"
msgstr "Мүчүлүштүктөрдү оңдоо режими"

msgid "Deinstallation of FFmpeg failed"
msgstr "FFmpeg орнотулбай калды"

msgid "Delete current mvi-files before changing bootlogo"
msgstr "Жүктөөлөөнү өзгөртүүдөн мурун учурдагы mvi-файлдарды жок кылыңыз"

msgid "Directory with bootlogo folders"
msgstr "Bootlogo папкалары бар каталог"

msgid "Display duration of the status messages (sec)"
msgstr "Статус билдирүүлөрүнүн узактыгын көрсөтүү (сек.)"

msgid "Easily switch between different bootlogos"
msgstr "Ар кандай жүктөө логотиптеринин ортосунда оңой которулуңуз"

msgid "Exclude"
msgstr "Чыгаруу"

msgid "Exit plugin without saving"
msgstr "Плагинди сактабастан чыгыңыз"

msgid "FFmpeg is needed to generate thumbnails from the mvi files"
msgstr "FFmpeg mvi файлдарынан эскиздерди түзүү үчүн керек"

msgid "FFmpeg ist missing, no preview pictures available - there is an option to install it in the stettings"
msgstr "FFmpeg жок, алдын ала көрүү сүрөттөрү жок - аны stettingsке орнотуу мүмкүнчүлүгү бар"

msgid "FFmpeg removed successfully"
msgstr "FFmpeg ийгиликтүү өчүрүлдү"

msgid "FFmpeg successfully installed"
msgstr "FFmpeg ийгиликтүү орнотулду"

msgid "First delete the mvi-files of the current bootlogo then copy the files of the new one"
msgstr "Алгач учурдагы жүктөөчүнүн mvi-файлдарын жок кылыңыз, андан кийин жаңысынын файлдарын көчүрүңүз"

msgid "Found bootlogos"
msgstr "Bootlogos табылган"

msgid "Full screen view the selected bootlogo"
msgstr "Тандалган жүктөө логотибин толук экрандан көрүү"

msgid "Hide directories without 'mvi'-files"
msgstr "'mvi'-файлдары жок каталогдорду жашыруу"

msgid "Hide empty directories"
msgstr "Бош каталогдорду жашыруу"

msgid "How many seconds should status messages be displayed (1-60 sec)"
msgstr "Статус билдирүүлөрү канча секундда көрсөтүлүшү керек (1-60 сек)"

msgid "Include"
msgstr "камтыйт"

msgid "Include or exlude logo in random choice"
msgstr "Кокусунан тандоодо логотипти кошуңуз же чыгарып салыңыз"

msgid "Included Screens"
msgstr "Камтылган экрандар"

msgid "Install/deinstall ffmpeg"
msgstr "ffmpeg орнотуу/жокко чыгаруу"

msgid "Installation of FFmpeg failed"
msgstr "FFmpeg орнотуу ишке ашкан жок"

msgid "No bootlogos found in directory"
msgstr "Каталогдо bootlogos табылган жок"

msgid "OK"
msgstr "макул"

msgid "Open settings"
msgstr "Жөндөөлөрдү ачыңыз"

msgid "Preview Logo"
msgstr "Логотипти алдын ала көрүү"

msgid "Preview picture"
msgstr "Сүрөттү алдын ала көрүү"

msgid "Random mode"
msgstr "Кокус режим"

msgid "Random selection at startup disabled"
msgstr "Ишке киргизүүдө туш келди тандоо өчүрүлгөн"

msgid "Random selection at startup enabled"
msgstr "Ишке киргизүүдө туш келди тандоо иштетилди"

msgid "Save Changes and exit plugin"
msgstr "Өзгөртүүлөрдү сактоо жана плагинден чыгуу"

msgid "Search for folders with boot logos in this directory"
msgstr "Бул каталогдон жүктөө логотиптери бар папкаларды издеңиз"

msgid "Which bootlogos should be displayed?"
msgstr "Кайсы жүктөөлөр көрсөтүлүшү керек?"

msgid "Which logo should be displayed as a preview picture?"
msgstr "Кайсы логотип алдын ала көрүү сүрөтү катары көрсөтүлүшү керек?"

msgid "[BootlogoChanger] activated new bootlogo"
msgstr "[BootlogoChanger] жаңы жүктөө логотибин иштетти"

msgid "[BootlogoChanger] activating new bootlogo failed"
msgstr "[BootlogoChanger] жаңы жүктөөчү логотип иштетилбей калды"

msgid "[BootlogoChanger] copy failed"
msgstr "[BootlogoChanger] көчүрмөсү ишке ашкан жок"

msgid "[BootlogoChanger] deleting old bootlogo files"
msgstr "[BootlogoChanger] эски bootlogo файлдарын жок кылуу"

msgid "[BootlogoChanger] deleting previewPicture"
msgstr "[BootlogoChanger] PreviewPicture жок кылынууда"

msgid "[BootlogoChanger] ffmpeg not found"
msgstr "[BootlogoChanger] ffmpeg табылган жок"

msgid "[BootlogoChanger] found Bootlogos"
msgstr "[BootlogoChanger] Bootlogos тапты"

msgid "[BootlogoChanger] found ffmpeg"
msgstr "[BootlogoChanger] ffmpeg тапты"

msgid "[BootlogoChanger] no bootlogos for randomization selected"
msgstr "[BootlogoChanger] рандомизация үчүн эч кандай жүктөөчү логотип тандалган жок"

msgid "[BootlogoChanger] previewPicture changed"
msgstr "[BootlogoChanger] алдын ала көрүүСүрөт өзгөрдү"

msgid "[BootlogoChanger] randomization of bootlogos activated"
msgstr "[BootlogoChanger] жүктөөлөрүнүн рандомизациясы иштетилди"

msgid "[BootlogoChanger] randomization of bootlogos deactivated"
msgstr "[BootlogoChanger] жүктөөлөрүнүн рандомизациясы өчүрүлгөн"

msgid "[BootlogoChanger] randomization: bootlogo found"
msgstr "[BootlogoChanger] рандомизациясы: bootlogo табылды"

msgid "[BootlogoChanger] selected bootlogos"
msgstr "[BootlogoChanger] тандалган жүктөөчү логотип"

msgid "deinstall"
msgstr "өчүрүү"

msgid "found"
msgstr "табылган"

msgid "install"
msgstr "орнотуу"

msgid "missing"
msgstr "жок"

msgid "off"
msgstr "өчүрүү"

msgid "on"
msgstr "күйүк"
