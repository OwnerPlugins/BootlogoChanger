msgid "Activate the debug-output on console"
msgstr "കൺസോളിൽ ഡീബഗ് ഔട്ട്പുട്ട് സജീവമാക്കുക"

msgid "Bootlogo is excluded from random selection"
msgstr "ക്രമരഹിതമായ തിരഞ്ഞെടുപ്പിൽ നിന്ന് Bootlogo ഒഴിവാക്കിയിരിക്കുന്നു"

msgid "Bootlogo is included in random selection"
msgstr "ക്രമരഹിതമായ തിരഞ്ഞെടുപ്പിൽ ബൂട്ട്ലോഗോ ഉൾപ്പെടുത്തിയിട്ടുണ്ട്"

msgid "Cancel"
msgstr "റദ്ദാക്കുക"

msgid "Choose random bootlogo at the start of the box"
msgstr "ബോക്സിൻ്റെ തുടക്കത്തിൽ റാൻഡം ബൂട്ട്ലോഗോ തിരഞ്ഞെടുക്കുക"

msgid "Copy logofiles failed"
msgstr "ലോഗോഫയലുകൾ പകർത്താനായില്ല"

msgid "Current bootlogo"
msgstr "നിലവിലെ ബൂട്ട്ലോഗോ"

msgid "Debugmode"
msgstr "ഡീബഗ് മോഡ്"

msgid "Deinstallation of FFmpeg failed"
msgstr "FFmpeg-ൻ്റെ ഡീഇൻസ്റ്റാളേഷൻ പരാജയപ്പെട്ടു"

msgid "Delete current mvi-files before changing bootlogo"
msgstr "ബൂട്ട്ലോഗോ മാറ്റുന്നതിന് മുമ്പ് നിലവിലുള്ള mvi-ഫയലുകൾ ഇല്ലാതാക്കുക"

msgid "Directory with bootlogo folders"
msgstr "ബൂട്ട്ലോഗോ ഫോൾഡറുകളുള്ള ഡയറക്ടറി"

msgid "Display duration of the status messages (sec)"
msgstr "സ്റ്റാറ്റസ് സന്ദേശങ്ങളുടെ പ്രദർശന ദൈർഘ്യം (സെക്കൻഡ്)"

msgid "Easily switch between different bootlogos"
msgstr "വ്യത്യസ്ത ബൂട്ട്ലോഗുകൾക്കിടയിൽ എളുപ്പത്തിൽ മാറുക"

msgid "Exclude"
msgstr "ഒഴിവാക്കുക"

msgid "Exit plugin without saving"
msgstr "പ്ലഗിൻ സംരക്ഷിക്കാതെ പുറത്തുകടക്കുക"

msgid "FFmpeg is needed to generate thumbnails from the mvi files"
msgstr "mvi ഫയലുകളിൽ നിന്ന് ലഘുചിത്രങ്ങൾ സൃഷ്ടിക്കാൻ FFmpeg ആവശ്യമാണ്"

msgid "FFmpeg ist missing, no preview pictures available - there is an option to install it in the stettings"
msgstr "FFmpeg നഷ്‌ടമായി, പ്രിവ്യൂ ചിത്രങ്ങളൊന്നും ലഭ്യമല്ല - ക്രമീകരണങ്ങളിൽ ഇത് ഇൻസ്റ്റാൾ ചെയ്യാനുള്ള ഒരു ഓപ്ഷൻ ഉണ്ട്"

msgid "FFmpeg removed successfully"
msgstr "FFmpeg വിജയകരമായി നീക്കം ചെയ്തു"

msgid "FFmpeg successfully installed"
msgstr "FFmpeg വിജയകരമായി ഇൻസ്റ്റാൾ ചെയ്തു"

msgid "First delete the mvi-files of the current bootlogo then copy the files of the new one"
msgstr "ആദ്യം നിലവിലുള്ള ബൂട്ട്ലോഗോയുടെ mvi ഫയലുകൾ ഇല്ലാതാക്കുക, തുടർന്ന് പുതിയതിൻ്റെ ഫയലുകൾ പകർത്തുക"

msgid "Found bootlogos"
msgstr "ബൂട്ട്ലോഗുകൾ കണ്ടെത്തി"

msgid "Full screen view the selected bootlogo"
msgstr "തിരഞ്ഞെടുത്ത ബൂട്ട്ലോഗോ പൂർണ്ണ സ്ക്രീനിൽ കാണുക"

msgid "Hide directories without 'mvi'-files"
msgstr "'mvi'-ഫയലുകൾ ഇല്ലാതെ ഡയറക്ടറികൾ മറയ്ക്കുക"

msgid "Hide empty directories"
msgstr "ശൂന്യമായ ഡയറക്ടറികൾ മറയ്ക്കുക"

msgid "How many seconds should status messages be displayed (1-60 sec)"
msgstr "സ്റ്റാറ്റസ് സന്ദേശങ്ങൾ എത്ര സെക്കൻഡ് പ്രദർശിപ്പിക്കണം (1-60 സെക്കൻഡ്)"

msgid "Include"
msgstr "ഉൾപ്പെടുത്തുക"

msgid "Include or exlude logo in random choice"
msgstr "ക്രമരഹിതമായ തിരഞ്ഞെടുപ്പിൽ ലോഗോ ഉൾപ്പെടുത്തുകയോ ഒഴിവാക്കുകയോ ചെയ്യുക"

msgid "Included Screens"
msgstr "ഉൾപ്പെടുത്തിയ സ്ക്രീനുകൾ"

msgid "Install/deinstall ffmpeg"
msgstr "ffmpeg ഇൻസ്റ്റാൾ ചെയ്യുക/അൺഇൻസ്റ്റാൾ ചെയ്യുക"

msgid "Installation of FFmpeg failed"
msgstr "FFmpeg-ൻ്റെ ഇൻസ്റ്റാളേഷൻ പരാജയപ്പെട്ടു"

msgid "No bootlogos found in directory"
msgstr "ഡയറക്ടറിയിൽ ബൂട്ട്ലോഗുകളൊന്നും കണ്ടെത്തിയില്ല"

msgid "OK"
msgstr "ശരി"

msgid "Open settings"
msgstr "ക്രമീകരണങ്ങൾ തുറക്കുക"

msgid "Preview Logo"
msgstr "പ്രിവ്യൂ ലോഗോ"

msgid "Preview picture"
msgstr "പ്രിവ്യൂ ചിത്രം"

msgid "Random mode"
msgstr "റാൻഡം മോഡ്"

msgid "Random selection at startup disabled"
msgstr "സ്റ്റാർട്ടപ്പിലെ ക്രമരഹിതമായ തിരഞ്ഞെടുപ്പ് പ്രവർത്തനരഹിതമാക്കി"

msgid "Random selection at startup enabled"
msgstr "സ്റ്റാർട്ടപ്പിൽ ക്രമരഹിതമായ തിരഞ്ഞെടുപ്പ് പ്രവർത്തനക്ഷമമാക്കി"

msgid "Save Changes and exit plugin"
msgstr "മാറ്റങ്ങൾ സംരക്ഷിച്ച് പ്ലഗിൻ പുറത്തുകടക്കുക"

msgid "Search for folders with boot logos in this directory"
msgstr "ഈ ഡയറക്‌ടറിയിൽ ബൂട്ട് ലോഗോകളുള്ള ഫോൾഡറുകൾക്കായി തിരയുക"

msgid "Which bootlogos should be displayed?"
msgstr "ഏതൊക്കെ ബൂട്ട്ലോഗുകൾ പ്രദർശിപ്പിക്കണം?"

msgid "Which logo should be displayed as a preview picture?"
msgstr "പ്രിവ്യൂ ചിത്രമായി ഏത് ലോഗോയാണ് പ്രദർശിപ്പിക്കേണ്ടത്?"

msgid "[BootlogoChanger] activated new bootlogo"
msgstr "[BootlogoChanger] പുതിയ ബൂട്ട്‌ലോഗോ സജീവമാക്കി"

msgid "[BootlogoChanger] activating new bootlogo failed"
msgstr "[BootlogoChanger] പുതിയ ബൂട്ട്‌ലോഗോ സജീവമാക്കുന്നത് പരാജയപ്പെട്ടു"

msgid "[BootlogoChanger] copy failed"
msgstr "[BootlogoChanger] പകർപ്പ് പരാജയപ്പെട്ടു"

msgid "[BootlogoChanger] deleting old bootlogo files"
msgstr "[BootlogoChanger] പഴയ ബൂട്ട്‌ലോഗോ ഫയലുകൾ ഇല്ലാതാക്കുന്നു"

msgid "[BootlogoChanger] deleting previewPicture"
msgstr "[BootlogoChanger] പ്രിവ്യൂ ചിത്രം ഇല്ലാതാക്കുന്നു"

msgid "[BootlogoChanger] ffmpeg not found"
msgstr "[BootlogoChanger] ffmpeg കണ്ടെത്തിയില്ല"

msgid "[BootlogoChanger] found Bootlogos"
msgstr "[BootlogoChanger] Bootlogos കണ്ടെത്തി"

msgid "[BootlogoChanger] found ffmpeg"
msgstr "[BootlogoChanger] ffmpeg കണ്ടെത്തി"

msgid "[BootlogoChanger] no bootlogos for randomization selected"
msgstr "[BootlogoChanger] ക്രമരഹിതമാക്കുന്നതിന് ബൂട്ട്ലോഗുകളൊന്നും തിരഞ്ഞെടുത്തിട്ടില്ല"

msgid "[BootlogoChanger] previewPicture changed"
msgstr "[BootlogoChanger] പ്രിവ്യൂ ചിത്രം മാറ്റി"

msgid "[BootlogoChanger] randomization of bootlogos activated"
msgstr "[BootlogoChanger] ബൂട്ട്ലോഗുകളുടെ ക്രമരഹിതമാക്കൽ സജീവമാക്കി"

msgid "[BootlogoChanger] randomization of bootlogos deactivated"
msgstr "[BootlogoChanger] ബൂട്ട്ലോഗുകളുടെ ക്രമരഹിതമാക്കൽ നിർജ്ജീവമാക്കി"

msgid "[BootlogoChanger] randomization: bootlogo found"
msgstr "[BootlogoChanger] ക്രമരഹിതമാക്കൽ: ബൂട്ട്ലോഗോ കണ്ടെത്തി"

msgid "[BootlogoChanger] selected bootlogos"
msgstr "[BootlogoChanger] തിരഞ്ഞെടുത്ത ബൂട്ട്ലോഗുകൾ"

msgid "deinstall"
msgstr "അൺഇൻസ്റ്റാൾ ചെയ്യുക"

msgid "found"
msgstr "കണ്ടെത്തി"

msgid "install"
msgstr "ഇൻസ്റ്റാൾ ചെയ്യുക"

msgid "missing"
msgstr "കാണുന്നില്ല"

msgid "off"
msgstr "ഓഫ്"

msgid "on"
msgstr "ഓൺ"
