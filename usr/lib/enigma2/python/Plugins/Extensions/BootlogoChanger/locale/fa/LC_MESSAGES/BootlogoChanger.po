msgid "Activate the debug-output on console"
msgstr "خروجی اشکال زدایی را در کنسول فعال کنید"

msgid "Bootlogo is excluded from random selection"
msgstr "بوتلوگو از انتخاب تصادفی حذف شده است"

msgid "Bootlogo is included in random selection"
msgstr "بوتلوگو در انتخاب تصادفی گنجانده شده است"

msgid "Cancel"
msgstr "لغو کنید"

msgid "Choose random bootlogo at the start of the box"
msgstr "بوتلوگوی تصادفی را در ابتدای کادر انتخاب کنید"

msgid "Copy logofiles failed"
msgstr "کپی لوگوفایل ها ناموفق بود"

msgid "Current bootlogo"
msgstr "بوتلوگوی فعلی"

msgid "Debugmode"
msgstr "حالت اشکال زدایی"

msgid "Deinstallation of FFmpeg failed"
msgstr "حذف نصب FFmpeg ناموفق بود"

msgid "Delete current mvi-files before changing bootlogo"
msgstr "قبل از تغییر بوتلوگو، فایل‌های mvi فعلی را حذف کنید"

msgid "Directory with bootlogo folders"
msgstr "دایرکتوری با پوشه های بوتلوگو"

msgid "Display duration of the status messages (sec)"
msgstr "نمایش مدت زمان پیام های وضعیت (ثانیه)"

msgid "Easily switch between different bootlogos"
msgstr "به راحتی بین بوتلوگوهای مختلف جابجا شوید"

msgid "Exclude"
msgstr "مستثنی کردن"

msgid "Exit plugin without saving"
msgstr "بدون ذخیره از افزونه خارج شوید"

msgid "FFmpeg is needed to generate thumbnails from the mvi files"
msgstr "FFmpeg برای تولید ریز عکسها از فایل های mvi مورد نیاز است"

msgid "FFmpeg ist missing, no preview pictures available - there is an option to install it in the stettings"
msgstr "FFmpeg گم شده است، هیچ تصویر پیش نمایشی در دسترس نیست - گزینه ای برای نصب آن در تنظیمات وجود دارد"

msgid "FFmpeg removed successfully"
msgstr "FFmpeg با موفقیت حذف شد"

msgid "FFmpeg successfully installed"
msgstr "FFmpeg با موفقیت نصب شد"

msgid "First delete the mvi-files of the current bootlogo then copy the files of the new one"
msgstr "ابتدا فایل های mvi بوتلوگوی فعلی را حذف کنید سپس فایل های جدید را کپی کنید"

msgid "Found bootlogos"
msgstr "بوتلوگوها پیدا شد"

msgid "Full screen view the selected bootlogo"
msgstr "مشاهده تمام صفحه بوتلوگوی انتخاب شده"

msgid "Hide directories without 'mvi'-files"
msgstr "پوشه ها را بدون فایل های mvi مخفی کنید"

msgid "Hide empty directories"
msgstr "پوشه های خالی را مخفی کنید"

msgid "How many seconds should status messages be displayed (1-60 sec)"
msgstr "پیام های وضعیت چند ثانیه باید نمایش داده شوند (1 تا 60 ثانیه)"

msgid "Include"
msgstr "شامل شود"

msgid "Include or exlude logo in random choice"
msgstr "شامل یا حذف لوگو در انتخاب تصادفی"

msgid "Included Screens"
msgstr "صفحه نمایش گنجانده شده است"

msgid "Install/deinstall ffmpeg"
msgstr "ffmpeg را نصب/حذف کنید"

msgid "Installation of FFmpeg failed"
msgstr "نصب FFmpeg ناموفق بود"

msgid "No bootlogos found in directory"
msgstr "هیچ بوتلوگویی در فهرست یافت نشد"

msgid "OK"
msgstr "باشه"

msgid "Open settings"
msgstr "تنظیمات را باز کنید"

msgid "Preview Logo"
msgstr "پیش نمایش لوگو"

msgid "Preview picture"
msgstr "پیش نمایش تصویر"

msgid "Random mode"
msgstr "حالت تصادفی"

msgid "Random selection at startup disabled"
msgstr "انتخاب تصادفی هنگام راه اندازی غیرفعال است"

msgid "Random selection at startup enabled"
msgstr "انتخاب تصادفی در هنگام راه اندازی فعال شد"

msgid "Save Changes and exit plugin"
msgstr "تغییرات را ذخیره کنید و از افزونه خارج شوید"

msgid "Search for folders with boot logos in this directory"
msgstr "پوشه هایی با آرم بوت را در این فهرست جستجو کنید"

msgid "Which bootlogos should be displayed?"
msgstr "کدام بوتلوگوها باید نمایش داده شوند؟"

msgid "Which logo should be displayed as a preview picture?"
msgstr "کدام لوگو باید به عنوان تصویر پیش نمایش نمایش داده شود؟"

msgid "[BootlogoChanger] activated new bootlogo"
msgstr "[BootlogoChanger] بوتلوگوی جدید را فعال کرد"

msgid "[BootlogoChanger] activating new bootlogo failed"
msgstr "[BootlogoChanger] فعال کردن بوتلوگوی جدید ناموفق بود"

msgid "[BootlogoChanger] copy failed"
msgstr "کپی [BootlogoChanger] ناموفق بود"

msgid "[BootlogoChanger] deleting old bootlogo files"
msgstr "[BootlogoChanger] حذف فایل های بوتلوگو قدیمی"

msgid "[BootlogoChanger] deleting previewPicture"
msgstr "[BootlogoChanger] حذف پیش‌نمایش تصویر"

msgid "[BootlogoChanger] ffmpeg not found"
msgstr "[BootlogoChanger] ffmpeg یافت نشد"

msgid "[BootlogoChanger] found Bootlogos"
msgstr "[BootlogoChanger] بوتلوگوها را پیدا کرد"

msgid "[BootlogoChanger] found ffmpeg"
msgstr "[BootlogoChanger] ffmpeg را پیدا کرد"

msgid "[BootlogoChanger] no bootlogos for randomization selected"
msgstr "[BootlogoChanger] هیچ بوتلوگویی برای تصادفی‌سازی انتخاب نشده است"

msgid "[BootlogoChanger] previewPicture changed"
msgstr "پیش نمایش [BootlogoChanger]تصویر تغییر کرد"

msgid "[BootlogoChanger] randomization of bootlogos activated"
msgstr "[BootlogoChanger] تصادفی سازی بوتلوگوها فعال شد"

msgid "[BootlogoChanger] randomization of bootlogos deactivated"
msgstr "[BootlogoChanger] تصادفی سازی بوتلوگوها غیرفعال شد"

msgid "[BootlogoChanger] randomization: bootlogo found"
msgstr "[BootlogoChanger] تصادفی سازی: بوتلوگو پیدا شد"

msgid "[BootlogoChanger] selected bootlogos"
msgstr "[BootlogoChanger] بوتلوگوهای انتخاب شده"

msgid "deinstall"
msgstr "حذف نصب کنید"

msgid "found"
msgstr "یافت"

msgid "install"
msgstr "نصب کنید"

msgid "missing"
msgstr "گم شده"

msgid "off"
msgstr "خاموش"

msgid "on"
msgstr "در"
