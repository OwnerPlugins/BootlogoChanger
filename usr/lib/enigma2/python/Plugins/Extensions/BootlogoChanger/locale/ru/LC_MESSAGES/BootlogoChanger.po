msgid "Activate the debug-output on console"
msgstr "Активируйте вывод отладки на консоли"

msgid "Bootlogo is excluded from random selection"
msgstr "Логотип Boot исключен из случайного выбора"

msgid "Bootlogo is included in random selection"
msgstr "Логотип Boot включен в случайный выбор"

msgid "Cancel"
msgstr "Отмена"

msgid "Choose random bootlogo at the start of the box"
msgstr "Выберите случайный загрузочный логотип в начале окна."

msgid "Copy logofiles failed"
msgstr "Копировать файлы логотипов не удалось."

msgid "Current bootlogo"
msgstr "Текущий загрузочный логотип"

msgid "Debugmode"
msgstr "Режим отладки"

msgid "Deinstallation of FFmpeg failed"
msgstr "Удаление FFmpeg не удалось"

msgid "Delete current mvi-files before changing bootlogo"
msgstr "Удалите текущие mvi-файлы перед сменой загрузочного логотипа."

msgid "Directory with bootlogo folders"
msgstr "Каталог с папками с загрузочным логотипом"

msgid "Display duration of the status messages (sec)"
msgstr "Продолжительность отображения статусных сообщений (сек)"

msgid "Easily switch between different bootlogos"
msgstr "Легко переключаться между различными загрузочными логотипами"

msgid "Exclude"
msgstr "Исключать"

msgid "Exit plugin without saving"
msgstr "Выйти из плагина без сохранения"

msgid "FFmpeg is needed to generate thumbnails from the mvi files"
msgstr "FFmpeg необходим для создания миниатюр из файлов MVI."

msgid "FFmpeg ist missing, no preview pictures available - there is an option to install it in the stettings"
msgstr "FFmpeg отсутствует, изображения для предварительного просмотра отсутствуют — в настройках есть возможность установить его."

msgid "FFmpeg removed successfully"
msgstr "FFmpeg успешно удален"

msgid "FFmpeg successfully installed"
msgstr "FFmpeg успешно установлен"

msgid "First delete the mvi-files of the current bootlogo then copy the files of the new one"
msgstr "Сначала удалите mvi-файлы текущего загрузочного логотипа, затем скопируйте файлы нового."

msgid "Found bootlogos"
msgstr "Найдены загрузочные логотипы"

msgid "Full screen view the selected bootlogo"
msgstr "Полноэкранный просмотр выбранного загрузочного логотипа"

msgid "Hide directories without 'mvi'-files"
msgstr "Скрыть каталоги без файлов mvi"

msgid "Hide empty directories"
msgstr "Скрыть пустые каталоги"

msgid "How many seconds should status messages be displayed (1-60 sec)"
msgstr "Сколько секунд должны отображаться сообщения о состоянии (1–60 секунд)"

msgid "Include"
msgstr "Включать"

msgid "Include or exlude logo in random choice"
msgstr "Включить или исключить логотип в случайном порядке"

msgid "Included Screens"
msgstr "Включенные экраны"

msgid "Install/deinstall ffmpeg"
msgstr "Установить/удалить ffmpeg"

msgid "Installation of FFmpeg failed"
msgstr "Установка FFmpeg не удалась"

msgid "No bootlogos found in directory"
msgstr "В каталоге не найдены загрузочные логотипы"

msgid "OK"
msgstr "ХОРОШО"

msgid "Open settings"
msgstr "Открыть настройки"

msgid "Preview Logo"
msgstr "Предварительный просмотр логотипа"

msgid "Preview picture"
msgstr "Предварительный просмотр изображения"

msgid "Random mode"
msgstr "Случайный режим"

msgid "Random selection at startup disabled"
msgstr "Случайный выбор при запуске отключен"

msgid "Random selection at startup enabled"
msgstr "Случайный выбор при запуске включен"

msgid "Save Changes and exit plugin"
msgstr "Сохранить изменения и выйти из плагина"

msgid "Search for folders with boot logos in this directory"
msgstr "Найдите в этом каталоге папки с загрузочными логотипами."

msgid "Which bootlogos should be displayed?"
msgstr "Какие загрузочные логотипы должны отображаться?"

msgid "Which logo should be displayed as a preview picture?"
msgstr "Какой логотип должен отображаться в качестве изображения предварительного просмотра?"

msgid "[BootlogoChanger] activated new bootlogo"
msgstr "[BootlogoChanger] активировал новый загрузочный логотип"

msgid "[BootlogoChanger] activating new bootlogo failed"
msgstr "[BootlogoChanger] не удалось активировать новый загрузочный логотип"

msgid "[BootlogoChanger] copy failed"
msgstr "[BootlogoChanger] не удалось скопировать"

msgid "[BootlogoChanger] deleting old bootlogo files"
msgstr "[BootlogoChanger] удаление старых файлов загрузочного логотипа"

msgid "[BootlogoChanger] deleting previewPicture"
msgstr "[BootlogoChanger] удаление предварительного просмотра изображения"

msgid "[BootlogoChanger] ffmpeg not found"
msgstr "[BootlogoChanger] ffmpeg не найден"

msgid "[BootlogoChanger] found Bootlogos"
msgstr "[BootlogoChanger] нашел загрузочные логотипы"

msgid "[BootlogoChanger] found ffmpeg"
msgstr "[BootlogoChanger] нашел ffmpeg"

msgid "[BootlogoChanger] no bootlogos for randomization selected"
msgstr "[BootlogoChanger] не выбраны загрузочные логотипы для рандомизации"

msgid "[BootlogoChanger] previewPicture changed"
msgstr "[BootlogoChanger] Предварительный просмотрИзображение изменено"

msgid "[BootlogoChanger] randomization of bootlogos activated"
msgstr "[BootlogoChanger] активирована рандомизация загрузочных логотипов"

msgid "[BootlogoChanger] randomization of bootlogos deactivated"
msgstr "[BootlogoChanger] отключена рандомизация загрузочных логотипов"

msgid "[BootlogoChanger] randomization: bootlogo found"
msgstr "[BootlogoChanger] рандомизация: найден загрузочный логотип"

msgid "[BootlogoChanger] selected bootlogos"
msgstr "[BootlogoChanger] выбранные загрузочные логотипы"

msgid "deinstall"
msgstr "удалить"

msgid "found"
msgstr "найденный"

msgid "install"
msgstr "установить"

msgid "missing"
msgstr "отсутствующий"

msgid "off"
msgstr "выключенный"

msgid "on"
msgstr "на"
