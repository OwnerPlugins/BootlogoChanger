msgid "Activate the debug-output on console"
msgstr "Aktivigu la sencimigan eligon sur konzolo"

msgid "Bootlogo is excluded from random selection"
msgstr "Bootlogo estas ekskludita de hazarda elekto"

msgid "Bootlogo is included in random selection"
msgstr "Bootlogo estas inkluzivita en hazarda elekto"

msgid "Cancel"
msgstr "Nuligi"

msgid "Choose random bootlogo at the start of the box"
msgstr "Elektu hazardan bootlogon ĉe la komenco de la skatolo"

msgid "Copy logofiles failed"
msgstr "Kopio de logodosieroj malsukcesis"

msgid "Current bootlogo"
msgstr "Nuna bootlogo"

msgid "Debugmode"
msgstr "Sencimiga reĝimo"

msgid "Deinstallation of FFmpeg failed"
msgstr "Malinstalado de FFmpeg malsukcesis"

msgid "Delete current mvi-files before changing bootlogo"
msgstr "Forigu nunajn mvi-dosierojn antaŭ ol ŝanĝi bootlogon"

msgid "Directory with bootlogo folders"
msgstr "Dosierujo kun bootlogo-dosierujoj"

msgid "Display duration of the status messages (sec)"
msgstr "Montru daŭron de la statusmesaĝoj (sec)"

msgid "Easily switch between different bootlogos"
msgstr "Facile ŝanĝi inter malsamaj botologoj"

msgid "Exclude"
msgstr "Ekskludi"

msgid "Exit plugin without saving"
msgstr "Eliru kromprogramon sen konservi"

msgid "FFmpeg is needed to generate thumbnails from the mvi files"
msgstr "FFmpeg estas necesa por generi bildetojn el la mvi-dosieroj"

msgid "FFmpeg ist missing, no preview pictures available - there is an option to install it in the stettings"
msgstr "FFmpeg mankas, neniuj antaŭprezentbildoj haveblaj - ekzistas opcio por instali ĝin en la agordoj"

msgid "FFmpeg removed successfully"
msgstr "FFmpeg sukcese forigita"

msgid "FFmpeg successfully installed"
msgstr "FFmpeg sukcese instalita"

msgid "First delete the mvi-files of the current bootlogo then copy the files of the new one"
msgstr "Unue forigu la mvi-dosierojn de la nuna bootlogo poste kopiu la dosierojn de la nova"

msgid "Found bootlogos"
msgstr "Trovis botologojn"

msgid "Full screen view the selected bootlogo"
msgstr "Plenekrana rigardu la elektitan botologon"

msgid "Hide directories without 'mvi'-files"
msgstr "Kaŝi dosierujojn sen 'mvi'-dosieroj"

msgid "Hide empty directories"
msgstr "Kaŝi malplenajn dosierujojn"

msgid "How many seconds should status messages be displayed (1-60 sec)"
msgstr "Kiom da sekundoj devus esti montrataj statomesaĝoj (1-60 sek)"

msgid "Include"
msgstr "Inkluzivi"

msgid "Include or exlude logo in random choice"
msgstr "Inkluzivi aŭ ekskludi logoon en hazarda elekto"

msgid "Included Screens"
msgstr "Inkluditaj Ekranoj"

msgid "Install/deinstall ffmpeg"
msgstr "Instali/malinstali ffmpeg"

msgid "Installation of FFmpeg failed"
msgstr "Instalado de FFmpeg malsukcesis"

msgid "No bootlogos found in directory"
msgstr "Neniuj botologoj trovitaj en dosierujo"

msgid "OK"
msgstr "Bone"

msgid "Open settings"
msgstr "Malfermu agordojn"

msgid "Preview Logo"
msgstr "Antaŭrigardo Logo"

msgid "Preview picture"
msgstr "Antaŭrigarda bildo"

msgid "Random mode"
msgstr "Hazarda reĝimo"

msgid "Random selection at startup disabled"
msgstr "Hazarda elekto ĉe ekfunkciigo estas malŝaltita"

msgid "Random selection at startup enabled"
msgstr "Hazarda elekto ĉe ekfunkciigo estas ebligita"

msgid "Save Changes and exit plugin"
msgstr "Konservu Ŝanĝojn kaj eliru aldonaĵon"

msgid "Search for folders with boot logos in this directory"
msgstr "Serĉu dosierujojn kun lanĉaj emblemoj en ĉi tiu dosierujo"

msgid "Which bootlogos should be displayed?"
msgstr "Kiuj botologoj estu montrataj?"

msgid "Which logo should be displayed as a preview picture?"
msgstr "Kiu emblemo devus esti montrita kiel antaŭrigarda bildo?"

msgid "[BootlogoChanger] activated new bootlogo"
msgstr "[BootlogoChanger] aktivigis novan bootlogon"

msgid "[BootlogoChanger] activating new bootlogo failed"
msgstr "[BootlogoChanger] aktivigo de nova bootlogo malsukcesis"

msgid "[BootlogoChanger] copy failed"
msgstr "[BootlogoChanger] kopio malsukcesis"

msgid "[BootlogoChanger] deleting old bootlogo files"
msgstr "[BootlogoChanger] forigante malnovajn bootlogo-dosierojn"

msgid "[BootlogoChanger] deleting previewPicture"
msgstr "[BootlogoChanger] forigante antaŭrigardon"

msgid "[BootlogoChanger] ffmpeg not found"
msgstr "[BootlogoChanger] ffmpeg ne trovita"

msgid "[BootlogoChanger] found Bootlogos"
msgstr "[BootlogoChanger] trovis Bootlogos"

msgid "[BootlogoChanger] found ffmpeg"
msgstr "[BootlogoChanger] trovis ffmpeg"

msgid "[BootlogoChanger] no bootlogos for randomization selected"
msgstr "[BootlogoChanger] neniuj botologoj por hazardo elektita"

msgid "[BootlogoChanger] previewPicture changed"
msgstr "[BootlogoChanger] antaŭrigardoBildo ŝanĝita"

msgid "[BootlogoChanger] randomization of bootlogos activated"
msgstr "[BootlogoChanger] hazardigo de botologoj aktivigita"

msgid "[BootlogoChanger] randomization of bootlogos deactivated"
msgstr "[BootlogoChanger] hazardigo de botologoj malaktivigita"

msgid "[BootlogoChanger] randomization: bootlogo found"
msgstr "[BootlogoChanger] hazardigo: bootlogo trovita"

msgid "[BootlogoChanger] selected bootlogos"
msgstr "[BootlogoChanger] elektitaj botologoj"

msgid "deinstall"
msgstr "malinstali"

msgid "found"
msgstr "trovita"

msgid "install"
msgstr "instali"

msgid "missing"
msgstr "mankas"

msgid "off"
msgstr "for"

msgid "on"
msgstr ""
