msgid "Activate the debug-output on console"
msgstr "Konsolda hata ayıklama çıkışını etkinleştirin"

msgid "Bootlogo is excluded from random selection"
msgstr "Bootlogo rastgele seçimin dışında bırakıldı"

msgid "Bootlogo is included in random selection"
msgstr "Bootlogo rastgele seçime dahil edildi"

msgid "Cancel"
msgstr "İptal etmek"

msgid "Choose random bootlogo at the start of the box"
msgstr "Kutunun başında rastgele önyükleme logosunu seçin"

msgid "Copy logofiles failed"
msgstr "Logo dosyalarının kopyalanması başarısız oldu"

msgid "Current bootlogo"
msgstr "Mevcut açılış logosu"

msgid "Debugmode"
msgstr "Hata ayıklama modu"

msgid "Deinstallation of FFmpeg failed"
msgstr "FFmpeg'in kaldırılması başarısız oldu"

msgid "Delete current mvi-files before changing bootlogo"
msgstr "Bootlogo'yu değiştirmeden önce mevcut mvi dosyalarını silin"

msgid "Directory with bootlogo folders"
msgstr "Bootlogo klasörlerini içeren dizin"

msgid "Display duration of the status messages (sec)"
msgstr "Durum mesajlarının görüntülenme süresi (sn)"

msgid "Easily switch between different bootlogos"
msgstr "Farklı açılış logoları arasında kolayca geçiş yapın"

msgid "Exclude"
msgstr "Hariç tutmak"

msgid "Exit plugin without saving"
msgstr "Kaydetmeden eklentiden çık"

msgid "FFmpeg is needed to generate thumbnails from the mvi files"
msgstr "Mvi dosyalarından küçük resimler oluşturmak için FFmpeg gereklidir"

msgid "FFmpeg ist missing, no preview pictures available - there is an option to install it in the stettings"
msgstr "FFmpeg eksik, ön izleme resmi yok - ayarlarda bunu yükleme seçeneği var"

msgid "FFmpeg removed successfully"
msgstr "FFmpeg başarıyla kaldırıldı"

msgid "FFmpeg successfully installed"
msgstr "FFmpeg başarıyla yüklendi"

msgid "First delete the mvi-files of the current bootlogo then copy the files of the new one"
msgstr "Önce mevcut bootlogo'nun mvi dosyalarını silin, ardından yenisinin dosyalarını kopyalayın"

msgid "Found bootlogos"
msgstr "Açılış logoları bulundu"

msgid "Full screen view the selected bootlogo"
msgstr "Seçilen önyükleme logosunu tam ekran görüntüleyin"

msgid "Hide directories without 'mvi'-files"
msgstr "'Mvi' dosyaları olmayan dizinleri gizle"

msgid "Hide empty directories"
msgstr "Boş dizinleri gizle"

msgid "How many seconds should status messages be displayed (1-60 sec)"
msgstr "Durum mesajları kaç saniye görüntülenmelidir (1-60 sn)"

msgid "Include"
msgstr "Katmak"

msgid "Include or exlude logo in random choice"
msgstr "Rastgele seçime logoyu dahil et veya hariç tut"

msgid "Included Screens"
msgstr "Dahil Edilen Ekranlar"

msgid "Install/deinstall ffmpeg"
msgstr "Ffmpeg'i yükleme/kaldırma"

msgid "Installation of FFmpeg failed"
msgstr "FFmpeg kurulumu başarısız oldu"

msgid "No bootlogos found in directory"
msgstr "Dizinde bootlogo bulunamadı"

msgid "OK"
msgstr "TAMAM"

msgid "Open settings"
msgstr "Ayarları aç"

msgid "Preview Logo"
msgstr "Logoyu önizle"

msgid "Preview picture"
msgstr "Resmin önizlemesi"

msgid "Random mode"
msgstr "Rastgele mod"

msgid "Random selection at startup disabled"
msgstr "Başlangıçta rastgele seçim devre dışı bırakıldı"

msgid "Random selection at startup enabled"
msgstr "Başlangıçta rastgele seçim etkin"

msgid "Save Changes and exit plugin"
msgstr "Değişiklikleri kaydet ve eklentiden çık"

msgid "Search for folders with boot logos in this directory"
msgstr "Bu dizinde önyükleme logoları olan klasörleri arayın"

msgid "Which bootlogos should be displayed?"
msgstr "Hangi açılış logoları görüntülenmeli?"

msgid "Which logo should be displayed as a preview picture?"
msgstr "Önizleme resmi olarak hangi logo görüntülenmeli?"

msgid "[BootlogoChanger] activated new bootlogo"
msgstr "[BootlogoChanger] yeni açılış logosunu etkinleştirdi"

msgid "[BootlogoChanger] activating new bootlogo failed"
msgstr "[BootlogoChanger] yeni açılış logosunu etkinleştirme başarısız oldu"

msgid "[BootlogoChanger] copy failed"
msgstr "[BootlogoChanger] kopyalama başarısız oldu"

msgid "[BootlogoChanger] deleting old bootlogo files"
msgstr "[BootlogoChanger] eski bootlogo dosyalarını silme"

msgid "[BootlogoChanger] deleting previewPicture"
msgstr "[BootlogoChanger] önizlemePicture siliniyor"

msgid "[BootlogoChanger] ffmpeg not found"
msgstr "[BootlogoChanger] ffmpeg bulunamadı"

msgid "[BootlogoChanger] found Bootlogos"
msgstr "[BootlogoChanger] Bootlogo'ları buldu"

msgid "[BootlogoChanger] found ffmpeg"
msgstr "[BootlogoChanger] ffmpeg'i buldu"

msgid "[BootlogoChanger] no bootlogos for randomization selected"
msgstr "[BootlogoChanger] rastgele seçim için önyükleme logosu seçilmedi"

msgid "[BootlogoChanger] previewPicture changed"
msgstr "[BootlogoChanger] önizlemeResim değiştirildi"

msgid "[BootlogoChanger] randomization of bootlogos activated"
msgstr "[BootlogoChanger] bootlogoların rastgele seçimi etkinleştirildi"

msgid "[BootlogoChanger] randomization of bootlogos deactivated"
msgstr "[BootlogoChanger] bootlogoların rastgele seçimi devre dışı bırakıldı"

msgid "[BootlogoChanger] randomization: bootlogo found"
msgstr "[BootlogoChanger] rastgeleleştirme: bootlogo bulundu"

msgid "[BootlogoChanger] selected bootlogos"
msgstr "[BootlogoChanger] seçili açılış logoları"

msgid "deinstall"
msgstr "kaldır"

msgid "found"
msgstr "kurmak"

msgid "install"
msgstr "düzenlemek"

msgid "missing"
msgstr "eksik"

msgid "off"
msgstr "kapalı"

msgid "on"
msgstr "Açık"
