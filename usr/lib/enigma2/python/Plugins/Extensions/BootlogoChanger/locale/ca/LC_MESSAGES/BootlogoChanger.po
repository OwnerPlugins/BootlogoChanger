msgid "Activate the debug-output on console"
msgstr "Activeu la sortida de depuració a la consola"

msgid "Bootlogo is excluded from random selection"
msgstr "Bootlogo està exclòs de la selecció aleatòria"

msgid "Bootlogo is included in random selection"
msgstr "Bootlogo s'inclou a la selecció aleatòria"

msgid "Cancel"
msgstr "Cancel·la"

msgid "Choose random bootlogo at the start of the box"
msgstr "Trieu el logotip d'arrencada aleatori al començament del quadre"

msgid "Copy logofiles failed"
msgstr "No s'han pogut copiar els fitxers de logotip"

msgid "Current bootlogo"
msgstr "Bootlogo actual"

msgid "Debugmode"
msgstr "Mode de depuració"

msgid "Deinstallation of FFmpeg failed"
msgstr "La desinstal·lació de FFmpeg ha fallat"

msgid "Delete current mvi-files before changing bootlogo"
msgstr "Suprimeix els fitxers mvi actuals abans de canviar el logotip d'arrencada"

msgid "Directory with bootlogo folders"
msgstr "Directori amb carpetes bootlogo"

msgid "Display duration of the status messages (sec)"
msgstr "Mostra la durada dels missatges d'estat (s)"

msgid "Easily switch between different bootlogos"
msgstr "Canvia fàcilment entre diferents logotips d'arrencada"

msgid "Exclude"
msgstr "Exclou"

msgid "Exit plugin without saving"
msgstr "Sortiu del connector sense desar"

msgid "FFmpeg is needed to generate thumbnails from the mvi files"
msgstr "FFmpeg és necessari per generar miniatures dels fitxers mvi"

msgid "FFmpeg ist missing, no preview pictures available - there is an option to install it in the stettings"
msgstr "Falta FFmpeg, no hi ha imatges de vista prèvia disponibles; hi ha una opció per instal·lar-lo a les configuracions"

msgid "FFmpeg removed successfully"
msgstr "FFmpeg s'ha eliminat correctament"

msgid "FFmpeg successfully installed"
msgstr "FFmpeg instal·lat correctament"

msgid "First delete the mvi-files of the current bootlogo then copy the files of the new one"
msgstr "Primer suprimiu els fitxers mvi del logotip d'arrencada actual i després copieu els fitxers del nou"

msgid "Found bootlogos"
msgstr "S'han trobat bootlogos"

msgid "Full screen view the selected bootlogo"
msgstr "Visualitza a pantalla completa el logotip d'arrencada seleccionat"

msgid "Hide directories without 'mvi'-files"
msgstr "Amaga els directoris sense fitxers 'mvi'"

msgid "Hide empty directories"
msgstr "Amaga els directoris buits"

msgid "How many seconds should status messages be displayed (1-60 sec)"
msgstr "Quants segons s'han de mostrar els missatges d'estat (1-60 segons)"

msgid "Include"
msgstr "Inclou"

msgid "Include or exlude logo in random choice"
msgstr "Inclou o exclou el logotip en una elecció aleatòria"

msgid "Included Screens"
msgstr "Pantalles incloses"

msgid "Install/deinstall ffmpeg"
msgstr "Instal·leu/desinstal·leu ffmpeg"

msgid "Installation of FFmpeg failed"
msgstr "La instal·lació de FFmpeg ha fallat"

msgid "No bootlogos found in directory"
msgstr "No s'ha trobat cap logotip d'arrencada al directori"

msgid "OK"
msgstr "D'acord"

msgid "Open settings"
msgstr "Obre la configuració"

msgid "Preview Logo"
msgstr "Vista prèvia del logotip"

msgid "Preview picture"
msgstr "Vista prèvia de la imatge"

msgid "Random mode"
msgstr "Mode aleatori"

msgid "Random selection at startup disabled"
msgstr "Selecció aleatòria a l'inici desactivada"

msgid "Random selection at startup enabled"
msgstr "Selecció aleatòria activada a l'inici"

msgid "Save Changes and exit plugin"
msgstr "Desa els canvis i surt del connector"

msgid "Search for folders with boot logos in this directory"
msgstr "Cerqueu carpetes amb logotips d'arrencada en aquest directori"

msgid "Which bootlogos should be displayed?"
msgstr "Quins bootlogos s'han de mostrar?"

msgid "Which logo should be displayed as a preview picture?"
msgstr "Quin logotip s'ha de mostrar com a imatge de previsualització?"

msgid "[BootlogoChanger] activated new bootlogo"
msgstr "[BootlogoChanger] ha activat el nou logotip d'arrencada"

msgid "[BootlogoChanger] activating new bootlogo failed"
msgstr "[BootlogoChanger] no s'ha pogut activar el nou logotip d'arrencada"

msgid "[BootlogoChanger] copy failed"
msgstr "La còpia de [BootlogoChanger] ha fallat"

msgid "[BootlogoChanger] deleting old bootlogo files"
msgstr "[BootlogoChanger] suprimint fitxers de logotip d'arrencada antics"

msgid "[BootlogoChanger] deleting previewPicture"
msgstr "[BootlogoChanger] suprimint la vista prèvia de la imatge"

msgid "[BootlogoChanger] ffmpeg not found"
msgstr "[BootlogoChanger] ffmpeg no trobat"

msgid "[BootlogoChanger] found Bootlogos"
msgstr "[BootlogoChanger] ha trobat Bootlogos"

msgid "[BootlogoChanger] found ffmpeg"
msgstr "[BootlogoChanger] trobat ffmpeg"

msgid "[BootlogoChanger] no bootlogos for randomization selected"
msgstr "[BootlogoChanger] no s'ha seleccionat cap logotip d'arrencada per a l'atzar"

msgid "[BootlogoChanger] previewPicture changed"
msgstr "[BootlogoChanger] vista prèvia La imatge ha canviat"

msgid "[BootlogoChanger] randomization of bootlogos activated"
msgstr "[BootlogoChanger] s'ha activat l'aleatorització dels logotips d'arrencada"

msgid "[BootlogoChanger] randomization of bootlogos deactivated"
msgstr "[BootlogoChanger] s'ha desactivat l'aleatorització dels logotips d'arrencada"

msgid "[BootlogoChanger] randomization: bootlogo found"
msgstr "[BootlogoChanger] aleatorització: bootlogo trobat"

msgid "[BootlogoChanger] selected bootlogos"
msgstr "[BootlogoChanger] logotips d'arrencada seleccionats"

msgid "deinstall"
msgstr "desinstal·lar"

msgid "found"
msgstr "trobat"

msgid "install"
msgstr "instal·lar"

msgid "missing"
msgstr "desaparegut"

msgid "off"
msgstr "apagat"

msgid "on"
msgstr "activat"
