msgid "Activate the debug-output on console"
msgstr "Aktivujte výstup ladenia na konzole"

msgid "Bootlogo is excluded from random selection"
msgstr "Bootlogo je vylúčené z náhodného výberu"

msgid "Bootlogo is included in random selection"
msgstr "Bootlogo je zahrnuté v náhodnom výbere"

msgid "Cancel"
msgstr "Zrušiť"

msgid "Choose random bootlogo at the start of the box"
msgstr "Vyberte si náhodné bootlogo na začiatku poľa"

msgid "Copy logofiles failed"
msgstr "Kopírovanie súborov s logom zlyhalo"

msgid "Current bootlogo"
msgstr "Aktuálne bootlogo"

msgid "Debugmode"
msgstr "Režim ladenia"

msgid "Deinstallation of FFmpeg failed"
msgstr "Odinštalovanie FFmpeg zlyhalo"

msgid "Delete current mvi-files before changing bootlogo"
msgstr "Pred zmenou bootloga odstráňte aktuálne súbory mvi"

msgid "Directory with bootlogo folders"
msgstr "Adresár s priečinkami bootlogo"

msgid "Display duration of the status messages (sec)"
msgstr "Zobrazenie trvania stavových správ (s)"

msgid "Easily switch between different bootlogos"
msgstr "Ľahko prepínajte medzi rôznymi bootlogami"

msgid "Exclude"
msgstr "Vylúčiť"

msgid "Exit plugin without saving"
msgstr "Ukončite doplnok bez uloženia"

msgid "FFmpeg is needed to generate thumbnails from the mvi files"
msgstr "FFmpeg je potrebný na generovanie miniatúr zo súborov mvi"

msgid "FFmpeg ist missing, no preview pictures available - there is an option to install it in the stettings"
msgstr "Chýba FFmpeg, nie sú k dispozícii žiadne náhľadové obrázky - v nastaveniach je možnosť nainštalovať ho"

msgid "FFmpeg removed successfully"
msgstr "FFmpeg bol úspešne odstránený"

msgid "FFmpeg successfully installed"
msgstr "FFmpeg úspešne nainštalovaný"

msgid "First delete the mvi-files of the current bootlogo then copy the files of the new one"
msgstr "Najprv odstráňte súbory mvi aktuálneho loga a potom skopírujte súbory nového loga"

msgid "Found bootlogos"
msgstr "Našli sa bootloga"

msgid "Full screen view the selected bootlogo"
msgstr "Zobrazenie vybraného bootloga na celej obrazovke"

msgid "Hide directories without 'mvi'-files"
msgstr "Skryť adresáre bez súborov 'mvi'"

msgid "Hide empty directories"
msgstr "Skryť prázdne adresáre"

msgid "How many seconds should status messages be displayed (1-60 sec)"
msgstr "Koľko sekúnd by sa mali zobraziť stavové správy (1-60 sekúnd)"

msgid "Include"
msgstr "Zahrnúť"

msgid "Include or exlude logo in random choice"
msgstr "Zahrnúť alebo vylúčiť logo v náhodnom výbere"

msgid "Included Screens"
msgstr "Zahrnuté obrazovky"

msgid "Install/deinstall ffmpeg"
msgstr "Nainštalovať/odinštalovať ffmpeg"

msgid "Installation of FFmpeg failed"
msgstr "Inštalácia FFmpeg zlyhala"

msgid "No bootlogos found in directory"
msgstr "V adresári sa nenašli žiadne bootloga"

msgid "OK"
msgstr ""

msgid "Open settings"
msgstr "Otvorte nastavenia"

msgid "Preview Logo"
msgstr "Ukážka loga"

msgid "Preview picture"
msgstr "Náhľadový obrázok"

msgid "Random mode"
msgstr "Náhodný režim"

msgid "Random selection at startup disabled"
msgstr "Náhodný výber pri spustení je zakázaný"

msgid "Random selection at startup enabled"
msgstr "Náhodný výber pri spustení povolený"

msgid "Save Changes and exit plugin"
msgstr "Uložte zmeny a ukončite doplnok"

msgid "Search for folders with boot logos in this directory"
msgstr "V tomto adresári vyhľadajte priečinky s logami zavádzania"

msgid "Which bootlogos should be displayed?"
msgstr "Ktoré bootloga by sa mali zobraziť?"

msgid "Which logo should be displayed as a preview picture?"
msgstr "Ktoré logo by sa malo zobraziť ako náhľadový obrázok?"

msgid "[BootlogoChanger] activated new bootlogo"
msgstr "[BootlogoChanger] aktivoval nové bootlogo"

msgid "[BootlogoChanger] activating new bootlogo failed"
msgstr "[BootlogoChanger] aktivácia nového loga boot zlyhala"

msgid "[BootlogoChanger] copy failed"
msgstr "Kopírovanie [BootlogoChanger] zlyhalo"

msgid "[BootlogoChanger] deleting old bootlogo files"
msgstr "[BootlogoChanger] odstraňuje staré súbory bootlogo"

msgid "[BootlogoChanger] deleting previewPicture"
msgstr "[BootlogoChanger] odstraňuje náhľadový obrázok"

msgid "[BootlogoChanger] ffmpeg not found"
msgstr "[BootlogoChanger] ffmpeg sa nenašiel"

msgid "[BootlogoChanger] found Bootlogos"
msgstr "[BootlogoChanger] našiel Bootlogos"

msgid "[BootlogoChanger] found ffmpeg"
msgstr "[BootlogoChanger] našiel ffmpeg"

msgid "[BootlogoChanger] no bootlogos for randomization selected"
msgstr "[BootlogoChanger] neboli vybraté žiadne logá zavádzania pre randomizáciu"

msgid "[BootlogoChanger] previewPicture changed"
msgstr "[BootlogoChanger] previewPicture zmenený"

msgid "[BootlogoChanger] randomization of bootlogos activated"
msgstr "[BootlogoChanger] randomizácia bootloga aktivovaná"

msgid "[BootlogoChanger] randomization of bootlogos deactivated"
msgstr "[BootlogoChanger] randomizácia bootloga deaktivovaná"

msgid "[BootlogoChanger] randomization: bootlogo found"
msgstr "[BootlogoChanger] randomizácia: bootlogo nájdené"

msgid "[BootlogoChanger] selected bootlogos"
msgstr "[BootlogoChanger] vybraté logá zavádzania"

msgid "deinstall"
msgstr "odinštalovať"

msgid "found"
msgstr "nájdené"

msgid "install"
msgstr "nainštalovať"

msgid "missing"
msgstr "chýba"

msgid "off"
msgstr "vypnuté"

msgid "on"
msgstr "na"
