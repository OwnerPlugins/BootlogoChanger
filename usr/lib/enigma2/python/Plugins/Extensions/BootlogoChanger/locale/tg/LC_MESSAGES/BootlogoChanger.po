msgid "Activate the debug-output on console"
msgstr "Баромади дебагро дар консол фаъол созед"

msgid "Bootlogo is excluded from random selection"
msgstr "Bootlogo аз интихоби тасодуфӣ хориҷ карда шудааст"

msgid "Bootlogo is included in random selection"
msgstr "Bootlogo ба интихоби тасодуфӣ дохил карда шудааст"

msgid "Cancel"
msgstr "Бекор кардан"

msgid "Choose random bootlogo at the start of the box"
msgstr "Дар оғози қуттии пурборкунандаи тасодуфӣ интихоб кунед"

msgid "Copy logofiles failed"
msgstr "Нусхабардории файлҳои лого муваффақ нашуд"

msgid "Current bootlogo"
msgstr "Логотипи ҷорӣ"

msgid "Debugmode"
msgstr "Реҷаи ислоҳ"

msgid "Deinstallation of FFmpeg failed"
msgstr "Хориҷ кардани FFmpeg ноком шуд"

msgid "Delete current mvi-files before changing bootlogo"
msgstr "Пеш аз тағир додани bootlogo файлҳои mvi-ро нест кунед"

msgid "Directory with bootlogo folders"
msgstr "Директория бо ҷузвдонҳои bootlogo"

msgid "Display duration of the status messages (sec)"
msgstr "Намоиши давомнокии паёмҳои ҳолати (сония)"

msgid "Easily switch between different bootlogos"
msgstr "Ба осонӣ байни боргузориҳои гуногун гузаред"

msgid "Exclude"
msgstr "Истисно кардан"

msgid "Exit plugin without saving"
msgstr "Васлкунаки худро бе захира кардан хориҷ кунед"

msgid "FFmpeg is needed to generate thumbnails from the mvi files"
msgstr "FFmpeg барои тавлиди эскизҳо аз файлҳои mvi лозим аст"

msgid "FFmpeg ist missing, no preview pictures available - there is an option to install it in the stettings"
msgstr "FFmpeg нест, тасвирҳои пешнамоиш мавҷуд нест - имкони насб кардани он дар stettings вуҷуд дорад"

msgid "FFmpeg removed successfully"
msgstr "FFmpeg бомуваффақият хориҷ карда шуд"

msgid "FFmpeg successfully installed"
msgstr "FFmpeg бомуваффақият насб карда шуд"

msgid "First delete the mvi-files of the current bootlogo then copy the files of the new one"
msgstr "Аввал mvi-файлҳои bootlogo-и ҷорӣро нест кунед ва пас файлҳои навро нусхабардорӣ кунед"

msgid "Found bootlogos"
msgstr "bootlogs ёфт"

msgid "Full screen view the selected bootlogo"
msgstr "Намоиши пурраи экрани пурборкунандаи интихобшуда"

msgid "Hide directories without 'mvi'-files"
msgstr "Директорияҳоро бе 'mvi'-файлҳо пинҳон кунед"

msgid "Hide empty directories"
msgstr "Директорияҳои холиро пинҳон кунед"

msgid "How many seconds should status messages be displayed (1-60 sec)"
msgstr "Паёмҳои ҳолати чанд сония бояд намоиш дода шаванд (1-60 сония)"

msgid "Include"
msgstr "дохил кунед"

msgid "Include or exlude logo in random choice"
msgstr "Логоро ба интихоби тасодуфӣ дохил кунед ё хориҷ кунед"

msgid "Included Screens"
msgstr "Экранҳои дохилшуда"

msgid "Install/deinstall ffmpeg"
msgstr "ffmpeg насб/нест кунед"

msgid "Installation of FFmpeg failed"
msgstr "Насби FFmpeg ноком шуд"

msgid "No bootlogos found in directory"
msgstr "Дар директория ягон bootlogos ёфт нашуд"

msgid "OK"
msgstr "ДУРУСТ"

msgid "Open settings"
msgstr "Танзимотро кушоед"

msgid "Preview Logo"
msgstr "Пешнамоиши логотип"

msgid "Preview picture"
msgstr "Пешнамоиши расм"

msgid "Random mode"
msgstr "Ҳолати тасодуфӣ"

msgid "Random selection at startup disabled"
msgstr "Интихоби тасодуфӣ ҳангоми оғозёбӣ ғайрифаъол аст"

msgid "Random selection at startup enabled"
msgstr "Интихоби тасодуфӣ ҳангоми оғозёбӣ фаъол аст"

msgid "Save Changes and exit plugin"
msgstr "Тағиротро захира кунед ва плагинро тарк кунед"

msgid "Search for folders with boot logos in this directory"
msgstr "Дар ин феҳрист ҷузвдонҳоро бо логотипи пурборшаванда ҷустуҷӯ кунед"

msgid "Which bootlogos should be displayed?"
msgstr "Кадом bootlogos бояд намоиш дода шаванд?"

msgid "Which logo should be displayed as a preview picture?"
msgstr "Кадом логотип бояд ҳамчун тасвири пешнамоиш намоиш дода шавад?"

msgid "[BootlogoChanger] activated new bootlogo"
msgstr "[BootlogoChanger] bootlogo навро фаъол кард"

msgid "[BootlogoChanger] activating new bootlogo failed"
msgstr "[BootlogoChanger] фаъолсозии bootlogo нав натавонист"

msgid "[BootlogoChanger] copy failed"
msgstr "Нусхаи [BootlogoChanger] ноком шуд"

msgid "[BootlogoChanger] deleting old bootlogo files"
msgstr "[BootlogoChanger] нест кардани файлҳои кӯҳнаи bootlogo"

msgid "[BootlogoChanger] deleting previewPicture"
msgstr "[BootlogoChanger] нест кардани пешнамоишPicture"

msgid "[BootlogoChanger] ffmpeg not found"
msgstr "[BootlogoChanger] ffmpeg ёфт нашуд"

msgid "[BootlogoChanger] found Bootlogos"
msgstr "[BootlogoChanger] Bootlogos ёфт"

msgid "[BootlogoChanger] found ffmpeg"
msgstr "[BootlogoChanger] ffmpeg ёфт"

msgid "[BootlogoChanger] no bootlogos for randomization selected"
msgstr "[BootlogoChanger] ҳеҷ bootlogos барои тасодуфӣ интихоб нашудааст"

msgid "[BootlogoChanger] previewPicture changed"
msgstr "[BootlogoChanger] пешнамоишТасвир тағир ёфт"

msgid "[BootlogoChanger] randomization of bootlogos activated"
msgstr "[BootlogoChanger] тасодуфии bootlogos фаъол карда шуд"

msgid "[BootlogoChanger] randomization of bootlogos deactivated"
msgstr "[BootlogoChanger] тасодуфии bootlogos ғайрифаъол карда шуд"

msgid "[BootlogoChanger] randomization: bootlogo found"
msgstr "[BootlogoChanger] тасодуфӣ: bootlogo ёфт"

msgid "[BootlogoChanger] selected bootlogos"
msgstr "[BootlogoChanger] bootlogos интихобшуда"

msgid "deinstall"
msgstr "нест кунед"

msgid "found"
msgstr "ёфт"

msgid "install"
msgstr "насб кунед"

msgid "missing"
msgstr "гумшуда"

msgid "off"
msgstr "хомӯш"

msgid "on"
msgstr "дар"
