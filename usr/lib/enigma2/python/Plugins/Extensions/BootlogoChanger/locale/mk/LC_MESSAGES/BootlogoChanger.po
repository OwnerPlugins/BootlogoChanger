msgid "Activate the debug-output on console"
msgstr "Активирајте го излезот за отстранување грешки на конзолата"

msgid "Bootlogo is excluded from random selection"
msgstr "Бутлогото е исклучено од случаен избор"

msgid "Bootlogo is included in random selection"
msgstr "Бутлогото е вклучено во случаен избор"

msgid "Cancel"
msgstr "Откажи"

msgid "Choose random bootlogo at the start of the box"
msgstr "Изберете случајно бутлого на почетокот на полето"

msgid "Copy logofiles failed"
msgstr "Копирањето на логодатотеките не успеа"

msgid "Current bootlogo"
msgstr "Тековно бутлого"

msgid "Debugmode"
msgstr "Режим за отстранување грешки"

msgid "Deinstallation of FFmpeg failed"
msgstr "Деинсталирањето на FFmpeg не успеа"

msgid "Delete current mvi-files before changing bootlogo"
msgstr "Избришете ги тековните mvi-датотеки пред да го промените бутлогото"

msgid "Directory with bootlogo folders"
msgstr "Директориум со папки за бутлого"

msgid "Display duration of the status messages (sec)"
msgstr "Прикажување на времетраењето на статусните пораки (сек)"

msgid "Easily switch between different bootlogos"
msgstr "Лесно префрлајте се помеѓу различни бутлога"

msgid "Exclude"
msgstr "Исклучи"

msgid "Exit plugin without saving"
msgstr "Излезете од приклучокот без зачувување"

msgid "FFmpeg is needed to generate thumbnails from the mvi files"
msgstr "FFmpeg е потребен за генерирање на сликички од датотеките mvi"

msgid "FFmpeg ist missing, no preview pictures available - there is an option to install it in the stettings"
msgstr "Недостасува FFmpeg, нема достапни слики за преглед - постои опција да се инсталира во поставките"

msgid "FFmpeg removed successfully"
msgstr "FFmpeg е успешно отстранет"

msgid "FFmpeg successfully installed"
msgstr "FFmpeg е успешно инсталиран"

msgid "First delete the mvi-files of the current bootlogo then copy the files of the new one"
msgstr "Прво избришете ги mvi-датотеките од тековното бутлого, а потоа копирајте ги датотеките на новото"

msgid "Found bootlogos"
msgstr "Пронајдени бутлога"

msgid "Full screen view the selected bootlogo"
msgstr "Приказ на цел екран на избраното бутолого"

msgid "Hide directories without 'mvi'-files"
msgstr "Скриј директориуми без 'mvi'-датотеки"

msgid "Hide empty directories"
msgstr "Скриј празни директориуми"

msgid "How many seconds should status messages be displayed (1-60 sec)"
msgstr "Колку секунди треба да се прикажат статусните пораки (1-60 секунди)"

msgid "Include"
msgstr "Вклучи"

msgid "Include or exlude logo in random choice"
msgstr "Вклучете или исклучете го логото во случаен избор"

msgid "Included Screens"
msgstr "Вклучени екрани"

msgid "Install/deinstall ffmpeg"
msgstr "Инсталирај/деинсталирај ffmpeg"

msgid "Installation of FFmpeg failed"
msgstr "Инсталирањето на FFmpeg не успеа"

msgid "No bootlogos found in directory"
msgstr "Не се најдени бутлога во директориумот"

msgid "OK"
msgstr "Во ред"

msgid "Open settings"
msgstr "Отворете ги поставките"

msgid "Preview Logo"
msgstr "Преглед на логото"

msgid "Preview picture"
msgstr "Прегледајте ја сликата"

msgid "Random mode"
msgstr "Случаен режим"

msgid "Random selection at startup disabled"
msgstr "Случајниот избор при стартување е оневозможен"

msgid "Random selection at startup enabled"
msgstr "Овозможено е случаен избор при стартување"

msgid "Save Changes and exit plugin"
msgstr "Зачувајте ги промените и излезете од приклучокот"

msgid "Search for folders with boot logos in this directory"
msgstr "Пребарајте папки со логоа за подигање во овој директориум"

msgid "Which bootlogos should be displayed?"
msgstr "Кои бутолога треба да се прикажат?"

msgid "Which logo should be displayed as a preview picture?"
msgstr "Кое лого треба да се прикаже како слика за преглед?"

msgid "[BootlogoChanger] activated new bootlogo"
msgstr "[BootlogoChanger] активираше ново подигање"

msgid "[BootlogoChanger] activating new bootlogo failed"
msgstr "Активирањето на новото лого на [BootlogoChanger] не успеа"

msgid "[BootlogoChanger] copy failed"
msgstr "Копирањето на [BootlogoChanger] не успеа"

msgid "[BootlogoChanger] deleting old bootlogo files"
msgstr "[BootlogoChanger] бришење стари датотеки со бутлого"

msgid "[BootlogoChanger] deleting previewPicture"
msgstr "[BootlogoChanger] се брише преглед на сликата"

msgid "[BootlogoChanger] ffmpeg not found"
msgstr "[BootlogoChanger] ffmpeg не е пронајден"

msgid "[BootlogoChanger] found Bootlogos"
msgstr "[BootlogoChanger] најде Bootlogos"

msgid "[BootlogoChanger] found ffmpeg"
msgstr "[BootlogoChanger] пронајден ffmpeg"

msgid "[BootlogoChanger] no bootlogos for randomization selected"
msgstr "[BootlogoChanger] нема избрано подигање за рандомизација"

msgid "[BootlogoChanger] previewPicture changed"
msgstr "Преглед на [BootlogoChanger] Сликата е променета"

msgid "[BootlogoChanger] randomization of bootlogos activated"
msgstr "[BootlogoChanger] рандомизацијата на бутлогата е активирана"

msgid "[BootlogoChanger] randomization of bootlogos deactivated"
msgstr "[BootlogoChanger] рандомизацијата на бутлогата е деактивирана"

msgid "[BootlogoChanger] randomization: bootlogo found"
msgstr "[BootlogoChanger] рандомизација: пронајдено е бутлогото"

msgid "[BootlogoChanger] selected bootlogos"
msgstr "[BootlogoChanger] избрани бутлога"

msgid "deinstall"
msgstr "деинсталирај"

msgid "found"
msgstr "пронајден"

msgid "install"
msgstr "инсталирај"

msgid "missing"
msgstr "исчезнати"

msgid "off"
msgstr "исклучен"

msgid "on"
msgstr "на"
