msgid "Activate the debug-output on console"
msgstr "Konsolda debug-çıxışını aktivləşdirin"

msgid "Bootlogo is excluded from random selection"
msgstr "Bootloqo təsadüfi seçimdən çıxarılıb"

msgid "Bootlogo is included in random selection"
msgstr "Bootlogo təsadüfi seçimə daxildir"

msgid "Cancel"
msgstr "Ləğv et"

msgid "Choose random bootlogo at the start of the box"
msgstr "Qutunun əvvəlində təsadüfi yükləmə loqosu seçin"

msgid "Copy logofiles failed"
msgstr "Loqofaylları kopyalamaq alınmadı"

msgid "Current bootlogo"
msgstr "Cari yükləmə loqosu"

msgid "Debugmode"
msgstr "Sazlama rejimi"

msgid "Deinstallation of FFmpeg failed"
msgstr "FFmpeg-in quraşdırılması uğursuz oldu"

msgid "Delete current mvi-files before changing bootlogo"
msgstr "Bootloqonu dəyişdirməzdən əvvəl cari mvi-faylları silin"

msgid "Directory with bootlogo folders"
msgstr "Bootloqo qovluqları olan qovluq"

msgid "Display duration of the status messages (sec)"
msgstr "Status mesajlarının göstərilməsi müddəti (san)"

msgid "Easily switch between different bootlogos"
msgstr "Müxtəlif açılış loqosu arasında asanlıqla keçid edin"

msgid "Exclude"
msgstr "İstisna etmək"

msgid "Exit plugin without saving"
msgstr "Yadda saxlamadan plaqindən çıxın"

msgid "FFmpeg is needed to generate thumbnails from the mvi files"
msgstr "FFmpeg mvi fayllarından miniatürlər yaratmaq üçün lazımdır"

msgid "FFmpeg ist missing, no preview pictures available - there is an option to install it in the stettings"
msgstr "FFmpeg yoxdur, önizləmə şəkilləri mövcud deyil - onu parametrlərdə quraşdırmaq üçün seçim var"

msgid "FFmpeg removed successfully"
msgstr "FFmpeg uğurla silindi"

msgid "FFmpeg successfully installed"
msgstr "FFmpeg uğurla quraşdırıldı"

msgid "First delete the mvi-files of the current bootlogo then copy the files of the new one"
msgstr "Əvvəlcə cari bootloqonun mvi fayllarını silin, sonra yenisinin fayllarını kopyalayın"

msgid "Found bootlogos"
msgstr "Bootloqlar tapıldı"

msgid "Full screen view the selected bootlogo"
msgstr "Seçilmiş yükləmə loqosuna tam ekran baxın"

msgid "Hide directories without 'mvi'-files"
msgstr "'mvi' faylları olmayan qovluqları gizlədin"

msgid "Hide empty directories"
msgstr "Boş qovluqları gizlədin"

msgid "How many seconds should status messages be displayed (1-60 sec)"
msgstr "Status mesajları neçə saniyə göstərilməlidir (1-60 saniyə)"

msgid "Include"
msgstr "Daxil et"

msgid "Include or exlude logo in random choice"
msgstr "Təsadüfi seçimə loqo daxil edin və ya istisna edin"

msgid "Included Screens"
msgstr "Daxil Ekranlar"

msgid "Install/deinstall ffmpeg"
msgstr "Ffmpeg quraşdırın/sökün"

msgid "Installation of FFmpeg failed"
msgstr "FFmpeg quraşdırılması uğursuz oldu"

msgid "No bootlogos found in directory"
msgstr "Kataloqda heç bir bootloqo tapılmadı"

msgid "OK"
msgstr ""

msgid "Open settings"
msgstr "Parametrləri açın"

msgid "Preview Logo"
msgstr "Logonu önizləyin"

msgid "Preview picture"
msgstr "Şəklin önizləməsi"

msgid "Random mode"
msgstr "Təsadüfi rejim"

msgid "Random selection at startup disabled"
msgstr "Başlanğıcda təsadüfi seçim deaktiv edilib"

msgid "Random selection at startup enabled"
msgstr "Başlanğıcda təsadüfi seçim aktivləşdirildi"

msgid "Save Changes and exit plugin"
msgstr "Dəyişiklikləri yadda saxlayın və plaqindən çıxın"

msgid "Search for folders with boot logos in this directory"
msgstr "Bu qovluqda açılış loqoları olan qovluqları axtarın"

msgid "Which bootlogos should be displayed?"
msgstr "Hansı bootloqlar göstərilməlidir?"

msgid "Which logo should be displayed as a preview picture?"
msgstr "Hansı loqo önizləmə şəkli kimi göstərilməlidir?"

msgid "[BootlogoChanger] activated new bootlogo"
msgstr "[BootlogoChanger] yeni bootloqonu aktivləşdirdi"

msgid "[BootlogoChanger] activating new bootlogo failed"
msgstr "[BootlogoChanger] yeni bootloqonun aktivləşdirilməsi uğursuz oldu"

msgid "[BootlogoChanger] copy failed"
msgstr "[BootlogoChanger] surəti alınmadı"

msgid "[BootlogoChanger] deleting old bootlogo files"
msgstr "[BootlogoChanger] köhnə bootlogo fayllarının silinməsi"

msgid "[BootlogoChanger] deleting previewPicture"
msgstr "[BootlogoChanger] previewPicture silinir"

msgid "[BootlogoChanger] ffmpeg not found"
msgstr "[BootlogoChanger] ffmpeg tapılmadı"

msgid "[BootlogoChanger] found Bootlogos"
msgstr "[BootlogoChanger] Bootloqos tapdı"

msgid "[BootlogoChanger] found ffmpeg"
msgstr "[BootlogoChanger] ffmpeg tapdı"

msgid "[BootlogoChanger] no bootlogos for randomization selected"
msgstr "[BootlogoChanger] təsadüfiləşdirmə üçün heç bir bootloqo seçilməyib"

msgid "[BootlogoChanger] previewPicture changed"
msgstr "[BootlogoChanger] previewŞəkil dəyişdirildi"

msgid "[BootlogoChanger] randomization of bootlogos activated"
msgstr "[BootlogoChanger] bootloqların təsadüfiləşdirilməsi aktivləşdirildi"

msgid "[BootlogoChanger] randomization of bootlogos deactivated"
msgstr "[BootlogoChanger] bootloqların təsadüfiləşdirilməsi deaktiv edilib"

msgid "[BootlogoChanger] randomization: bootlogo found"
msgstr "[BootlogoChanger] təsadüfiləşdirmə: bootloqo tapıldı"

msgid "[BootlogoChanger] selected bootlogos"
msgstr "[BootlogoChanger] bootloqları seçdi"

msgid "deinstall"
msgstr "silin"

msgid "found"
msgstr "tapıldı"

msgid "install"
msgstr "quraşdırın"

msgid "missing"
msgstr "itkin"

msgid "off"
msgstr ""

msgid "on"
msgstr "haqqında"
