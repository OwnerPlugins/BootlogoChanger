msgid "Activate the debug-output on console"
msgstr "Aktywuj wyjście debugowania na konsoli"

msgid "Bootlogo is excluded from random selection"
msgstr "Bootlogo jest wykluczone z losowego wyboru"

msgid "Bootlogo is included in random selection"
msgstr "Bootlogo jest uwzględniane w losowym wyborze"

msgid "Cancel"
msgstr "Anulować"

msgid "Choose random bootlogo at the start of the box"
msgstr "Wybierz losowe logo startowe na początku pudełka"

msgid "Copy logofiles failed"
msgstr "Kopiowanie plików logo nie powiodło się"

msgid "Current bootlogo"
msgstr "Aktualne logo startowe"

msgid "Debugmode"
msgstr "Tryb debugowania"

msgid "Deinstallation of FFmpeg failed"
msgstr "Deinstalacja FFmpeg nie powiodła się"

msgid "Delete current mvi-files before changing bootlogo"
msgstr "Usuń bieżące pliki mvi przed zmianą bootlogo"

msgid "Directory with bootlogo folders"
msgstr "Katalog z folderami bootlogo"

msgid "Display duration of the status messages (sec)"
msgstr "Czas wyświetlania komunikatów o stanie (s)"

msgid "Easily switch between different bootlogos"
msgstr "Łatwe przełączanie pomiędzy różnymi logo startowymi"

msgid "Exclude"
msgstr "Wykluczać"

msgid "Exit plugin without saving"
msgstr "Wyjdź z wtyczki bez zapisywania"

msgid "FFmpeg is needed to generate thumbnails from the mvi files"
msgstr "Do generowania miniatur z plików mvi potrzebny jest FFmpeg"

msgid "FFmpeg ist missing, no preview pictures available - there is an option to install it in the stettings"
msgstr "Brakuje FFmpeg, brak zdjęć podglądu - istnieje możliwość zainstalowania go w ustawieniach"

msgid "FFmpeg removed successfully"
msgstr "FFmpeg został pomyślnie usunięty"

msgid "FFmpeg successfully installed"
msgstr "Pomyślnie zainstalowano FFmpeg"

msgid "First delete the mvi-files of the current bootlogo then copy the files of the new one"
msgstr "Najpierw usuń pliki mvi bieżącego bootlogo, a następnie skopiuj pliki nowego"

msgid "Found bootlogos"
msgstr "Znaleziono bootlogo"

msgid "Full screen view the selected bootlogo"
msgstr "Wyświetlanie na pełnym ekranie wybranego bootlogo"

msgid "Hide directories without 'mvi'-files"
msgstr "Ukryj katalogi bez plików „mvi”."

msgid "Hide empty directories"
msgstr "Ukryj puste katalogi"

msgid "How many seconds should status messages be displayed (1-60 sec)"
msgstr "Ile sekund powinny być wyświetlane komunikaty o statusie (1-60 s)"

msgid "Include"
msgstr "Włączać"

msgid "Include or exlude logo in random choice"
msgstr "Uwzględnij lub wyklucz logo w losowym wyborze"

msgid "Included Screens"
msgstr "Dołączone ekrany"

msgid "Install/deinstall ffmpeg"
msgstr "Zainstaluj/odinstaluj ffmpeg"

msgid "Installation of FFmpeg failed"
msgstr "Instalacja FFmpeg nie powiodła się"

msgid "No bootlogos found in directory"
msgstr "W katalogu nie znaleziono logo startowego"

msgid "OK"
msgstr ""

msgid "Open settings"
msgstr "Otwórz ustawienia"

msgid "Preview Logo"
msgstr "Podgląd logo"

msgid "Preview picture"
msgstr "Podgląd obrazu"

msgid "Random mode"
msgstr "Tryb losowy"

msgid "Random selection at startup disabled"
msgstr "Losowy wybór przy uruchomieniu wyłączony"

msgid "Random selection at startup enabled"
msgstr "Włączono losowy wybór przy uruchomieniu"

msgid "Save Changes and exit plugin"
msgstr "Zapisz zmiany i wyjdź z wtyczki"

msgid "Search for folders with boot logos in this directory"
msgstr "Wyszukaj w tym katalogu foldery z logo startowym"

msgid "Which bootlogos should be displayed?"
msgstr "Które bootlogo powinny być wyświetlane?"

msgid "Which logo should be displayed as a preview picture?"
msgstr "Które logo powinno wyświetlić się jako obraz podglądowy?"

msgid "[BootlogoChanger] activated new bootlogo"
msgstr "[BootlogoChanger] aktywował nowe bootlogo"

msgid "[BootlogoChanger] activating new bootlogo failed"
msgstr "[BootlogoChanger] aktywacja nowego bootlogo nie powiodła się"

msgid "[BootlogoChanger] copy failed"
msgstr "Kopiowanie [BootlogoChanger] nie powiodło się"

msgid "[BootlogoChanger] deleting old bootlogo files"
msgstr "[BootlogoChanger] usuwanie starych plików bootlogo"

msgid "[BootlogoChanger] deleting previewPicture"
msgstr "[BootlogoChanger] usuwanie podglądu obrazu"

msgid "[BootlogoChanger] ffmpeg not found"
msgstr "[BootlogoChanger] Nie znaleziono ffmpeg"

msgid "[BootlogoChanger] found Bootlogos"
msgstr "[BootlogoChanger] znalazł Bootlogo"

msgid "[BootlogoChanger] found ffmpeg"
msgstr "[BootlogoChanger] znalazł ffmpeg"

msgid "[BootlogoChanger] no bootlogos for randomization selected"
msgstr "[BootlogoChanger] Nie wybrano logo startowego do randomizacji"

msgid "[BootlogoChanger] previewPicture changed"
msgstr "[BootlogoChanger] podglądZmieniono obraz"

msgid "[BootlogoChanger] randomization of bootlogos activated"
msgstr "[BootlogoChanger] Aktywowano randomizację bootlogo"

msgid "[BootlogoChanger] randomization of bootlogos deactivated"
msgstr "[BootlogoChanger] Dezaktywowano losowość bootlogo"

msgid "[BootlogoChanger] randomization: bootlogo found"
msgstr "[BootlogoChanger] randomizacja: znaleziono bootlogo"

msgid "[BootlogoChanger] selected bootlogos"
msgstr "[BootlogoChanger] wybrane logo startowe"

msgid "deinstall"
msgstr "odinstaluj"

msgid "found"
msgstr "znaleziony"

msgid "install"
msgstr "zainstalować"

msgid "missing"
msgstr "zaginiony"

msgid "off"
msgstr "wyłączony"

msgid "on"
msgstr "NA"
