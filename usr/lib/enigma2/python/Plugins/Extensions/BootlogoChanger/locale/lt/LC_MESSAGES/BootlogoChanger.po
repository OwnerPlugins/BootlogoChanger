msgid "Activate the debug-output on console"
msgstr "Konsolėje suaktyvinkite derinimo išvestį"

msgid "Bootlogo is excluded from random selection"
msgstr "„Bootlogo“ neįtraukiamas į atsitiktinę atranką"

msgid "Bootlogo is included in random selection"
msgstr "„Bootlogo“ įtrauktas į atsitiktinį pasirinkimą"

msgid "Cancel"
msgstr "Atšaukti"

msgid "Choose random bootlogo at the start of the box"
msgstr "Laukelio pradžioje pasirinkite atsitiktinį įkrovos logotipą"

msgid "Copy logofiles failed"
msgstr "Nepavyko nukopijuoti logotipo failų"

msgid "Current bootlogo"
msgstr "Dabartinis įkrovos logotipas"

msgid "Debugmode"
msgstr "Derinimo režimas"

msgid "Deinstallation of FFmpeg failed"
msgstr "Nepavyko pašalinti FFmpeg"

msgid "Delete current mvi-files before changing bootlogo"
msgstr "Prieš keisdami įkrovos logotipą, ištrinkite esamus mvi failus"

msgid "Directory with bootlogo folders"
msgstr "Katalogas su įkrovos logotipo aplankais"

msgid "Display duration of the status messages (sec)"
msgstr "Būsenos pranešimų rodymo trukmė (sek.)"

msgid "Easily switch between different bootlogos"
msgstr "Lengvai perjunkite skirtingus įkrovos logotipus"

msgid "Exclude"
msgstr "Išskirti"

msgid "Exit plugin without saving"
msgstr "Išeikite iš papildinio neišsaugoję"

msgid "FFmpeg is needed to generate thumbnails from the mvi files"
msgstr "FFmpeg reikalingas norint generuoti miniatiūras iš mvi failų"

msgid "FFmpeg ist missing, no preview pictures available - there is an option to install it in the stettings"
msgstr "Trūksta FFmpeg, nėra peržiūros nuotraukų - yra galimybė jį įdiegti nustatymuose"

msgid "FFmpeg removed successfully"
msgstr "FFmpeg sėkmingai pašalintas"

msgid "FFmpeg successfully installed"
msgstr "FFmpeg sėkmingai įdiegtas"

msgid "First delete the mvi-files of the current bootlogo then copy the files of the new one"
msgstr "Pirmiausia ištrinkite dabartinio įkrovos logotipo mvi failus, tada nukopijuokite naujojo failus"

msgid "Found bootlogos"
msgstr "Rasti bootlogos"

msgid "Full screen view the selected bootlogo"
msgstr "Peržiūrėkite pasirinktą įkrovos logotipą visame ekrane"

msgid "Hide directories without 'mvi'-files"
msgstr "Slėpti katalogus be „mvi“ failų"

msgid "Hide empty directories"
msgstr "Slėpti tuščius katalogus"

msgid "How many seconds should status messages be displayed (1-60 sec)"
msgstr "Kiek sekundžių turėtų būti rodomi būsenos pranešimai (1–60 sek.)"

msgid "Include"
msgstr "Įtraukti"

msgid "Include or exlude logo in random choice"
msgstr "Įtraukti arba neįtraukti logotipo atsitiktiniu pasirinkimu"

msgid "Included Screens"
msgstr "Įtraukti ekranai"

msgid "Install/deinstall ffmpeg"
msgstr "Įdiekite / pašalinkite ffmpeg"

msgid "Installation of FFmpeg failed"
msgstr "Nepavyko įdiegti FFmpeg"

msgid "No bootlogos found in directory"
msgstr "Kataloge nerasta įkrovos logotipų"

msgid "OK"
msgstr "Gerai"

msgid "Open settings"
msgstr "Atidarykite nustatymus"

msgid "Preview Logo"
msgstr "Peržiūrėti logotipą"

msgid "Preview picture"
msgstr "Peržiūrėti paveikslėlį"

msgid "Random mode"
msgstr "Atsitiktinis režimas"

msgid "Random selection at startup disabled"
msgstr "Atsitiktinis pasirinkimas paleidžiant išjungtas"

msgid "Random selection at startup enabled"
msgstr "Atsitiktinis pasirinkimas paleidžiant įjungtas"

msgid "Save Changes and exit plugin"
msgstr "Išsaugokite pakeitimus ir išeikite iš papildinio"

msgid "Search for folders with boot logos in this directory"
msgstr "Šiame kataloge ieškokite aplankų su įkrovos logotipais"

msgid "Which bootlogos should be displayed?"
msgstr "Kurie įkrovos logotipai turėtų būti rodomi?"

msgid "Which logo should be displayed as a preview picture?"
msgstr "Kuris logotipas turėtų būti rodomas kaip peržiūros paveikslėlis?"

msgid "[BootlogoChanger] activated new bootlogo"
msgstr "[BootlogoChanger] suaktyvino naują įkrovos logotipą"

msgid "[BootlogoChanger] activating new bootlogo failed"
msgstr "[BootlogoChanger] nepavyko suaktyvinti naujo įkrovos logotipo"

msgid "[BootlogoChanger] copy failed"
msgstr "Nepavyko nukopijuoti [BootlogoChanger]"

msgid "[BootlogoChanger] deleting old bootlogo files"
msgstr "[BootlogoChanger] ištrina senus įkrovos logotipo failus"

msgid "[BootlogoChanger] deleting previewPicture"
msgstr "[BootlogoChanger] ištrinama peržiūros nuotrauka"

msgid "[BootlogoChanger] ffmpeg not found"
msgstr "[BootlogoChanger] ffmpeg nerastas"

msgid "[BootlogoChanger] found Bootlogos"
msgstr "[BootlogoChanger] rado Bootlogos"

msgid "[BootlogoChanger] found ffmpeg"
msgstr "[BootlogoChanger] rasta ffmpeg"

msgid "[BootlogoChanger] no bootlogos for randomization selected"
msgstr "[BootlogoChanger] Nepasirinkta atsitiktinių imčių įkrovos logotipų"

msgid "[BootlogoChanger] previewPicture changed"
msgstr "[BootlogoChanger] peržiūra Paveikslėlis pakeistas"

msgid "[BootlogoChanger] randomization of bootlogos activated"
msgstr "[BootlogoChanger] suaktyvintas įkrovos logotipų atsitiktinis atskyrimas"

msgid "[BootlogoChanger] randomization of bootlogos deactivated"
msgstr "[BootlogoChanger] atsitiktinis įkrovos logotipų nustatymas išjungtas"

msgid "[BootlogoChanger] randomization: bootlogo found"
msgstr "[BootlogoChanger] atsitiktinis atskyrimas: rastas įkrovos logotipas"

msgid "[BootlogoChanger] selected bootlogos"
msgstr "[BootlogoChanger] pasirinko įkrovos logotipus"

msgid "deinstall"
msgstr "pašalinti"

msgid "found"
msgstr "rasta"

msgid "install"
msgstr "įdiegti"

msgid "missing"
msgstr "trūksta"

msgid "off"
msgstr "išjungti"

msgid "on"
msgstr "įjungta"
