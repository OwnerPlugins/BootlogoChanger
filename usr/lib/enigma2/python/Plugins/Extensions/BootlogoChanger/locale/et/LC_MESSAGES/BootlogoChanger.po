msgid "Activate the debug-output on console"
msgstr "Aktiveerige konsoolil silumisväljund"

msgid "Bootlogo is excluded from random selection"
msgstr "Bootlogo on juhuslikust valikust välja jäetud"

msgid "Bootlogo is included in random selection"
msgstr "Bootlogo sisaldub juhuslikus valikus"

msgid "Cancel"
msgstr "Tühista"

msgid "Choose random bootlogo at the start of the box"
msgstr "Valige kasti alguses juhuslik alglaadimislogo"

msgid "Copy logofiles failed"
msgstr "Logofailide kopeerimine ebaõnnestus"

msgid "Current bootlogo"
msgstr "Praegune alglogo"

msgid "Debugmode"
msgstr ""

msgid "Deinstallation of FFmpeg failed"
msgstr "FFmpegi desinstallimine ebaõnnestus"

msgid "Delete current mvi-files before changing bootlogo"
msgstr "Enne alglaadimislogo muutmist kustutage praegused mvi-failid"

msgid "Directory with bootlogo folders"
msgstr "Kataloog alglaadimislogo kaustadega"

msgid "Display duration of the status messages (sec)"
msgstr "Olekuteadete kuvamise kestus (s)"

msgid "Easily switch between different bootlogos"
msgstr "Lihtne vahetada erinevate alglogode vahel"

msgid "Exclude"
msgstr "Välistada"

msgid "Exit plugin without saving"
msgstr "Välju pistikprogrammist salvestamata"

msgid "FFmpeg is needed to generate thumbnails from the mvi files"
msgstr "FFmpeg on vajalik mvi-failidest pisipiltide genereerimiseks"

msgid "FFmpeg ist missing, no preview pictures available - there is an option to install it in the stettings"
msgstr "FFmpeg puudub, eelvaatepilte pole saadaval - on võimalus installida see settings"

msgid "FFmpeg removed successfully"
msgstr "FFmpeg eemaldati edukalt"

msgid "FFmpeg successfully installed"
msgstr "FFmpeg edukalt installitud"

msgid "First delete the mvi-files of the current bootlogo then copy the files of the new one"
msgstr "Kõigepealt kustutage praeguse bootlogo mvi-failid ja kopeerige seejärel uue failid"

msgid "Found bootlogos"
msgstr "Leitud bootlogod"

msgid "Full screen view the selected bootlogo"
msgstr "Kuva valitud alglogo täisekraanil"

msgid "Hide directories without 'mvi'-files"
msgstr "Peida kataloogid ilma mvi-failideta"

msgid "Hide empty directories"
msgstr "Peida tühjad kataloogid"

msgid "How many seconds should status messages be displayed (1-60 sec)"
msgstr "Mitu sekundit tuleks olekuteateid kuvada (1–60 sek)"

msgid "Include"
msgstr "Kaasa"

msgid "Include or exlude logo in random choice"
msgstr "Lisage või välistage logo juhusliku valiku korral"

msgid "Included Screens"
msgstr "Kaasasolevad ekraanid"

msgid "Install/deinstall ffmpeg"
msgstr "Installige/desinstallige ffmpeg"

msgid "Installation of FFmpeg failed"
msgstr "FFmpegi installimine ebaõnnestus"

msgid "No bootlogos found in directory"
msgstr "Kataloogist ei leitud ühtegi alglaadimislogo"

msgid "OK"
msgstr ""

msgid "Open settings"
msgstr "Ava seaded"

msgid "Preview Logo"
msgstr "Logo eelvaade"

msgid "Preview picture"
msgstr "Pildi eelvaade"

msgid "Random mode"
msgstr "Juhuslik režiim"

msgid "Random selection at startup disabled"
msgstr "Juhuslik valik käivitamisel on keelatud"

msgid "Random selection at startup enabled"
msgstr "Juhuslik valik käivitamisel on lubatud"

msgid "Save Changes and exit plugin"
msgstr "Salvestage muudatused ja väljuge pistikprogrammist"

msgid "Search for folders with boot logos in this directory"
msgstr "Otsige sellest kataloogist alglaadimislogodega kaustu"

msgid "Which bootlogos should be displayed?"
msgstr "Milliseid alglogosid tuleks kuvada?"

msgid "Which logo should be displayed as a preview picture?"
msgstr "Millist logo tuleks kuvada eelvaatepildina?"

msgid "[BootlogoChanger] activated new bootlogo"
msgstr "[BootlogoChanger] aktiveeris uue alglaadimislogo"

msgid "[BootlogoChanger] activating new bootlogo failed"
msgstr "[BootlogoChanger] uue alglaadimislogo aktiveerimine ebaõnnestus"

msgid "[BootlogoChanger] copy failed"
msgstr "[BootlogoChanger] kopeerimine ebaõnnestus"

msgid "[BootlogoChanger] deleting old bootlogo files"
msgstr "[BootlogoChanger] vanade alglaadimislogo failide kustutamine"

msgid "[BootlogoChanger] deleting previewPicture"
msgstr "[BootlogoChanger] eelvaatepildi kustutamine"

msgid "[BootlogoChanger] ffmpeg not found"
msgstr "[BootlogoChanger] ffmpeg ei leitud"

msgid "[BootlogoChanger] found Bootlogos"
msgstr "[BootlogoChanger] leidis Bootlogos"

msgid "[BootlogoChanger] found ffmpeg"
msgstr "[BootlogoChanger] leidis ffmpeg"

msgid "[BootlogoChanger] no bootlogos for randomization selected"
msgstr "[BootlogoChanger] randomiseerimiseks pole valitud ühtegi alglaadimislogo"

msgid "[BootlogoChanger] previewPicture changed"
msgstr "[BootlogoChanger] eelvaadePilt muudetud"

msgid "[BootlogoChanger] randomization of bootlogos activated"
msgstr "[BootlogoChanger] alglaadimislogide randomiseerimine on aktiveeritud"

msgid "[BootlogoChanger] randomization of bootlogos deactivated"
msgstr "[BootlogoChanger] alglaadimislogide randomiseerimine deaktiveeritud"

msgid "[BootlogoChanger] randomization: bootlogo found"
msgstr "[BootlogoChanger] randomiseerimine: bootlogo leitud"

msgid "[BootlogoChanger] selected bootlogos"
msgstr "[BootlogoChanger] on valitud alglaadimislogod"

msgid "deinstall"
msgstr "desinstallida"

msgid "found"
msgstr "leitud"

msgid "install"
msgstr "installida"

msgid "missing"
msgstr "puudu"

msgid "off"
msgstr "välja"

msgid "on"
msgstr "sisse"
