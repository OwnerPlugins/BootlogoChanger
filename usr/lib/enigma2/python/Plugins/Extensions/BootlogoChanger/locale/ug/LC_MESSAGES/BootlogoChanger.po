msgid "Activate the debug-output on console"
msgstr "كونترول سۇپىسىدىكى ھەل قىلىش-چىقىرىشنى قوزغىتىڭ"

msgid "Bootlogo is excluded from random selection"
msgstr "Bootlogo ئىختىيارى تاللاشتىن چىقىرىۋېتىلدى"

msgid "Bootlogo is included in random selection"
msgstr "Bootlogo تاسادىپىي تاللاشقا كىرگۈزۈلگەن"

msgid "Cancel"
msgstr "بىكار قىلىش"

msgid "Choose random bootlogo at the start of the box"
msgstr "رامكىنىڭ بېشىدا تاسادىپىي bootlogo نى تاللاڭ"

msgid "Copy logofiles failed"
msgstr "لوگىكىلىق ھۆججەتلەرنى كۆچۈرۈش مەغلۇب بولدى"

msgid "Current bootlogo"
msgstr "نۆۋەتتىكى bootlogo"

msgid "Debugmode"
msgstr "ھەل قىلىش ھالىتى"

msgid "Deinstallation of FFmpeg failed"
msgstr "FFmpeg نى ئۆچۈرۈش مەغلۇب بولدى"

msgid "Delete current mvi-files before changing bootlogo"
msgstr "Bootlogo نى ئۆزگەرتىشتىن بۇرۇن نۆۋەتتىكى mvi- ھۆججەتلەرنى ئۆچۈرۈڭ"

msgid "Directory with bootlogo folders"
msgstr "Bootlogo ھۆججەت قىسقۇچلىرى بىلەن مۇندەرىجە"

msgid "Display duration of the status messages (sec)"
msgstr "ھالەت ئۇچۇرلىرىنىڭ داۋاملىشىش ۋاقتى (سېكۇنت)"

msgid "Easily switch between different bootlogos"
msgstr "ئوخشىمىغان قوزغىتىش پروگراممىلىرىنى ئاسانلا ئالماشتۇرۇڭ"

msgid "Exclude"
msgstr "چىقىرىۋېتىڭ"

msgid "Exit plugin without saving"
msgstr "ساقلىماي قىستۇرمىدىن چىقىڭ"

msgid "FFmpeg is needed to generate thumbnails from the mvi files"
msgstr "Mvi ھۆججىتىدىن كىچىك كۆرۈنۈش ھاسىل قىلىش ئۈچۈن FFmpeg لازىم"

msgid "FFmpeg ist missing, no preview pictures available - there is an option to install it in the stettings"
msgstr "FFmpeg يوقاپ كەتتى ، ئالدىن كۆرۈش رەسىملىرى يوق - ئۇنى تەڭشەكلەرگە ئورنىتىش ھوقۇقى بار"

msgid "FFmpeg removed successfully"
msgstr "FFmpeg مۇۋەپپەقىيەتلىك ئۆچۈرۈلدى"

msgid "FFmpeg successfully installed"
msgstr "FFmpeg مۇۋەپپەقىيەتلىك قاچىلاندى"

msgid "First delete the mvi-files of the current bootlogo then copy the files of the new one"
msgstr "ئالدى بىلەن نۆۋەتتىكى bootlogo نىڭ mvi ھۆججىتىنى ئۆچۈرۈڭ ، ئاندىن يېڭى ھۆججەتلەرنى كۆچۈرۈڭ"

msgid "Found bootlogos"
msgstr "Bootlogos تېپىلدى"

msgid "Full screen view the selected bootlogo"
msgstr "تاللانغان bootlogo نى تولۇق ئېكران كۆرۈنۈشى"

msgid "Hide directories without 'mvi'-files"
msgstr "مۇندەرىجىنى 'mvi' ھۆججىتىسىز يوشۇرۇڭ"

msgid "Hide empty directories"
msgstr "قۇرۇق مۇندەرىجىنى يوشۇرۇڭ"

msgid "How many seconds should status messages be displayed (1-60 sec)"
msgstr "ھالەت ئۇچۇرلىرى قانچە سېكۇنت كۆرسىتىلىشى كېرەك (1-60 سېكۇنت)"

msgid "Include"
msgstr "ئۆز ئىچىگە ئالىدۇ"

msgid "Include or exlude logo in random choice"
msgstr "بەلگىنى ئىختىيارى تاللاشتا قوشۇڭ ياكى چىقىرىۋېتىڭ"

msgid "Included Screens"
msgstr "ئېكراننى ئۆز ئىچىگە ئالىدۇ"

msgid "Install/deinstall ffmpeg"
msgstr "Ffmpeg نى قاچىلاش / ئۆچۈرۈش"

msgid "Installation of FFmpeg failed"
msgstr "FFmpeg نى قاچىلاش مەغلۇب بولدى"

msgid "No bootlogos found in directory"
msgstr "مۇندەرىجىدە ھېچقانداق bootlogos تېپىلمىدى"

msgid "OK"
msgstr "ماقۇل"

msgid "Open settings"
msgstr "تەڭشەكلەرنى ئېچىڭ"

msgid "Preview Logo"
msgstr "ئالدىن كۆرۈش بەلگىسى"

msgid "Preview picture"
msgstr "رەسىمنى ئالدىن كۆرۈش"

msgid "Random mode"
msgstr "ئىختىيارى ھالەت"

msgid "Random selection at startup disabled"
msgstr "قوزغالغاندا ئىختىيارى تاللاش چەكلەنگەن"

msgid "Random selection at startup enabled"
msgstr "قوزغالغاندا ئىختىيارى تاللاش قوزغىتىلدى"

msgid "Save Changes and exit plugin"
msgstr "ئۆزگەرتىشلەرنى ساقلاش ۋە قىستۇرمىدىن چېكىنىش"

msgid "Search for folders with boot logos in this directory"
msgstr "بۇ مۇندەرىجىدە قوزغىتىش بەلگىسى بار ھۆججەت قىسقۇچلارنى ئىزدەڭ"

msgid "Which bootlogos should be displayed?"
msgstr "قايسى قوزغىتىش پروگراممىلىرىنى كۆرسىتىش كېرەك؟"

msgid "Which logo should be displayed as a preview picture?"
msgstr "قايسى بەلگە ئالدىن كۆرۈش رەسىمى سۈپىتىدە كۆرسىتىلىشى كېرەك؟"

msgid "[BootlogoChanger] activated new bootlogo"
msgstr "[BootlogoChanger] يېڭى قوزغىتىش پروگراممىسى قوزغىتىلدى"

msgid "[BootlogoChanger] activating new bootlogo failed"
msgstr "[BootlogoChanger] يېڭى bootlogo نى قوزغىتىش مەغلۇب بولدى"

msgid "[BootlogoChanger] copy failed"
msgstr "[BootlogoChanger] كۆپەيتىلگەن"

msgid "[BootlogoChanger] deleting old bootlogo files"
msgstr "[BootlogoChanger] كونا bootlogo ھۆججەتلىرىنى ئۆچۈرۈۋاتىدۇ"

msgid "[BootlogoChanger] deleting previewPicture"
msgstr "[BootlogoChanger] ئالدىن كۆرۈش رەسىمنى ئۆچۈرۈش"

msgid "[BootlogoChanger] ffmpeg not found"
msgstr "[BootlogoChanger] ffmpeg تېپىلمىدى"

msgid "[BootlogoChanger] found Bootlogos"
msgstr "[BootlogoChanger] Bootlogos نى تاپتى"

msgid "[BootlogoChanger] found ffmpeg"
msgstr "[BootlogoChanger] ffmpeg نى تاپتى"

msgid "[BootlogoChanger] no bootlogos for randomization selected"
msgstr "[BootlogoChanger] ئىختىيارىي تاللانما تاللانما يوق"

msgid "[BootlogoChanger] previewPicture changed"
msgstr "[BootlogoChanger] previewPicture ئۆزگەرتىلدى"

msgid "[BootlogoChanger] randomization of bootlogos activated"
msgstr "[BootlogoChanger] قوزغىتىش پروگراممىسىنىڭ ئىختىيارىي قوزغىتىلدى"

msgid "[BootlogoChanger] randomization of bootlogos deactivated"
msgstr "[BootlogoChanger] bootlogos نىڭ ئىختىيارىيلىقى توختىتىلدى"

msgid "[BootlogoChanger] randomization: bootlogo found"
msgstr "[BootlogoChanger] ئىختىيارىيلاشتۇرۇش: bootlogo تېپىلدى"

msgid "[BootlogoChanger] selected bootlogos"
msgstr "[BootlogoChanger] تاللانغان bootlogos"

msgid "deinstall"
msgstr "ئۆچۈرۈش"

msgid "found"
msgstr "تېپىلدى"

msgid "install"
msgstr "قاچىلاش"

msgid "missing"
msgstr "يوقاپ كەتتى"

msgid "off"
msgstr ""

msgid "on"
msgstr ""
