msgid "Activate the debug-output on console"
msgstr "Activatz la sortida de desbugatge sus la consola"

msgid "Bootlogo is excluded from random selection"
msgstr "Bootlogo es exclús de la seleccion aleatòria"

msgid "Bootlogo is included in random selection"
msgstr "Bootlogo es inclus dins la seleccion aleatòria"

msgid "Cancel"
msgstr "Anullar"

msgid "Choose random bootlogo at the start of the box"
msgstr "Causissètz lo bootlogo aleatòri al començament de la bóstia"

msgid "Copy logofiles failed"
msgstr "La còpia dels fichièrs de lògo a fracassat"

msgid "Current bootlogo"
msgstr "Logo d'arrenjament actual"

msgid "Debugmode"
msgstr "Mòde de depuracion"

msgid "Deinstallation of FFmpeg failed"
msgstr "La desinstallacion de FFmpeg a fracassat"

msgid "Delete current mvi-files before changing bootlogo"
msgstr "Suprimir los fichièrs mvi actuals abans de cambiar lo logo d'aviada"

msgid "Directory with bootlogo folders"
msgstr "Repertòri amb de dorsièrs de bootlogo"

msgid "Display duration of the status messages (sec)"
msgstr "Durada d'afichatge dels messatges d'estat (sec)"

msgid "Easily switch between different bootlogos"
msgstr "Cambiar aisidament entre diferents bootlogos"

msgid "Exclude"
msgstr "Exclure"

msgid "Exit plugin without saving"
msgstr "Sortir del plugin sens enregistrar"

msgid "FFmpeg is needed to generate thumbnails from the mvi files"
msgstr "FFmpeg es necessari per generar de miniaturas a partir dels fichièrs mvi"

msgid "FFmpeg ist missing, no preview pictures available - there is an option to install it in the stettings"
msgstr "FFmpeg manca, pas d'imatges d'apercebut disponibles - i a una opcion per l'installar dins los stettings"

msgid "FFmpeg removed successfully"
msgstr "FFmpeg suprimit amb succès"

msgid "FFmpeg successfully installed"
msgstr "FFmpeg installat amb succès"

msgid "First delete the mvi-files of the current bootlogo then copy the files of the new one"
msgstr "D'en primièr suprimissètz los fichièrs mvi del bootlogo actual puèi copiatz los fichièrs del novèl"

msgid "Found bootlogos"
msgstr "Trobats los lògos d'arrenjament"

msgid "Full screen view the selected bootlogo"
msgstr "Afichatge a l'ecran complet lo bootlogo seleccionat"

msgid "Hide directories without 'mvi'-files"
msgstr "Amagar los repertòris sens fichièrs 'mvi'"

msgid "Hide empty directories"
msgstr "Amagar los repertòris vuèges"

msgid "How many seconds should status messages be displayed (1-60 sec)"
msgstr "Quantas segondas los messatges d'estat deurián èsser afichats (1-60 seg)"

msgid "Include"
msgstr "Inclure"

msgid "Include or exlude logo in random choice"
msgstr "Inclure o exclure lo logotip dins una causida aleatòria"

msgid "Included Screens"
msgstr "Ecrans incluses"

msgid "Install/deinstall ffmpeg"
msgstr "Installar/desinstallar ffmpeg"

msgid "Installation of FFmpeg failed"
msgstr "L'installacion de FFmpeg a fracassat"

msgid "No bootlogos found in directory"
msgstr "Cap de bootlogos pas trobat dins lo repertòri"

msgid "OK"
msgstr "ÒC BEN"

msgid "Open settings"
msgstr "Dobrir los paramètres"

msgid "Preview Logo"
msgstr "Logotip d'apercebut"

msgid "Preview picture"
msgstr "Imatge d'apercebut"

msgid "Random mode"
msgstr "Mòde aleatòri"

msgid "Random selection at startup disabled"
msgstr "Seleccion aleatòria a l'aviada desactivada"

msgid "Random selection at startup enabled"
msgstr "Seleccion aleatòria a l'aviada activada"

msgid "Save Changes and exit plugin"
msgstr "Enregistrar las modificacions e sortir del plugin"

msgid "Search for folders with boot logos in this directory"
msgstr "Cercar de dorsièrs amb de lògos d'aviada dins aqueste repertòri"

msgid "Which bootlogos should be displayed?"
msgstr "Quins bootlogos deurián èsser afichats?"

msgid "Which logo should be displayed as a preview picture?"
msgstr "Quin lògo deu èsser afichat coma imatge d'apercebut?"

msgid "[BootlogoChanger] activated new bootlogo"
msgstr "[BootlogoChanger] a activat lo novèl bootlogo"

msgid "[BootlogoChanger] activating new bootlogo failed"
msgstr "[BootlogoChanger] l'activacion del novèl lògo d'arrenjament a fracassat"

msgid "[BootlogoChanger] copy failed"
msgstr "[BootlogoChanger] còpia a fracassat"

msgid "[BootlogoChanger] deleting old bootlogo files"
msgstr "[BootlogoChanger] suprimissent los ancians fichièrs d'arrenjament"

msgid "[BootlogoChanger] deleting previewPicture"
msgstr "[BootlogoChanger] suprimissent l'apercebutImatge"

msgid "[BootlogoChanger] ffmpeg not found"
msgstr "[BootlogoChanger] ffmpeg pas trobat"

msgid "[BootlogoChanger] found Bootlogos"
msgstr "[BootlogoChanger] trobèt los Bootlogos"

msgid "[BootlogoChanger] found ffmpeg"
msgstr "[BootlogoChanger] trobat ffmpeg"

msgid "[BootlogoChanger] no bootlogos for randomization selected"
msgstr "[BootlogoChanger] pas de bootlogos per l'aleatorizacion seleccionats"

msgid "[BootlogoChanger] previewPicture changed"
msgstr "[BootlogoChanger] apercebutImatge modificat"

msgid "[BootlogoChanger] randomization of bootlogos activated"
msgstr "[BootlogoChanger] aleatorizacion dels bootlogos activat"

msgid "[BootlogoChanger] randomization of bootlogos deactivated"
msgstr "[BootlogoChanger] l'aleatorizacion dels bootlogos desactivada"

msgid "[BootlogoChanger] randomization: bootlogo found"
msgstr "[BootlogoChanger] aleatorizacion: bootlogo trobat"

msgid "[BootlogoChanger] selected bootlogos"
msgstr "[BootlogoChanger] los logos d'arrenjament seleccionats"

msgid "deinstall"
msgstr "desinstallar"

msgid "found"
msgstr "fondar"

msgid "install"
msgstr "installar"

msgid "missing"
msgstr "mancant"

msgid "off"
msgstr "desactivat"

msgid "on"
msgstr "sus"
