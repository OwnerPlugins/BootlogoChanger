msgid "Activate the debug-output on console"
msgstr "Activa a saída de depuración na consola"

msgid "Bootlogo is excluded from random selection"
msgstr "Bootlogo está excluído da selección aleatoria"

msgid "Bootlogo is included in random selection"
msgstr "Bootlogo está incluído na selección aleatoria"

msgid "Cancel"
msgstr "Cancelar"

msgid "Choose random bootlogo at the start of the box"
msgstr "Escolla bootlogo aleatorio ao comezo da caixa"

msgid "Copy logofiles failed"
msgstr "Produciuse un erro ao copiar os ficheiros de logotipo"

msgid "Current bootlogo"
msgstr "Bootlogo actual"

msgid "Debugmode"
msgstr "Modo de depuración"

msgid "Deinstallation of FFmpeg failed"
msgstr "Fallou a desinstalación de FFmpeg"

msgid "Delete current mvi-files before changing bootlogo"
msgstr "Elimina os ficheiros mvi actuais antes de cambiar o logotipo de arranque"

msgid "Directory with bootlogo folders"
msgstr "Directorio con carpetas bootlogo"

msgid "Display duration of the status messages (sec)"
msgstr "Mostrar a duración das mensaxes de estado (s)"

msgid "Easily switch between different bootlogos"
msgstr "Cambia facilmente entre diferentes logotipos de arranque"

msgid "Exclude"
msgstr "Excluír"

msgid "Exit plugin without saving"
msgstr "Sae do complemento sen gardar"

msgid "FFmpeg is needed to generate thumbnails from the mvi files"
msgstr "FFmpeg é necesario para xerar miniaturas dos ficheiros mvi"

msgid "FFmpeg ist missing, no preview pictures available - there is an option to install it in the stettings"
msgstr "Falta FFmpeg, non hai imaxes de vista previa dispoñibles; hai unha opción para instalalo nos axustes"

msgid "FFmpeg removed successfully"
msgstr "FFmpeg eliminouse correctamente"

msgid "FFmpeg successfully installed"
msgstr "FFmpeg instalouse correctamente"

msgid "First delete the mvi-files of the current bootlogo then copy the files of the new one"
msgstr "Primeiro elimine os ficheiros mvi do logotipo de arranque actual e despois copie os ficheiros do novo"

msgid "Found bootlogos"
msgstr "Bootlogos atopados"

msgid "Full screen view the selected bootlogo"
msgstr "Ver a pantalla completa o logotipo de arranque seleccionado"

msgid "Hide directories without 'mvi'-files"
msgstr "Ocultar directorios sen ficheiros 'mvi'"

msgid "Hide empty directories"
msgstr "Ocultar directorios baleiros"

msgid "How many seconds should status messages be displayed (1-60 sec)"
msgstr "Cantos segundos deberían mostrarse as mensaxes de estado (1-60 segundos)"

msgid "Include"
msgstr "Incluír"

msgid "Include or exlude logo in random choice"
msgstr "Incluír ou excluír o logotipo nunha elección aleatoria"

msgid "Included Screens"
msgstr "Pantallas incluídas"

msgid "Install/deinstall ffmpeg"
msgstr "Instalar/desinstalar ffmpeg"

msgid "Installation of FFmpeg failed"
msgstr "Fallou a instalación de FFmpeg"

msgid "No bootlogos found in directory"
msgstr "Non se atoparon logos de arranque no directorio"

msgid "OK"
msgstr ""

msgid "Open settings"
msgstr "Abra a configuración"

msgid "Preview Logo"
msgstr "Vista previa do logotipo"

msgid "Preview picture"
msgstr "Vista previa da imaxe"

msgid "Random mode"
msgstr "Modo aleatorio"

msgid "Random selection at startup disabled"
msgstr "Desactivouse a selección aleatoria ao inicio"

msgid "Random selection at startup enabled"
msgstr "Selección aleatoria ao inicio habilitada"

msgid "Save Changes and exit plugin"
msgstr "Garda os cambios e sae do complemento"

msgid "Search for folders with boot logos in this directory"
msgstr "Busca cartafoles con logotipos de arranque neste directorio"

msgid "Which bootlogos should be displayed?"
msgstr "Que logos de arranque deberían mostrarse?"

msgid "Which logo should be displayed as a preview picture?"
msgstr "Que logotipo debería mostrarse como imaxe de vista previa?"

msgid "[BootlogoChanger] activated new bootlogo"
msgstr "[BootlogoChanger] activou o novo logotipo de arranque"

msgid "[BootlogoChanger] activating new bootlogo failed"
msgstr "[BootlogoChanger] fallou ao activar o novo logotipo de arranque"

msgid "[BootlogoChanger] copy failed"
msgstr "Fallou a copia de [BootlogoChanger]."

msgid "[BootlogoChanger] deleting old bootlogo files"
msgstr "[BootlogoChanger] eliminando ficheiros de logo de arranque antigos"

msgid "[BootlogoChanger] deleting previewPicture"
msgstr "[BootlogoChanger] eliminando a vista previa da imaxe"

msgid "[BootlogoChanger] ffmpeg not found"
msgstr "[BootlogoChanger] ffmpeg non atopado"

msgid "[BootlogoChanger] found Bootlogos"
msgstr "[BootlogoChanger] atopou Bootlogos"

msgid "[BootlogoChanger] found ffmpeg"
msgstr "[BootlogoChanger] atopou ffmpeg"

msgid "[BootlogoChanger] no bootlogos for randomization selected"
msgstr "[BootlogoChanger] non se seleccionaron logos de arranque para a aleatorización"

msgid "[BootlogoChanger] previewPicture changed"
msgstr "[BootlogoChanger] vista previaA imaxe cambiou"

msgid "[BootlogoChanger] randomization of bootlogos activated"
msgstr "[BootlogoChanger] aleatorización de logotipos de arranque activada"

msgid "[BootlogoChanger] randomization of bootlogos deactivated"
msgstr "[BootlogoChanger] desactivouse a aleatorización dos logotipos de arranque"

msgid "[BootlogoChanger] randomization: bootlogo found"
msgstr "[BootlogoChanger] aleatorización: bootlogo atopado"

msgid "[BootlogoChanger] selected bootlogos"
msgstr "[BootlogoChanger] logotipos de arranque seleccionados"

msgid "deinstall"
msgstr "desinstalar"

msgid "found"
msgstr "atopado"

msgid "install"
msgstr "instalar"

msgid "missing"
msgstr "desaparecido"

msgid "off"
msgstr "apagado"

