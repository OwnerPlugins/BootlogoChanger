msgid "Activate the debug-output on console"
msgstr "Aktiválja a hibakeresési kimenetet a konzolon"

msgid "Bootlogo is excluded from random selection"
msgstr "A Bootlogo ki van zárva a véletlenszerű kiválasztásból"

msgid "Bootlogo is included in random selection"
msgstr "A Bootlogo szerepel a véletlenszerű kiválasztásban"

msgid "Cancel"
msgstr "Mégsem"

msgid "Choose random bootlogo at the start of the box"
msgstr "Válassza ki a véletlenszerű bootlogót a doboz elején"

msgid "Copy logofiles failed"
msgstr "A logófájlok másolása nem sikerült"

msgid "Current bootlogo"
msgstr "Jelenlegi bootlogó"

msgid "Debugmode"
msgstr "Hibakeresési mód"

msgid "Deinstallation of FFmpeg failed"
msgstr "Az FFmpeg eltávolítása nem sikerült"

msgid "Delete current mvi-files before changing bootlogo"
msgstr "A bootlogo megváltoztatása előtt törölje az aktuális mvi-fájlokat"

msgid "Directory with bootlogo folders"
msgstr "Könyvtár bootlogo mappákkal"

msgid "Display duration of the status messages (sec)"
msgstr "Az állapotüzenetek megjelenítési időtartama (mp)"

msgid "Easily switch between different bootlogos"
msgstr "Könnyen válthat a különböző bootlogók között"

msgid "Exclude"
msgstr "Kizárás"

msgid "Exit plugin without saving"
msgstr "Mentés nélkül lépjen ki a bővítményből"

msgid "FFmpeg is needed to generate thumbnails from the mvi files"
msgstr "Az FFmpeg szükséges a miniatűrök létrehozásához az mvi fájlokból"

msgid "FFmpeg ist missing, no preview pictures available - there is an option to install it in the stettings"
msgstr "Az FFmpeg hiányzik, nincs előnézeti kép - lehetőség van a telepítésre a beállításokban"

msgid "FFmpeg removed successfully"
msgstr "Az FFmpeg sikeresen eltávolítva"

msgid "FFmpeg successfully installed"
msgstr "Az FFmpeg sikeresen telepítve"

msgid "First delete the mvi-files of the current bootlogo then copy the files of the new one"
msgstr "Először törölje az aktuális bootlogó mvi-fájljait, majd másolja az új fájljait"

msgid "Found bootlogos"
msgstr "Bootlogókat találtam"

msgid "Full screen view the selected bootlogo"
msgstr "A kiválasztott rendszerindító logó teljes képernyős megtekintése"

msgid "Hide directories without 'mvi'-files"
msgstr "Könyvtárak elrejtése 'mvi'-fájlok nélkül"

msgid "Hide empty directories"
msgstr "Üres könyvtárak elrejtése"

msgid "How many seconds should status messages be displayed (1-60 sec)"
msgstr "Hány másodpercig jelenjenek meg az állapotüzenetek (1-60 mp)"

msgid "Include"
msgstr "Tartalmazza"

msgid "Include or exlude logo in random choice"
msgstr "A logó felvétele vagy kizárása véletlenszerű választásnál"

msgid "Included Screens"
msgstr "Mellékelt képernyők"

msgid "Install/deinstall ffmpeg"
msgstr "Az ffmpeg telepítése/eltávolítása"

msgid "Installation of FFmpeg failed"
msgstr "Az FFmpeg telepítése nem sikerült"

msgid "No bootlogos found in directory"
msgstr "Nem található bootlogos a könyvtárban"

msgid "OK"
msgstr "RENDBEN"

msgid "Open settings"
msgstr "Nyissa meg a beállításokat"

msgid "Preview Logo"
msgstr "Embléma előnézete"

msgid "Preview picture"
msgstr "Előnézeti kép"

msgid "Random mode"
msgstr "Véletlenszerű mód"

msgid "Random selection at startup disabled"
msgstr "Véletlenszerű kiválasztás indításkor letiltva"

msgid "Random selection at startup enabled"
msgstr "Véletlenszerű kiválasztás indításkor engedélyezve"

msgid "Save Changes and exit plugin"
msgstr "Mentse a változtatásokat, és lépjen ki a beépülő modulból"

msgid "Search for folders with boot logos in this directory"
msgstr "Keresse meg a rendszerindító logókat tartalmazó mappákat ebben a könyvtárban"

msgid "Which bootlogos should be displayed?"
msgstr "Milyen bootlogókat kell megjeleníteni?"

msgid "Which logo should be displayed as a preview picture?"
msgstr "Melyik logót kell megjeleníteni előnézeti képként?"

msgid "[BootlogoChanger] activated new bootlogo"
msgstr "[BootlogoChanger] aktiválta az új bootlogót"

msgid "[BootlogoChanger] activating new bootlogo failed"
msgstr "[BootlogoChanger] az új bootlogo aktiválása nem sikerült"

msgid "[BootlogoChanger] copy failed"
msgstr "A [BootlogoChanger] másolása nem sikerült"

msgid "[BootlogoChanger] deleting old bootlogo files"
msgstr "[BootlogoChanger] a régi bootlogo fájlok törlése"

msgid "[BootlogoChanger] deleting previewPicture"
msgstr "[BootlogoChanger] previewPicture törlése"

msgid "[BootlogoChanger] ffmpeg not found"
msgstr "[BootlogoChanger] ffmpeg nem található"

msgid "[BootlogoChanger] found Bootlogos"
msgstr "A [BootlogoChanger] Bootlogos-t talált"

msgid "[BootlogoChanger] found ffmpeg"
msgstr "[BootlogoChanger] talált ffmpeg"

msgid "[BootlogoChanger] no bootlogos for randomization selected"
msgstr "[BootlogoChanger] nincs kiválasztva véletlenszerű rendszerindítási logó"

msgid "[BootlogoChanger] previewPicture changed"
msgstr "[BootlogoChanger] előnézet A kép megváltozott"

msgid "[BootlogoChanger] randomization of bootlogos activated"
msgstr "[BootlogoChanger] a bootlogók véletlenszerűsítése aktiválva"

msgid "[BootlogoChanger] randomization of bootlogos deactivated"
msgstr "[BootlogoChanger] A rendszerindító logók véletlenszerűsítése deaktiválva"

msgid "[BootlogoChanger] randomization: bootlogo found"
msgstr "[BootlogoChanger] randomizálás: bootlogo található"

msgid "[BootlogoChanger] selected bootlogos"
msgstr "[BootlogoChanger] kiválasztott rendszerindító logókat"

msgid "deinstall"
msgstr "távolítsa el"

msgid "found"
msgstr "talált"

msgid "install"
msgstr "telepíteni"

msgid "missing"
msgstr "hiányzó"

msgid "off"
msgstr "le"

msgid "on"
msgstr "-on"
