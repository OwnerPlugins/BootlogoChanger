msgid "Activate the debug-output on console"
msgstr "Gníomhachtaigh an t-aschur dífhabhtaithe ar an gconsól"

msgid "Bootlogo is excluded from random selection"
msgstr "Eisiatar Bootlogo ó roghnú randamach"

msgid "Bootlogo is included in random selection"
msgstr "Tá Bootlogo san áireamh sa roghnú randamach"

msgid "Cancel"
msgstr "Cealaigh"

msgid "Choose random bootlogo at the start of the box"
msgstr "Roghnaigh bootlogo randamach ag tús an bhosca"

msgid "Copy logofiles failed"
msgstr "Theip ar chóipeáil comhaid lógó"

msgid "Current bootlogo"
msgstr "Lógó tosaithe reatha"

msgid "Debugmode"
msgstr "Modh dífhabhtaithe"

msgid "Deinstallation of FFmpeg failed"
msgstr "Theip ar dhíshuiteáil FFmpeg"

msgid "Delete current mvi-files before changing bootlogo"
msgstr "Scrios mvi-comhaid reatha sula n-athraítear bootlogo"

msgid "Directory with bootlogo folders"
msgstr "Eolaire le fillteáin bootlogo"

msgid "Display duration of the status messages (sec)"
msgstr "Fad taispeána na dteachtaireachtaí stádais (soicind)"

msgid "Easily switch between different bootlogos"
msgstr "Athraigh go héasca idir bootlogos éagsúla"

msgid "Exclude"
msgstr "Eisigh"

msgid "Exit plugin without saving"
msgstr "Scoir an breiseán gan sábháil"

msgid "FFmpeg is needed to generate thumbnails from the mvi files"
msgstr "Tá FFmpeg ag teastáil chun mionsamhlacha a ghiniúint ó na comhaid mvi"

msgid "FFmpeg ist missing, no preview pictures available - there is an option to install it in the stettings"
msgstr "Níl FFmpeg ist in easnamh, níl aon pictiúir réamhamhairc ar fáil - tá rogha ann é a shuiteáil sna stettings"

msgid "FFmpeg removed successfully"
msgstr "Baineadh FFmpeg go rathúil"

msgid "FFmpeg successfully installed"
msgstr "D'éirigh le suiteáil FFmpeg"

msgid "First delete the mvi-files of the current bootlogo then copy the files of the new one"
msgstr "Ar dtús scrios na comhaid mvi den bootlogo reatha agus ansin cóipeáil comhaid an ceann nua"

msgid "Found bootlogos"
msgstr "Aimsíodh lógónna"

msgid "Full screen view the selected bootlogo"
msgstr "Amharc ar an lógó tosaithe ar scáileán iomlán"

msgid "Hide directories without 'mvi'-files"
msgstr "Folaigh na heolairí gan comhaid 'mvi'"

msgid "Hide empty directories"
msgstr "Folaigh eolaire folamh"

msgid "How many seconds should status messages be displayed (1-60 sec)"
msgstr "Cé mhéad soicind ar cheart teachtaireachtaí stádais a thaispeáint (1-60 soicind)"

msgid "Include"
msgstr "Cuir san áireamh"

msgid "Include or exlude logo in random choice"
msgstr "Cuir an lógó san áireamh i rogha randamach"

msgid "Included Screens"
msgstr "Scáileáin san áireamh"

msgid "Install/deinstall ffmpeg"
msgstr "Suiteáil/díshuiteáil ffmpeg"

msgid "Installation of FFmpeg failed"
msgstr "Theip ar shuiteáil FFmpeg"

msgid "No bootlogos found in directory"
msgstr "Níor aimsíodh lógónna ar bith sa chomhadlann"

msgid "OK"
msgstr "ceart go leor"

msgid "Open settings"
msgstr "Oscail socruithe"

msgid "Preview Logo"
msgstr "Lógó Réamhamhairc"

msgid "Preview picture"
msgstr "Réamhamharc pictiúr"

msgid "Random mode"
msgstr "Modh randamach"

msgid "Random selection at startup disabled"
msgstr "Díchumasaíodh roghnú randamach ag an am tosaithe"

msgid "Random selection at startup enabled"
msgstr "Roghnú randamach ag am tosaithe cumasaithe"

msgid "Save Changes and exit plugin"
msgstr "Sábháil Athruithe agus fág an breiseán"

msgid "Search for folders with boot logos in this directory"
msgstr "Cuardaigh fillteáin le lógónna tosaithe san eolaire seo"

msgid "Which bootlogos should be displayed?"
msgstr "Cé na bootlogos ba chóir a thaispeáint?"

msgid "Which logo should be displayed as a preview picture?"
msgstr "Cén lógó ar cheart a thaispeáint mar phictiúr réamhamhairc?"

msgid "[BootlogoChanger] activated new bootlogo"
msgstr "Chuir [BootlogoChanger] bootlogo nua i ngníomh"

msgid "[BootlogoChanger] activating new bootlogo failed"
msgstr "Theip ar [BootlogoChanger] bootlogo nua a ghníomhachtú"

msgid "[BootlogoChanger] copy failed"
msgstr "Theip ar chóip [BootlogoChanger]"

msgid "[BootlogoChanger] deleting old bootlogo files"
msgstr "[BootlogoChanger] ag scriosadh seanchomhaid bootlogo"

msgid "[BootlogoChanger] deleting previewPicture"
msgstr "[BootlogoChanger] previewPicture á scriosadh"

msgid "[BootlogoChanger] ffmpeg not found"
msgstr "[BootlogoChanger] ffmpeg gan aimsiú"

msgid "[BootlogoChanger] found Bootlogos"
msgstr "[BootlogoChanger] aimsíodh Bootlogos"

msgid "[BootlogoChanger] found ffmpeg"
msgstr "Fuair ​​[BootlogoChanger] ffmpeg"

msgid "[BootlogoChanger] no bootlogos for randomization selected"
msgstr "[BootlogoChanger] níl aon bootlogos le haghaidh randamú roghnaithe"

msgid "[BootlogoChanger] previewPicture changed"
msgstr "[BootlogoChanger] previewPicture athraithe"

msgid "[BootlogoChanger] randomization of bootlogos activated"
msgstr "[BootlogoChanger] randamachú bootlogos gníomhachtaithe"

msgid "[BootlogoChanger] randomization of bootlogos deactivated"
msgstr "[BootlogoChanger] randamachú bootlogos díghníomhachtaithe"

msgid "[BootlogoChanger] randomization: bootlogo found"
msgstr "[BootlogoChanger] randamú: bootlogo aimsithe"

msgid "[BootlogoChanger] selected bootlogos"
msgstr "[BootlogoChanger] bootlogos roghnaithe"

msgid "deinstall"
msgstr "dhíshuiteáil"

msgid "found"
msgstr "fuarthas"

msgid "install"
msgstr "shuiteáil"

msgid "missing"
msgstr "ar iarraidh"

msgid "off"
msgstr "as"

msgid "on"
msgstr "ar"
