msgid "Activate the debug-output on console"
msgstr "Активуйте вихід налагодження на консолі"

msgid "Bootlogo is excluded from random selection"
msgstr "Bootlogo виключено з випадкового вибору"

msgid "Bootlogo is included in random selection"
msgstr "Bootlogo включено у випадковий вибір"

msgid "Cancel"
msgstr "Скасувати"

msgid "Choose random bootlogo at the start of the box"
msgstr "Виберіть випадковий логотип завантаження на початку вікна"

msgid "Copy logofiles failed"
msgstr "Не вдалося скопіювати файли логотипів"

msgid "Current bootlogo"
msgstr "Поточний bootlogo"

msgid "Debugmode"
msgstr "Режим налагодження"

msgid "Deinstallation of FFmpeg failed"
msgstr "Помилка деінсталяції FFmpeg"

msgid "Delete current mvi-files before changing bootlogo"
msgstr "Видаліть поточні mvi-файли перед зміною bootlogo"

msgid "Directory with bootlogo folders"
msgstr "Каталог з папками bootlogo"

msgid "Display duration of the status messages (sec)"
msgstr "Тривалість відображення повідомлень про статус (сек)"

msgid "Easily switch between different bootlogos"
msgstr "Легко перемикайтеся між різними логотипами завантаження"

msgid "Exclude"
msgstr "Виключити"

msgid "Exit plugin without saving"
msgstr "Вийти з плагіна без збереження"

msgid "FFmpeg is needed to generate thumbnails from the mvi files"
msgstr "FFmpeg потрібен для створення мініатюр із файлів mvi"

msgid "FFmpeg ist missing, no preview pictures available - there is an option to install it in the stettings"
msgstr "FFmpeg відсутній, зображення для попереднього перегляду недоступні - є можливість встановити його в налаштуваннях"

msgid "FFmpeg removed successfully"
msgstr "FFmpeg успішно видалено"

msgid "FFmpeg successfully installed"
msgstr "FFmpeg успішно встановлено"

msgid "First delete the mvi-files of the current bootlogo then copy the files of the new one"
msgstr "Спочатку видаліть mvi-файли поточного bootlogo, а потім скопіюйте файли нового"

msgid "Found bootlogos"
msgstr "Знайдено bootlogos"

msgid "Full screen view the selected bootlogo"
msgstr "Повноекранний перегляд вибраного bootlogo"

msgid "Hide directories without 'mvi'-files"
msgstr "Приховати каталоги без 'mvi'-файлів"

msgid "Hide empty directories"
msgstr "Приховати порожні каталоги"

msgid "How many seconds should status messages be displayed (1-60 sec)"
msgstr "Скільки секунд мають відображатися повідомлення про стан (1-60 секунд)"

msgid "Include"
msgstr "Включати"

msgid "Include or exlude logo in random choice"
msgstr "Включати або виключати логотип у випадковому виборі"

msgid "Included Screens"
msgstr "Включені екрани"

msgid "Install/deinstall ffmpeg"
msgstr "Встановити/видалити ffmpeg"

msgid "Installation of FFmpeg failed"
msgstr "Помилка встановлення FFmpeg"

msgid "No bootlogos found in directory"
msgstr "У каталозі не знайдено логотипів завантаження"

msgid "OK"
msgstr "добре"

msgid "Open settings"
msgstr "Відкрийте налаштування"

msgid "Preview Logo"
msgstr "Попередній перегляд логотипу"

msgid "Preview picture"
msgstr "Попередній перегляд зображення"

msgid "Random mode"
msgstr "Випадковий режим"

msgid "Random selection at startup disabled"
msgstr ""

msgid "Random selection at startup enabled"
msgstr ""

msgid "Save Changes and exit plugin"
msgstr "Зберегти зміни та вийти з плагіна"

msgid "Search for folders with boot logos in this directory"
msgstr "Шукайте папки з логотипами завантаження в цьому каталозі"

msgid "Which bootlogos should be displayed?"
msgstr "Які завантажувальні логотипи мають відображатися?"

msgid "Which logo should be displayed as a preview picture?"
msgstr "Який логотип має відображатися як зображення попереднього перегляду?"

msgid "[BootlogoChanger] activated new bootlogo"
msgstr "[BootlogoChanger] активував новий логотип завантаження"

msgid "[BootlogoChanger] activating new bootlogo failed"
msgstr "[BootlogoChanger] не вдалося активувати новий логотип завантаження"

msgid "[BootlogoChanger] copy failed"
msgstr "Помилка копіювання [BootlogoChanger]."

msgid "[BootlogoChanger] deleting old bootlogo files"
msgstr "[BootlogoChanger] видалення старих файлів bootlogo"

msgid "[BootlogoChanger] deleting previewPicture"
msgstr "[BootlogoChanger] видалення попереднього перегляду зображення"

msgid "[BootlogoChanger] ffmpeg not found"
msgstr "[BootlogoChanger] ffmpeg не знайдено"

msgid "[BootlogoChanger] found Bootlogos"
msgstr "[BootlogoChanger] знайдено Bootlogos"

msgid "[BootlogoChanger] found ffmpeg"
msgstr "[BootlogoChanger] знайдено ffmpeg"

msgid "[BootlogoChanger] no bootlogos for randomization selected"
msgstr "[BootlogoChanger] не вибрано логотипи завантаження для рандомізації"

msgid "[BootlogoChanger] previewPicture changed"
msgstr "Попередній перегляд [BootlogoChanger]Зображення змінено"

msgid "[BootlogoChanger] randomization of bootlogos activated"
msgstr "[BootlogoChanger] рандомізація bootlogos активована"

msgid "[BootlogoChanger] randomization of bootlogos deactivated"
msgstr "[BootlogoChanger] рандомізацію bootlogos вимкнено"

msgid "[BootlogoChanger] randomization: bootlogo found"
msgstr "[BootlogoChanger] рандомізація: bootlogo знайдено"

msgid "[BootlogoChanger] selected bootlogos"
msgstr "[BootlogoChanger] вибрані логотипи завантаження"

msgid "deinstall"
msgstr "видалити"

msgid "found"
msgstr "знайдено"

msgid "install"
msgstr "встановити"

msgid "missing"
msgstr "відсутній"

msgid "off"
msgstr "вимкнено"

msgid "on"
msgstr "на"
