msgid "Activate the debug-output on console"
msgstr "បើកដំណើរការលទ្ធផលបំបាត់កំហុសនៅលើកុងសូល។"

msgid "Bootlogo is excluded from random selection"
msgstr "Bootlogo ត្រូវបានដកចេញពីការជ្រើសរើសចៃដន្យ"

msgid "Bootlogo is included in random selection"
msgstr "Bootlogo ត្រូវបានរួមបញ្ចូលក្នុងការជ្រើសរើសដោយចៃដន្យ"

msgid "Cancel"
msgstr "បោះបង់"

msgid "Choose random bootlogo at the start of the box"
msgstr "ជ្រើសរើស bootlogo ចៃដន្យនៅដើមប្រអប់"

msgid "Copy logofiles failed"
msgstr "ការចម្លងឯកសារឡូហ្គោបានបរាជ័យ"

msgid "Current bootlogo"
msgstr "bootlogo បច្ចុប្បន្ន"

msgid "Debugmode"
msgstr "របៀបបំបាត់កំហុស"

msgid "Deinstallation of FFmpeg failed"
msgstr "ការដំឡើង FFmpeg បានបរាជ័យ"

msgid "Delete current mvi-files before changing bootlogo"
msgstr "លុបឯកសារ mvi-បច្ចុប្បន្ន មុនពេលផ្លាស់ប្តូរ bootlogo"

msgid "Directory with bootlogo folders"
msgstr "ថតឯកសារដែលមាន bootlogo"

msgid "Display duration of the status messages (sec)"
msgstr "បង្ហាញរយៈពេលនៃសារស្ថានភាព (វិនាទី)"

msgid "Easily switch between different bootlogos"
msgstr "ងាយស្រួលប្តូររវាង bootlogos ផ្សេងៗគ្នា"

msgid "Exclude"
msgstr "មិនរាប់បញ្ចូល"

msgid "Exit plugin without saving"
msgstr "ចេញពីកម្មវិធីជំនួយដោយមិនរក្សាទុក"

msgid "FFmpeg is needed to generate thumbnails from the mvi files"
msgstr "FFmpeg គឺចាំបាច់ដើម្បីបង្កើតរូបភាពតូចៗពីឯកសារ mvi"

msgid "FFmpeg ist missing, no preview pictures available - there is an option to install it in the stettings"
msgstr "បាត់ FFmpeg មិនមានរូបភាពមើលជាមុនទេ - មានជម្រើសដើម្បីដំឡើងវានៅក្នុងការកំណត់"

msgid "FFmpeg removed successfully"
msgstr "FFmpeg ត្រូវបានដកចេញដោយជោគជ័យ"

msgid "FFmpeg successfully installed"
msgstr "FFmpeg បានដំឡើងដោយជោគជ័យ"

msgid "First delete the mvi-files of the current bootlogo then copy the files of the new one"
msgstr "ដំបូងលុបឯកសារ mvi នៃ bootlogo បច្ចុប្បន្ន បន្ទាប់មកចម្លងឯកសារថ្មី។"

msgid "Found bootlogos"
msgstr "បានរកឃើញ bootlogos"

msgid "Full screen view the selected bootlogo"
msgstr "មើលពេញអេក្រង់ bootlogo ដែលបានជ្រើសរើស"

msgid "Hide directories without 'mvi'-files"
msgstr "លាក់ថតដោយគ្មានឯកសារ 'mvi'"

msgid "Hide empty directories"
msgstr "លាក់ថតទទេ"

msgid "How many seconds should status messages be displayed (1-60 sec)"
msgstr "តើត្រូវបង្ហាញសារស្ថានភាពប៉ុន្មានវិនាទី (1-60 វិ)"

msgid "Include"
msgstr "រួមបញ្ចូល"

msgid "Include or exlude logo in random choice"
msgstr "រួមបញ្ចូល ឬដករូបសញ្ញាជាជម្រើសចៃដន្យ"

msgid "Included Screens"
msgstr "អេក្រង់រួមបញ្ចូល"

msgid "Install/deinstall ffmpeg"
msgstr "ដំឡើង/លុប ffmpeg"

msgid "Installation of FFmpeg failed"
msgstr "ការដំឡើង FFmpeg បានបរាជ័យ"

msgid "No bootlogos found in directory"
msgstr "រកមិនឃើញ bootlogos នៅក្នុងថតឯកសារទេ។"

msgid "OK"
msgstr "យល់ព្រម"

msgid "Open settings"
msgstr "បើកការកំណត់"

msgid "Preview Logo"
msgstr "មើលរូបសញ្ញាជាមុន"

msgid "Preview picture"
msgstr "មើលរូបភាពជាមុន"

msgid "Random mode"
msgstr "របៀបចៃដន្យ"

msgid "Random selection at startup disabled"
msgstr "ការជ្រើសរើសចៃដន្យនៅពេលចាប់ផ្តើមត្រូវបានបិទ"

msgid "Random selection at startup enabled"
msgstr "ការជ្រើសរើសចៃដន្យនៅពេលចាប់ផ្តើមត្រូវបានបើក"

msgid "Save Changes and exit plugin"
msgstr "រក្សាទុកការផ្លាស់ប្តូរ ហើយចេញពីកម្មវិធីជំនួយ"

msgid "Search for folders with boot logos in this directory"
msgstr "ស្វែងរកថតដែលមានឡូហ្គោចាប់ផ្ដើមនៅក្នុងថតនេះ។"

msgid "Which bootlogos should be displayed?"
msgstr "តើ bootlogos មួយណាគួរបង្ហាញ?"

msgid "Which logo should be displayed as a preview picture?"
msgstr "តើរូបសញ្ញាមួយណាគួរបង្ហាញជារូបភាពមើលជាមុន?"

msgid "[BootlogoChanger] activated new bootlogo"
msgstr "[BootlogoChanger] បានធ្វើឱ្យសកម្ម bootlogo ថ្មី។"

msgid "[BootlogoChanger] activating new bootlogo failed"
msgstr "[BootlogoChanger] ការធ្វើឱ្យសកម្ម bootlogo ថ្មីបានបរាជ័យ"

msgid "[BootlogoChanger] copy failed"
msgstr "ការចម្លង [BootlogoChanger] បានបរាជ័យ"

msgid "[BootlogoChanger] deleting old bootlogo files"
msgstr "[BootlogoChanger] ការលុបឯកសារ bootlogo ចាស់"

msgid "[BootlogoChanger] deleting previewPicture"
msgstr "[BootlogoChanger] ការលុបរូបភាពមើលជាមុន"

msgid "[BootlogoChanger] ffmpeg not found"
msgstr "[BootlogoChanger] ffmpeg រកមិនឃើញទេ។"

msgid "[BootlogoChanger] found Bootlogos"
msgstr "[BootlogoChanger] បានរកឃើញ Bootlogos"

msgid "[BootlogoChanger] found ffmpeg"
msgstr "[BootlogoChanger] បានរកឃើញ ffmpeg"

msgid "[BootlogoChanger] no bootlogos for randomization selected"
msgstr "[BootlogoChanger] គ្មាន bootlogos សម្រាប់ចៃដន្យដែលបានជ្រើសរើសទេ។"

msgid "[BootlogoChanger] previewPicture changed"
msgstr "[BootlogoChanger] ការមើលជាមុនរូបភាពបានផ្លាស់ប្តូរ"

msgid "[BootlogoChanger] randomization of bootlogos activated"
msgstr "[BootlogoChanger] ការចៃដន្យនៃ bootlogos ត្រូវបានធ្វើឱ្យសកម្ម"

msgid "[BootlogoChanger] randomization of bootlogos deactivated"
msgstr "[BootlogoChanger] ការចៃដន្យនៃ bootlogos ត្រូវបានធ្វើឱ្យអសកម្ម"

msgid "[BootlogoChanger] randomization: bootlogo found"
msgstr "[BootlogoChanger] ចៃដន្យ៖ បានរកឃើញ bootlogo"

msgid "[BootlogoChanger] selected bootlogos"
msgstr "[BootlogoChanger] បានជ្រើសរើស bootlogos"

msgid "deinstall"
msgstr "លុប"

msgid "found"
msgstr "បានរកឃើញ"

msgid "install"
msgstr "ដំឡើង"

msgid "missing"
msgstr "បាត់"

msgid "off"
msgstr "បិទ"

msgid "on"
msgstr "នៅលើ"
